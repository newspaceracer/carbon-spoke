---
// carbon-checked: Carbon ships no avatar/identity component; an initials chip is
// the reusable home for person identity in contact cards and the comment thread.
// Identity chip — initials by default, or a supplied glyph (e.g. a building for a
// facility). Neutral, token-styled, presentational only. The initials rule and the
// chip's STYLES are shared (src/lib/avatar.ts + the global `.avatar` rules in
// src/styles/theme.css) so this component and the client-rendered chips never drift.
import { initials as computeInitials } from '../lib/avatar';
interface Props {
  name: string;
  /** Diameter token step: sm (1.5rem), md (2rem), or lg (4rem, for identity headers). */
  size?: 'sm' | 'md' | 'lg';
  /** Render this inline SVG instead of initials — for non-person entities. */
  icon?: string;
}
const { name, size = 'md', icon } = Astro.props;
---

<span class:list={['avatar', `avatar--${size}`]} aria-hidden="true">
  {icon ? <Fragment set:html={icon} /> : computeInitials(name)}
</span>
