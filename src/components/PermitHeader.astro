---
// Permit detail header — editorial layout on the page background (no tiles):
// number eyebrow, name, status indicator, action buttons, badge rows, then an
// at-a-glance strip of labeled facts (plain data, not boxed content pieces).
import type { Badge } from '../data/permit';
import type { DirectoryUser } from '../data/user';
import { withBase } from '../lib/base';
import Avatar from './Avatar.astro';

interface Stat {
  label: string;
  value: string;
}

/** One reviewer on the analysis team. A `status` other than "Pending review"
 *  (i.e. a timestamp) means their analysis is complete. `addedAt` is when they
 *  joined the permit; `lastEditedAt` is their latest activity while still
 *  pending (absent = nothing since they were added). */
interface TeamMember {
  id: string;
  role: string;
  name: string;
  detail: string;
  status: string;
  addedAt?: string;
  lastEditedAt?: string;
  highlight?: boolean;
}

interface Props {
  id: string;
  name: string;
  organization: string;
  status: { label: string; kind: string };
  infoTags: Badge[];
  flagTags: Badge[];
  stats: Stat[];
  /** Dates the applicant requested — shown as a reminder in the approve modal
   *  and used to prefill its confirmation date-range picker (ISO pair). */
  requestedWindow: { start: string; end: string; startISO: string; endISO: string };
  /** OPTIONAL. When present, the header gains a clickable "Analysis review"
   *  key-metric (how many reviewers are done) that opens a modal listing the
   *  team, their completion, and a control to add reviewers. Passed by the
   *  finalize (under-review) view; omitted on the read-only detail page, which
   *  carries its own roster in the Overview tab. */
  analysisTeam?: TeamMember[];
  /** The user directory the add-reviewer control draws from (required when
   *  analysisTeam is passed). */
  directory?: DirectoryUser[];
}

const {
  id, name, organization, status, infoTags, flagTags, stats, requestedWindow,
  analysisTeam, directory = [],
} = Astro.props;

// An amendment reuses the whole application flow, prefilled from this permit and
// numbered with an "-A" suffix — offered only once the permit is Active.
const amendHref = withBase(`/apply?amend=${id}`);

// ── Analysis-review metric (only when analysisTeam is supplied) ──
// "Done" = a member whose status is a timestamp, not the "Pending review"
// sentinel. Completion drives the header meter + the modal summary.
const isDone = (m: TeamMember) => m.status !== 'Pending review';
// The stacked status cell: a state label + a date/time line below it. Done →
// the completion timestamp. Pending → last activity, or when they were added if
// there's been none.
const reviewMeta = (m: TeamMember) => {
  const done = isDone(m);
  return {
    done,
    statusLabel: done ? 'Analysis complete' : 'Pending review',
    when: done
      ? m.status
      : m.lastEditedAt
        ? `Last edited ${m.lastEditedAt}`
        : `Added ${m.addedAt ?? '—'}`,
  };
};
const reviewTotal = analysisTeam?.length ?? 0;
const reviewDone = analysisTeam?.filter(isDone).length ?? 0;
const reviewAllDone = reviewTotal > 0 && reviewDone === reviewTotal;
// The add-reviewer combo lists directory users not already on the team.
const onTeam = new Set(analysisTeam?.map((m) => m.id));
const eligibleUsers = directory
  .filter((u) => !onTeam.has(u.id))
  .sort((a, b) => a.name.localeCompare(b.name));
// Shared with the detail page's roster (removed/added edits).
const teamStorageKey = `permit-team-${id}`;
---

<header class="banner cds--g100" id="permit-banner" data-permit-id={id} data-status={status.label} data-letter-url={withBase('/final-letter')}>
  <div class="banner__inner">
  <div class="banner__crumb"><slot name="breadcrumb" /></div>
  <div class="banner__main">
    <div class="banner__lead">
      <p class="banner__eyebrow t-heading-compact-01">{organization}</p>
      <h1 class="banner__title t-heading-05">{name}</h1>
      <div class="banner__id-row">
        <span class="banner__number t-heading-03">{id}</span>
        <cds-icon-indicator class="permit-status-indicator" size="20" kind={status.kind} label={status.label}></cds-icon-indicator>
      </div>
      <div class="banner__tags">
        {infoTags.map((tag) => <cds-tag type={tag.type} size="md">{tag.label}</cds-tag>)}
        {flagTags.map((tag) => (
          <cds-tag type={tag.type} size="lg">
            <svg slot="icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" width="16" height="16" aria-hidden="true">
              <path d="M14.5,14h-13c-0.2,0-0.3-0.1-0.4-0.2c-0.1-0.2-0.1-0.3,0-0.5l6.5-12C7.7,1,8,0.9,8.2,1.1c0.1,0,0.2,0.1,0.2,0.2l6.5,12 c0.1,0.2,0.1,0.3,0,0.5C14.9,13.9,14.7,14,14.5,14z M2.3,13h11.3L8,2.5L2.3,13z"/>
              <path d="M7.5 6H8.5V9.5H7.5z"/>
              <path d="M8,10.8c-0.4,0-0.8,0.3-0.8,0.8s0.3,0.8,0.8,0.8c0.4,0,0.8-0.3,0.8-0.8S8.4,10.8,8,10.8z"/>
            </svg>
            {tag.label}
          </cds-tag>
        ))}
      </div>
    </div>

    <!-- Actions depend on where the permit sits in the workflow — only the set for
         the current status is shown (the script toggles by [data-when]):
           • Under review     → Approve (primary) + Request changes / Reject in the menu
           • Out for signature → Sign permit
           • Active            → Request amendment (the applicant's next move)
           • Changes requested / Rejected → no decision remains here
         tooltip-alignment=bottom: the caret's tooltip defaults to opening upward,
         which is clipped once the header is a pinned bar — open it downward. -->
    <div class="banner__actions">
      <cds-combo-button data-when="Under review" class="permit-actions" size="md" label="Approve permit" menu-alignment="bottom-end" tooltip-alignment="bottom">
        <cds-menu>
          <cds-menu-item label="Request changes"></cds-menu-item>
          <cds-menu-item label="Download"></cds-menu-item>
          <cds-menu-item-divider></cds-menu-item-divider>
          <cds-menu-item label="Reject permit" kind="danger"></cds-menu-item>
        </cds-menu>
      </cds-combo-button>
      <cds-button data-when="Out for signature" class="permit-action-sign" size="md" hidden>Sign permit</cds-button>
      <cds-button data-when="Active" class="permit-action-amend" size="md" href={amendHref} hidden>Request amendment</cds-button>
    </div>
  </div>

  <div class="banner__facts">
    <dl class="banner__stats">
      {stats.map((s) => (
        <div class="stat">
          <dt class="stat__label t-label-01">{s.label}</dt>
          <dd class="stat__value t-body-01">{s.value}</dd>
        </div>
      ))}
    </dl>

    {analysisTeam && (
      <!-- Key metric: at-a-glance analysis-review completion. The whole tile is a
           button that opens the roster modal (Carbon ships no clickable-metric →
           dialog control; a clickable-tile is a navigation link, not a dialog
           trigger). carbon-checked: dialog-opening metric tile. -->
      <button type="button" class="analysis-metric" id="analysis-metric" aria-haspopup="dialog">
        <cds-progress-bar
          id="analysis-metric-bar"
          class="analysis-metric__bar"
          label="Analysis review"
          helper-text={`${reviewDone} of ${reviewTotal} reviewers done`}
          value={reviewDone}
          max={reviewTotal}
          size="small"
          status={reviewAllDone ? 'finished' : 'active'}
        ></cds-progress-bar>
        <span class="analysis-metric__cta t-label-01">
          View team
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" width="16" height="16" aria-hidden="true"><path d="M11 8L6 3 5.3 3.7 9.6 8l-4.3 4.3L6 13z"/></svg>
        </span>
      </button>
    )}
  </div>
  </div>
</header>

<!-- Compact bar — a SEPARATE, position:fixed bar (constant height, out of normal
     flow) that fades in once the full header above has scrolled away. Because it
     never enters document flow, showing/hiding it can't change the page height,
     so it can't trigger the scroll-anchoring feedback that makes a *resizing*
     sticky header oscillate. Shows number + requested window + the action. -->
<div class="compactbar cds--g100" id="permit-compactbar" aria-hidden="true">
  <div class="compactbar__inner">
    <span class="compactbar__number t-heading-03">{id}</span>
    <cds-icon-indicator class="permit-status-indicator" size="16" kind={status.kind} label={status.label}></cds-icon-indicator>
    <span class="compactbar__window t-body-01">{requestedWindow.start} – {requestedWindow.end}</span>
    <div class="compactbar__spacer"></div>
    <cds-combo-button data-when="Under review" class="permit-actions" size="sm" label="Approve permit" menu-alignment="bottom-end" tooltip-alignment="bottom">
      <cds-menu>
        <cds-menu-item label="Request changes"></cds-menu-item>
        <cds-menu-item label="Download"></cds-menu-item>
        <cds-menu-item-divider></cds-menu-item-divider>
        <cds-menu-item label="Reject permit" kind="danger"></cds-menu-item>
      </cds-menu>
    </cds-combo-button>
    <cds-button data-when="Out for signature" class="permit-action-sign" size="sm" hidden>Sign permit</cds-button>
    <cds-button data-when="Active" class="permit-action-amend" size="sm" href={amendHref} hidden>Request amendment</cds-button>
  </div>
</div>

<!-- Confirmation dialogs for the two decision actions. Overlays live outside
     normal flow; Carbon owns the focus trap + return and the accessible heading. -->
<cds-modal id="approve-permit-modal" size="md">
  <cds-modal-header>
    <cds-modal-close-button></cds-modal-close-button>
    <cds-modal-label>Permit {id}</cds-modal-label>
    <cds-modal-heading>Approve this permit?</cds-modal-heading>
  </cds-modal-header>
  <cds-modal-body>
    <cds-stack gap="7">
      <p class="t-body-01">
        Approving authorizes the applicant to begin the requested research and
        collection under the stated conditions. The applicant and all assigned
        reviewers will be notified.
      </p>

      <!-- Effective validity window the reviewer confirms — prefilled with the
           requested dates, editable. Range mode is auto-detected by the from/to
           inputs; the container `value` seeds both (ISO `start/end`). The
           requested dates repeat below as a reminder. -->
      <cds-stack gap="3">
        <cds-date-picker id="approve-window" value={`${requestedWindow.startISO}/${requestedWindow.endISO}`}>
          <cds-date-picker-input
            kind="from"
            label-text="Permit start date"
            placeholder="mm/dd/yyyy"
          ></cds-date-picker-input>
          <cds-date-picker-input
            kind="to"
            label-text="Permit end date"
            placeholder="mm/dd/yyyy"
          ></cds-date-picker-input>
        </cds-date-picker>
        <p class="requested-reminder t-label-01">
          Applicant requested {requestedWindow.start} – {requestedWindow.end}
        </p>
      </cds-stack>

      <!-- CEQA determination — a required either/or, so a radio group, defaulting
           to N/A (the common case for scientific collection permits). -->
      <cds-radio-button-group
        name="ceqa"
        legend-text="CEQA"
        orientation="horizontal"
        value="na"
      >
        <cds-radio-button label-text="Yes" value="yes"></cds-radio-button>
        <cds-radio-button label-text="N/A" value="na"></cds-radio-button>
      </cds-radio-button-group>
    </cds-stack>
  </cds-modal-body>
  <cds-modal-footer>
    <cds-modal-footer-button kind="secondary" data-modal-close>Cancel</cds-modal-footer-button>
    <cds-modal-footer-button kind="primary" id="approve-confirm" data-modal-close>Approve permit</cds-modal-footer-button>
  </cds-modal-footer>
</cds-modal>

<cds-modal id="sign-permit-modal" size="sm">
  <cds-modal-header>
    <cds-modal-close-button></cds-modal-close-button>
    <cds-modal-label>Permit {id}</cds-modal-label>
    <cds-modal-heading>Record the signed permit?</cds-modal-heading>
  </cds-modal-header>
  <cds-modal-body>
    <p class="t-body-01">
      Confirm the applicant has signed and returned the permit. This activates it:
      the permit becomes valid and the applicant can begin the authorized work.
    </p>
  </cds-modal-body>
  <cds-modal-footer>
    <cds-modal-footer-button kind="secondary" data-modal-close>Cancel</cds-modal-footer-button>
    <cds-modal-footer-button kind="primary" id="sign-confirm" data-modal-close>Mark as signed</cds-modal-footer-button>
  </cds-modal-footer>
</cds-modal>

<cds-modal id="request-changes-modal" size="md">
  <cds-modal-header>
    <cds-modal-close-button></cds-modal-close-button>
    <cds-modal-label>Permit {id}</cds-modal-label>
    <cds-modal-heading>Request changes</cds-modal-heading>
  </cds-modal-header>
  <cds-modal-body>
    <cds-stack gap="7">
      <p class="t-body-01">
        Return the application to the applicant with the items to address.
        They’ll be notified and can resubmit once the requested changes are made.
      </p>

      <!-- Reasons are not mutually exclusive, so a checkbox group. -->
      <cds-checkbox-group legend-text="What’s needed">
        <cds-checkbox value="dpr65a" label-text="DPR65A form submission"></cds-checkbox>
        <cds-checkbox value="dpr65b" label-text="DPR65B form submission"></cds-checkbox>
        <cds-checkbox
          value="missing-docs"
          label-text="Additional documentation requested / missing documents"
        ></cds-checkbox>
        <cds-checkbox
          value="other"
          label-text="Other information or changes requested"
        ></cds-checkbox>
      </cds-checkbox-group>

      <cds-textarea
        label="Additional information"
        placeholder="Describe what the applicant needs to change or provide…"
        rows="4"
      ></cds-textarea>
    </cds-stack>
  </cds-modal-body>
  <cds-modal-footer>
    <cds-modal-footer-button kind="secondary" data-modal-close>Cancel</cds-modal-footer-button>
    <cds-modal-footer-button kind="primary" id="request-confirm" data-modal-close>Send request</cds-modal-footer-button>
  </cds-modal-footer>
</cds-modal>

<cds-modal id="reject-permit-modal" size="sm" alert>
  <cds-modal-header>
    <cds-modal-close-button></cds-modal-close-button>
    <cds-modal-label>Permit {id}</cds-modal-label>
    <cds-modal-heading>Reject this permit?</cds-modal-heading>
  </cds-modal-header>
  <cds-modal-body>
    <p class="t-body-01">
      Rejecting closes this application. The applicant will be notified and must
      submit a new application to reapply. This can’t be undone.
    </p>
  </cds-modal-body>
  <cds-modal-footer>
    <cds-modal-footer-button kind="secondary" data-modal-close>Cancel</cds-modal-footer-button>
    <cds-modal-footer-button kind="danger" id="reject-confirm" data-modal-close>Reject permit</cds-modal-footer-button>
  </cds-modal-footer>
</cds-modal>

{analysisTeam && (
  <cds-modal id="analysis-team-modal" size="md">
    <cds-modal-header>
      <cds-modal-close-button></cds-modal-close-button>
      <cds-modal-label>Permit {id}</cds-modal-label>
      <cds-modal-heading>Analysis review</cds-modal-heading>
    </cds-modal-header>
    <cds-modal-body>
      <cds-stack gap="7">
        <cds-progress-bar
          id="analysis-modal-bar"
          label="Reviews complete"
          helper-text={`${reviewDone} of ${reviewTotal} reviewers done`}
          value={reviewDone}
          max={reviewTotal}
          status={reviewAllDone ? 'finished' : 'active'}
        ></cds-progress-bar>

        <!-- Add a directory user to the review team. Sits ABOVE the roster so its
             dropdown opens down into the list area (not off the modal's bottom
             edge, where the body's scroll would clip it). Only existing users;
             the combo rebuilds after each change to exclude whoever's already on. -->
        <form class="team-add" id="analysis-add">
          <cds-combo-box
            id="analysis-add-select"
            class="team-add__select"
            title-text="Add a reviewer"
            label="Search staff by name…"
          >
            {eligibleUsers.map((u) => (
              <cds-combo-box-item value={u.id}>{u.name} — {u.role}</cds-combo-box-item>
            ))}
          </cds-combo-box>
          <cds-button kind="tertiary" size="md" id="analysis-add-btn" type="button">Add reviewer</cds-button>
        </form>

        <!-- Reviewer roster. Each row shows completion (icon-indicator, not colour
             alone) and a remove control. Seed rows carry data-seed so removing one
             is tracked differently from dropping a just-added user. -->
        <ul class="review-roster" id="review-roster" data-team-key={teamStorageKey}>
          {analysisTeam.map((m) => {
            const meta = reviewMeta(m);
            return (
            <li class="review-row" data-user-id={m.id} data-seed data-done={String(meta.done)}>
              <Avatar name={m.name} size="md" />
              <div class="review-row__id">
                <p class="review-row__name t-body-01">{m.name}{m.highlight ? <span class="review-row__lead t-label-01"> · Lead</span> : null}</p>
                <p class="review-row__role t-label-01">{m.role} — {m.detail}</p>
              </div>
              <div class="review-row__status">
                <span class="review-row__state">
                  <cds-icon-indicator
                    class="review-row__ind"
                    size="16"
                    kind={meta.done ? 'succeeded' : 'pending'}
                    label={meta.statusLabel}
                  ></cds-icon-indicator>
                </span>
                <span class="review-row__when t-label-01">{meta.when}</span>
              </div>
              <cds-icon-button kind="ghost" size="sm" align="left" data-remove aria-label={`Remove ${m.name}`}>
                <svg slot="icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" width="16" height="16" aria-hidden="true"><path d="M12 12h2v12h-2zM18 12h2v12h-2z"/><path d="M4 6v2h2v20a2 2 0 002 2h16a2 2 0 002-2V8h2V6zm4 22V8h16v20zM12 2h8v2h-8z"/></svg>
              </cds-icon-button>
            </li>
            );
          })}
        </ul>
      </cds-stack>
    </cds-modal-body>
    <cds-modal-footer>
      <cds-modal-footer-button kind="primary" data-modal-close>Done</cds-modal-footer-button>
    </cds-modal-footer>
  </cds-modal>

  <!-- Directory JSON + row template for the client add-reviewer flow. -->
  <script type="application/json" id="analysis-directory" set:html={JSON.stringify(directory)}></script>
  <template id="review-row-template">
    <li class="review-row" data-done="false">
      <span class="avatar avatar--md" aria-hidden="true"></span>
      <div class="review-row__id">
        <p class="review-row__name t-body-01"></p>
        <p class="review-row__role t-label-01"></p>
      </div>
      <div class="review-row__status">
        <span class="review-row__state">
          <cds-icon-indicator class="review-row__ind" size="16" kind="pending" label="Pending review"></cds-icon-indicator>
        </span>
        <span class="review-row__when t-label-01"></span>
      </div>
      <cds-icon-button kind="ghost" size="sm" align="left" data-remove aria-label="Remove reviewer">
        <svg slot="icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" width="16" height="16" aria-hidden="true"><path d="M12 12h2v12h-2zM18 12h2v12h-2z"/><path d="M4 6v2h2v20a2 2 0 002 2h16a2 2 0 002-2V8h2V6zm4 22V8h16v20zM12 2h8v2h-8z"/></svg>
      </cds-icon-button>
    </li>
  </template>
)}

<script>
  // ── Workflow state machine (prototype-local) ──
  // The permit moves through a small set of statuses; each has a cds-icon-indicator
  // `kind` (kept in sync with data/permits.ts) and its own action set. The current
  // status persists to `permit-status-${id}` so it survives a reload, and every
  // transition broadcasts `permit-status-changed` so other surfaces on the page —
  // notably the Special conditions tab, which freezes once the permit leaves review
  // — react without a reload.
  //   Under review ──approve──▶ Out for signature ──sign──▶ Active
  //                └─request changes─▶ Changes requested
  //                └─reject──────────▶ Rejected
  const banner = document.getElementById('permit-banner');
  const permitId = banner?.dataset.permitId ?? '';
  const seededStatus = banner?.dataset.status ?? 'Under review';
  const statusKey = `permit-status-${permitId}`;

  const STATUS_KIND: Record<string, string> = {
    'Under review': 'in-progress',
    'Out for signature': 'pending',
    'Active': 'succeeded',
    'Changes requested': 'caution-minor',
    'Rejected': 'failed',
  };

  const currentStatus = () =>
    (permitId && localStorage.getItem(statusKey)) || seededStatus;

  // Reflect a status across every surface: the two status indicators and the
  // action controls (only those tagged for the current status are shown).
  const paintStatus = (status: string) => {
    const kind = STATUS_KIND[status] ?? 'unknown';
    document.querySelectorAll('.permit-status-indicator').forEach((el) => {
      el.setAttribute('kind', kind);
      el.setAttribute('label', status);
    });
    document.querySelectorAll<HTMLElement>('[data-when]').forEach((el) => {
      el.hidden = el.dataset.when !== status;
    });
  };

  const setStatus = (status: string) => {
    if (permitId) localStorage.setItem(statusKey, status);
    paintStatus(status);
    window.dispatchEvent(
      new CustomEvent('permit-status-changed', { detail: { status } }),
    );
  };

  // Combo-button fires onClick for its primary button AND for menu-item picks;
  // route each to the matching confirmation modal. Both the full header and the
  // compact bar carry a `.permit-actions` combo-button, so wire them all.
  // (Cancel / X / confirm all close natively via [data-modal-close].)
  const approveModal = document.getElementById('approve-permit-modal') as any;
  const rejectModal = document.getElementById('reject-permit-modal') as any;
  const requestModal = document.getElementById('request-changes-modal') as any;
  const signModal = document.getElementById('sign-permit-modal') as any;
  document.querySelectorAll('.permit-actions').forEach((combo) => {
    (combo as any).onClick = (e: Event) => {
      const item = (e.target as HTMLElement).closest?.('cds-menu-item');
      const label = item?.getAttribute('label');
      if (label === 'Reject permit') rejectModal.open = true;
      else if (label === 'Request changes') requestModal.open = true;
      else if (!item) approveModal.open = true; // primary "Approve permit"
    };
  });
  document.querySelectorAll('.permit-action-sign').forEach((btn) => {
    btn.addEventListener('click', () => (signModal.open = true));
  });
  // Request amendment navigates to the prefilled application (href); before it
  // does, record that an amendment exists for this permit so the detail page can
  // surface a link back to it. Set synchronously so it lands before navigation.
  document.querySelectorAll('.permit-action-amend').forEach((btn) => {
    btn.addEventListener('click', () => {
      if (permitId) localStorage.setItem(`permit-amendment-${permitId}`, `${permitId}-A`);
    });
  });

  // Approving no longer jumps straight to "Out for signature". It captures the
  // confirmed window + CEQA and hands off to the live final-letter view, where the
  // reviewer reads the document, edits parks/dates, and THEN sends for signature
  // (that step advances the status). Capture the picked window as ISO from the
  // date-picker's change event; if untouched, the letter view falls back to the
  // requested window it already carries.
  const toISO = (d: Date) =>
    `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`;
  let approvedStartISO = '';
  let approvedEndISO = '';
  document.getElementById('approve-window')?.addEventListener('cds-date-picker-changed', (e) => {
    const dates = (e as CustomEvent).detail?.selectedDates ?? [];
    if (dates[0]) approvedStartISO = toISO(dates[0]);
    if (dates[1]) approvedEndISO = toISO(dates[1]);
  });
  document.getElementById('approve-confirm')?.addEventListener('click', () => {
    const letterUrl = banner?.dataset.letterUrl;
    if (!letterUrl) return setStatus('Out for signature'); // fallback if unwired
    const ceqa = (document.querySelector(
      '#approve-permit-modal cds-radio-button-group[name="ceqa"]',
    ) as any)?.value;
    const finalKey = `permit-final-${permitId}`;
    const prior = JSON.parse(localStorage.getItem(finalKey) || '{}');
    localStorage.setItem(
      finalKey,
      JSON.stringify({
        ...prior,
        ...(approvedStartISO ? { startISO: approvedStartISO } : {}),
        ...(approvedEndISO ? { endISO: approvedEndISO } : {}),
        ceqa,
      }),
    );
    window.location.href = letterUrl;
  });
  document
    .getElementById('sign-confirm')
    ?.addEventListener('click', () => setStatus('Active'));
  document
    .getElementById('request-confirm')
    ?.addEventListener('click', () => setStatus('Changes requested'));
  document
    .getElementById('reject-confirm')
    ?.addEventListener('click', () => setStatus('Rejected'));

  // Reflect the persisted (or seeded) status on load.
  paintStatus(currentStatus());

  // ── Compact bar reveal ──
  // Show the compact bar once the full header has scrolled out of view. This is
  // NOT a resize: the full header simply scrolls away (constant height) and the
  // compact bar is position:fixed (out of flow, constant height). Nothing changes
  // the document height on scroll, so there's no scroll-anchoring feedback and no
  // content jump — the two failure modes that made a *resizing* sticky header
  // oscillate. An IntersectionObserver on the header flips a single class.
  const compactbar = document.getElementById('permit-compactbar');
  if (banner && compactbar && 'IntersectionObserver' in window) {
    const io = new IntersectionObserver(
      ([entry]) => {
        const gone = !entry.isIntersecting;
        compactbar.classList.toggle('compactbar--shown', gone);
        compactbar.setAttribute('aria-hidden', String(!gone));
      },
      // Reveal once the header's bottom passes the sticky line for the tab bar
      // (fixed UI-Shell 48px + compact bar 48px = 96px), so the compact bar takes
      // over exactly as the tabs pin beneath it.
      { rootMargin: '-96px 0px 0px 0px', threshold: 0 },
    );
    io.observe(banner);
  }
</script>

<!-- ── Analysis-review key-metric + roster modal (only rendered on the finalize
     view, so everything here is guarded on the metric existing) ── -->
<script>
  import { initials } from '../lib/avatar';

  interface DirUser { id: string; name: string; role: string; detail: string; email: string; }
  interface TeamEdits { removed: string[]; added: DirUser[]; }

  const metricBtn = document.getElementById('analysis-metric');
  const modal = document.getElementById('analysis-team-modal') as any;
  const roster = document.getElementById('review-roster');

  if (metricBtn && modal && roster) {
    metricBtn.addEventListener('click', () => (modal.open = true));

    const teamKey = (roster as HTMLElement).dataset.teamKey || 'permit-team';
    const tpl = document.getElementById('review-row-template') as HTMLTemplateElement;
    const dirEl = document.getElementById('analysis-directory');
    const addSelect = document.getElementById('analysis-add-select') as any;
    const addBtn = document.getElementById('analysis-add-btn');
    const bars = [
      document.getElementById('analysis-metric-bar'),
      document.getElementById('analysis-modal-bar'),
    ].filter(Boolean) as any[];

    let directory: DirUser[] = [];
    try { directory = JSON.parse(dirEl?.textContent || '[]'); } catch { directory = []; }
    const byId = new Map(directory.map((u) => [u.id, u]));

    // Today, formatted like the seeded dates ("Jul 22, 2026") — the "added" line
    // for a reviewer joined just now. Completion is data-driven (a reviewer marks
    // their own analysis done elsewhere), so nothing here toggles it.
    const today = new Date().toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });

    // localStorage — {removed, added} shared with the detail-page roster.
    const loadTeam = (): TeamEdits => {
      try {
        const p = JSON.parse(localStorage.getItem(teamKey) || '{}');
        return { removed: Array.isArray(p.removed) ? p.removed : [], added: Array.isArray(p.added) ? p.added : [] };
      } catch { return { removed: [], added: [] }; }
    };
    const saveTeam = (e: TeamEdits) => localStorage.setItem(teamKey, JSON.stringify(e));

    // Seed ids = the rows the server rendered — captured before edits are applied.
    const seedIds = new Set(
      Array.from(roster.querySelectorAll<HTMLElement>('[data-user-id]')).map((r) => r.dataset.userId!),
    );
    const currentIds = () =>
      Array.from(roster.querySelectorAll<HTMLElement>('[data-user-id]')).map((r) => r.dataset.userId!);

    const rows = () => Array.from(roster.querySelectorAll<HTMLElement>('.review-row'));

    // Recompute the two meters from the live roster (added reviewers are pending).
    const recompute = () => {
      const all = rows();
      const total = all.length;
      const done = all.filter((r) => r.dataset.done === 'true').length;
      const allDone = total > 0 && done === total;
      bars.forEach((bar) => {
        bar.max = total;
        bar.value = done;
        bar.helperText = `${done} of ${total} reviewers done`;
        bar.status = allDone ? 'finished' : 'active';
      });
    };

    // Rebuild the combo to directory users not already on the team.
    const refreshCombo = () => {
      const onTeam = new Set(currentIds());
      addSelect.value = '';
      addSelect.innerHTML = '';
      directory
        .filter((u) => !onTeam.has(u.id))
        .sort((a, b) => a.name.localeCompare(b.name))
        .forEach((u) => {
          const item = document.createElement('cds-combo-box-item');
          item.setAttribute('value', u.id);
          item.textContent = `${u.name} — ${u.role}`;
          addSelect.appendChild(item);
        });
    };

    const removeMember = (id: string, row: HTMLElement) => {
      row.remove();
      const e = loadTeam();
      if (seedIds.has(id)) { if (!e.removed.includes(id)) e.removed.push(id); }
      else { e.added = e.added.filter((u) => u.id !== id); }
      saveTeam(e);
      refreshCombo();
      recompute();
    };

    const wireRow = (row: HTMLElement) => {
      row.querySelector('[data-remove]')?.addEventListener('click', () => removeMember(row.dataset.userId!, row));
    };

    const buildRow = (u: DirUser): HTMLElement => {
      const li = tpl.content.firstElementChild!.cloneNode(true) as HTMLElement;
      li.dataset.userId = u.id;
      const chip = li.querySelector('.avatar');
      if (chip) chip.textContent = initials(u.name);
      const nameEl = li.querySelector('.review-row__name');
      if (nameEl) nameEl.textContent = u.name;
      const roleEl = li.querySelector('.review-row__role');
      if (roleEl) roleEl.textContent = `${u.role} — ${u.detail}`;
      const whenEl = li.querySelector('.review-row__when');
      if (whenEl) whenEl.textContent = `Added ${today}`;
      (li.querySelector('[data-remove]') as HTMLElement)?.setAttribute('aria-label', `Remove ${u.name}`);
      return li;
    };

    const addMember = () => {
      const id = addSelect.value;
      if (!id || currentIds().includes(id)) return;
      const u = byId.get(id);
      if (!u) return;
      const row = buildRow(u);
      roster.appendChild(row);
      wireRow(row);
      const e = loadTeam();
      e.removed = e.removed.filter((r) => r !== id);
      if (!e.added.some((a) => a.id === id)) e.added.push(u);
      saveTeam(e);
      refreshCombo();
      recompute();
    };
    addBtn?.addEventListener('click', addMember);

    // ── Init: replay stored add/remove edits, wire, recompute ──
    const edits = loadTeam();
    edits.removed.forEach((id) => roster.querySelector(`[data-user-id="${id}"]`)?.remove());
    edits.added.forEach((u) => { if (!currentIds().includes(u.id)) roster.appendChild(buildRow(u)); });
    rows().forEach(wireRow);
    refreshCombo();
    recompute();
  }
</script>

<style>
  /* Dark banner panel — the header carries the g100 dark theme zone (see the
     `cds--g100` class on the element), so its background is the near-black base
     (--cds-background) and Carbon flips the text, tags, and button to their
     light dark-zone values automatically. Number sits UNDER the name. */
  .banner {
    background: var(--cds-background, #161616);
    /* Full-bleed: break out of the constrained page column so the gray band
       spans the whole viewport width. .banner__inner re-centers the content so
       it stays aligned with the rest of the page. */
    margin-inline: calc(50% - 50vw);
    padding-block: var(--cds-spacing-07, 2rem); /* 32px, on-scale */
    /* The full header just scrolls away normally — no sticky, no resize. The
       compact bar below takes over the pinned role. */
  }

  /* ── Compact bar ─────────────────────────────────────────────────────────
     A position:fixed bar pinned under the UI-Shell header (48px). Constant
     height, out of normal flow — so revealing/hiding it never changes document
     height (that's what kills the scroll-anchoring oscillation). Fades in once
     the full header has scrolled away. Its 48px height + the 48px UI-Shell header
     define the tab strip's sticky offset (6rem) on the page. */
  .compactbar {
    position: fixed;
    top: var(--cds-spacing-09, 3rem);
    left: 0;
    right: 0;
    height: var(--cds-spacing-09, 3rem);
    background: var(--cds-background, #161616);
    z-index: 95;
    opacity: 0;
    transform: translateY(-0.5rem);
    pointer-events: none;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }
  .compactbar--shown {
    opacity: 1;
    transform: none;
    pointer-events: auto;
  }
  .compactbar__inner {
    max-inline-size: 99rem;
    height: 100%;
    margin-inline: auto;
    padding-inline: var(--cds-grid-margin, 1.5rem);
    display: flex;
    align-items: center;
    gap: var(--cds-spacing-04, 0.75rem);
  }
  .compactbar__number {
    color: var(--cds-text-primary, #f4f4f4);
    white-space: nowrap;
  }
  .compactbar__window {
    color: var(--cds-text-secondary, #c6c6c6);
    white-space: nowrap;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .compactbar__spacer {
    flex: 1 1 auto;
  }
  @media (prefers-reduced-motion: reduce) {
    .compactbar {
      transition: none;
    }
  }

  /* Re-center the full-bleed banner's content to match the 2x Grid: same 99rem
     cap and responsive page margin as .cds--css-grid, so the header lines up
     with the panels below. */
  .banner__inner {
    max-inline-size: 99rem;
    margin-inline: auto;
    padding-inline: var(--cds-grid-margin, 1.5rem);
  }
  /* Breadcrumb row sits above the title, inside the dark header. */
  .banner__crumb {
    margin-bottom: var(--cds-spacing-05, 1rem); /* 16px */
  }
  .banner__main {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem 2rem;
  }
  .banner__lead {
    min-width: 0;
    flex: 1 1 22rem;
  }
  /* Organization eyebrow — sits above the title, subordinate to it (secondary
     value, not a hue). Meaningful content, not an ornamental micro-label. */
  .banner__eyebrow {
    margin: 0 0 var(--cds-spacing-03, 0.5rem); /* 8px */
    color: var(--cds-text-secondary, #525252);
  }
  .banner__title {
    margin: 0;
    max-width: 46rem;
  }
  .banner__id-row {
    display: flex;
    align-items: center;
    gap: var(--cds-spacing-04, 0.75rem);
    margin-top: var(--cds-spacing-03, 0.5rem); /* 8px */
  }
  .banner__number {
    color: var(--cds-text-primary, #161616);
  }
  .banner__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--cds-spacing-02, 0.25rem);
    margin-top: var(--cds-spacing-05, 1rem); /* 16px, on-scale */
  }
  .banner__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
    flex: 0 0 auto;
  }
  /* Only the action set for the current status is shown; the script toggles
     [hidden] on the rest. Custom elements don't honor the UA [hidden] rule
     reliably, so force it. */
  [data-when][hidden] {
    display: none;
  }
  /* Facts strip: the labeled facts on the left, the optional analysis-review
     key-metric on the right, sharing the divider above them. */
  .banner__facts {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--cds-spacing-06, 1.5rem);
    margin-top: var(--cds-spacing-07, 2rem);      /* 32px above the divider */
    padding-top: var(--cds-spacing-06, 1.5rem);   /* 24px, on-scale */
    border-top: 1px solid var(--cds-border-subtle-01, #e0e0e0);
  }
  .banner__stats {
    flex: 1 1 22rem;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(11rem, 1fr));
    gap: var(--cds-spacing-06, 1.5rem);
    margin: 0;
  }
  .stat {
    min-width: 0;
  }
  .stat__label {
    margin: 0;
    color: var(--cds-text-secondary, #525252);
  }
  .stat__value {
    margin: 0.25rem 0 0;
    color: var(--cds-text-primary, #161616);
  }

  /* ── Analysis-review key metric ──────────────────────────────────────────
     A clickable tile in the facts strip: the completion meter + a "View team"
     affordance. Opens the roster modal. Reset the native button so only the
     meter's own tokens show; the hover/focus ring signals it's interactive. */
  .analysis-metric {
    flex: 0 1 20rem;
    display: flex;
    flex-direction: column;
    gap: var(--cds-spacing-03, 0.5rem);
    padding: var(--cds-spacing-04, 0.75rem);
    margin: calc(-1 * var(--cds-spacing-04, 0.75rem));
    background: transparent;
    border: 0;
    border-radius: 0;
    text-align: left;
    cursor: pointer;
    color: inherit;
    transition: background 0.11s ease;
  }
  .analysis-metric:hover {
    background: var(--cds-layer-hover, rgba(141, 141, 141, 0.16));
  }
  .analysis-metric:focus-visible {
    outline: 2px solid var(--cds-focus, #0f62fe);
    outline-offset: -2px;
  }
  .analysis-metric__bar {
    display: block;
    width: 100%;
    pointer-events: none; /* the whole tile is the click target */
  }
  .analysis-metric__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.125rem;
    color: var(--cds-link-primary, #78a9ff);
  }
  .analysis-metric__cta svg {
    fill: currentColor;
  }

  /* ── Roster modal ── */
  .review-roster {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    /* Cap the list and let IT scroll, so a long team never grows the modal past
       the viewport (and so the add-reviewer dropdown above it clears the list). */
    max-block-size: 22rem;
    overflow-y: auto;
  }
  .review-row {
    display: grid;
    /* The status track is a FIXED width so its left edge lands on the same
       vertical line in every row — a content-sized (auto) track would differ
       row to row, since each row is its own grid. Long strings wrap inside it
       rather than shifting the start point. */
    grid-template-columns: auto minmax(0, 1fr) 15rem auto;
    align-items: center;
    gap: var(--cds-spacing-05, 1rem);
    padding: var(--cds-spacing-05, 1rem) 0;
    border-block-end: 1px solid var(--cds-border-subtle-01, #e0e0e0);
  }
  .review-row:first-child {
    border-block-start: 1px solid var(--cds-border-subtle-01, #e0e0e0);
  }
  .review-row__id {
    min-width: 0;
  }
  .review-row__name {
    margin: 0;
    color: var(--cds-text-primary, #161616);
  }
  .review-row__lead {
    color: var(--cds-text-secondary, #525252);
  }
  .review-row__role {
    margin: 0.125rem 0 0;
    color: var(--cds-text-secondary, #525252);
  }
  /* Status is its own column: the state (indicator + label) over the date/time,
     both hugging the column's left edge so they share a start line. */
  .review-row__status {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.125rem;
    min-width: 0;
  }
  .review-row__state {
    display: inline-flex;
    align-items: center;
    white-space: nowrap;
  }
  /* The date/time sits UNDER the status text, not under the icon — indent it by
     the icon (16px) + the indicator's icon↔label gap (0.5rem) so it lines up
     with where "Analysis complete" / "Pending review" begins. */
  .review-row__when {
    padding-inline-start: calc(16px + var(--cds-spacing-03, 0.5rem));
    text-align: left;
    color: var(--cds-text-secondary, #525252);
  }
  @media (max-width: 42rem) {
    /* Stack the status under the name on narrow modals. */
    .review-row {
      grid-template-columns: auto minmax(0, 1fr) auto;
      row-gap: var(--cds-spacing-04, 0.75rem);
    }
    .review-row__status {
      grid-column: 2 / -1;
    }
  }
  /* Add-a-reviewer: combo grows, button aligns to the input bottom (the combo's
     title label floats above, so flex-end lines the two controls up). */
  .team-add {
    display: flex;
    align-items: flex-end;
    gap: var(--cds-spacing-05, 1rem);
  }
  .team-add__select {
    flex: 1 1 auto;
  }
  .team-add cds-button {
    flex: 0 0 auto;
  }

  /* Approve modal: quiet reminder of the applicant's requested window, sitting
     directly under the editable confirmation date range. Secondary value only —
     it's context, not the field. */
  .requested-reminder {
    margin: 0;
    color: var(--cds-text-secondary, #525252);
  }
</style>
