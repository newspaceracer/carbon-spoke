---
// The one shell every page uses. Pulls in the Carbon theme (tokens + Plex +
// theme-zone classes) and registers the cds-* web components client-side.
import '../styles/theme.css';
import AppHeader from '../components/AppHeader.astro';

interface Props {
  title?: string;
}
const { title = 'Carbon Spoke' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <!-- Carbon requires a theme class on <body> so nested theme zones
       (cds--g90 / cds--g100) resolve correctly. We use the g10 zone: a gray
       page with WHITE raised layers (tiles/fields/cards), so elements contrast
       against the background for free — Carbon's value-layering model. -->
  <body class="cds--g10">
    <!-- Honor the saved light/dark preference (set on the profile page) before
         the page paints, so there's no flash of the default theme. Light maps to
         the g10 zone, dark to g90 — the same body theme-zone mechanic, just
         swapped. Runs inline (is:inline) so it executes synchronously here. -->
    <script is:inline>
      (function () {
        try {
          var dark = localStorage.getItem('theme-preference') === 'dark';
          var b = document.body;
          b.classList.remove('cds--white', 'cds--g10', 'cds--g90', 'cds--g100');
          b.classList.add(dark ? 'cds--g90' : 'cds--g10');
        } catch (e) {}
      })();
    </script>

    <!-- A page supplies its own product nav via `<... slot="nav" />`; otherwise
         it gets the generic AppHeader. This guarantees exactly one top bar. -->
    {Astro.slots.has('nav') ? <slot name="nav" /> : <AppHeader />}
    <slot />

    <!-- Registers every cds-* custom element used in the app. Astro bundles
         this and it runs in the browser, where the components upgrade. -->
    <script>
      import '../carbon.ts';
    </script>
  </body>
</html>
