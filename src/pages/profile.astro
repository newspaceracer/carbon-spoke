---
import { withBase } from '../lib/base';
/* manifest:
     shell:  PermitNav (cds-header UI Shell) — the Profile global action links here.
     header: identity banner (g100 zone) — avatar, name, role · division, contact facts.
     spine:  main.page > .cds--css-grid  (main col 11 / rail col 5, mirrors permit Overview)
     sections:
       - Personal information (main) -> VIEW-FIRST form (read-only until Edit),
                                        matching the read-then-act grammar of the
                                        district/permit pages: header Edit action ->
                                        cds-text-input + cds-dropdown unlock -> Save/Cancel
                                        (cds-button) footer, cds-inline-notification on save
       - Notification preferences (main) -> per-event Email / In-app cds-toggle grid
       - Role & access (rail) -> READ-ONLY cds-tile: role/permission cds-tags + assigned
                                 districts; changing access is an admin action, so stated
   All fields are prototype-local: edits persist to localStorage (like permit comments).
*/
import BaseLayout from '../layouts/BaseLayout.astro';
import PermitNav from '../components/PermitNav.astro';
import PermitSection from '../components/PermitSection.astro';
import Avatar from '../components/Avatar.astro';
import AddressFieldset from '../components/AddressFieldset.astro';
import PhoneField from '../components/PhoneField.astro';
import { currentUser, divisions, requestableRoles } from '../data/user';
import { districtDirectory } from '../data/district';

export const prototype = {
  title: 'My profile',
  summary:
    'The signed-in reviewer manages their own account — personal details, ' +
    'notification delivery, and a read-only view of their role and assigned districts.',
  tag: 'Internal tool',
};

const u = currentUser;
const fullName = `${u.firstName} ${u.lastName}`;
const divisionLabel = divisions.find((d) => d.value === u.division)?.label ?? '';

// Dropdown options render alphabetically (states are already A–Z at the source).
const divisionsSorted = [...divisions].sort((a, b) => a.label.localeCompare(b.label));
const districtsSorted = [...districtDirectory].sort((a, b) => a.name.localeCompare(b.name));
---

<BaseLayout title={`My profile — ${fullName}`}>
  <PermitNav slot="nav" />

  <main class="page">
    <!-- Identity banner — dark g100 zone, consistent with the permit header. -->
    <header class="banner cds--g100">
      <div class="banner__inner">
        <cds-breadcrumb no-trailing-slash class="banner__crumb">
          <cds-breadcrumb-item>
            <cds-breadcrumb-link href={withBase('/')}>Home</cds-breadcrumb-link>
          </cds-breadcrumb-item>
          <cds-breadcrumb-item>
            <cds-breadcrumb-link aria-current="page">My profile</cds-breadcrumb-link>
          </cds-breadcrumb-item>
        </cds-breadcrumb>

        <div class="banner__id">
          <span id="banner-avatar"><Avatar name={fullName} size="lg" /></span>
          <div class="banner__lead">
            <h1 class="banner__name t-heading-05" id="banner-name">{fullName}</h1>
            <p class="banner__sub t-body-02" id="banner-sub">{u.title} · {divisionLabel}</p>
          </div>
        </div>

        <dl class="banner__stats">
          <div class="stat">
            <dt class="stat__label t-label-01">Email</dt>
            <dd class="stat__value t-body-01" id="stat-email">{u.email}</dd>
          </div>
          <div class="stat">
            <dt class="stat__label t-label-01">Office phone</dt>
            <dd class="stat__value t-body-01" id="stat-phone">{u.phone}</dd>
          </div>
          <div class="stat">
            <dt class="stat__label t-label-01">Member since</dt>
            <dd class="stat__value t-body-01">{u.memberSince}</dd>
          </div>
        </dl>
      </div>
    </header>

    <div class="cds--css-grid cds--css-grid--with-row-gap body">
      <!-- ── Main column ─────────────────────────────────────────────────── -->
      <div class="main cds--css-grid-column cds--sm:col-span-4 cds--md:col-span-8 cds--lg:col-span-11">
        <PermitSection title="Personal information">
          <!-- View-first, like the rest of the app: the record reads read-only
               until you deliberately enter edit mode. Save/Cancel then bound the
               transaction (see .form__actions, hidden until editing). -->
          <cds-button slot="aside" id="profile-edit" kind="ghost" size="sm">Edit</cds-button>
          <p class="section-hint t-body-01">Update how you appear to applicants and other reviewers across the permitting system.</p>

          <!-- Confirmation of a save. Hidden until the form is submitted. -->
          <cds-inline-notification
            id="save-notice"
            hidden
            kind="success"
            low-contrast
            title="Changes saved"
            subtitle="Your profile has been updated."
          ></cds-inline-notification>

          <form id="profile-form" class="form" data-storage-key="profile-personal">
            <div class="field-grid">
              <cds-text-input id="f-firstName" label="First name" value={u.firstName} readonly></cds-text-input>
              <cds-text-input id="f-lastName" label="Last name" value={u.lastName} readonly></cds-text-input>
              <cds-text-input id="f-title" label="Job title" value={u.title} readonly></cds-text-input>
              <cds-dropdown id="f-division" title-text="Division" value={u.division} read-only>
                {divisionsSorted.map((d) => (
                  <cds-dropdown-item value={d.value}>{d.label}</cds-dropdown-item>
                ))}
              </cds-dropdown>
              <cds-text-input id="f-email" type="email" label="Email address" value={u.email} readonly></cds-text-input>
              <div class="field-grid__wide">
                <PhoneField id="f-phone" label="Office phone" value={u.phone} />
              </div>

              <h3 class="form__subhead field-grid__wide t-heading-01">Mailing address</h3>
              <div class="field-grid__wide">
                <AddressFieldset prefix="addr" country={u.address.country} value={u.address} />
              </div>
            </div>

            <div class="form__actions" id="form-actions" hidden>
              <cds-button id="profile-reset" kind="ghost" type="button">Cancel</cds-button>
              <cds-button id="profile-save" type="button">Save changes</cds-button>
            </div>
          </form>
        </PermitSection>

        <PermitSection title="Appearance">
          <p class="section-hint t-body-01">Choose how the permitting system looks. Your preference is saved to this browser and applies across every page.</p>

          <div class="prefs" id="appearance-prefs">
            <div class="prefs__row">
              <div class="prefs__info">
                <p class="prefs__label t-heading-compact-01">Dark mode</p>
                <p class="prefs__desc t-body-01">Switch from the default light theme to a dark color theme.</p>
              </div>
              <cds-toggle
                id="theme-toggle"
                class="prefs__toggle"
                label-text="Dark mode"
                hide-label
              ></cds-toggle>
            </div>
          </div>
        </PermitSection>

        <PermitSection title="Notification preferences">
          <p class="section-hint t-body-01">Choose which permit activity you're notified about. All notifications are sent by email to <span class="prefs__email" id="prefs-email">{u.email}</span>.</p>

          <div class="prefs" id="notification-prefs" data-storage-key="profile-notifications">
            {u.notifications.map((n) => (
              <div class="prefs__row">
                <div class="prefs__info">
                  <p class="prefs__label t-heading-compact-01">{n.label}</p>
                  <p class="prefs__desc t-body-01">{n.description}</p>
                </div>
                <cds-toggle
                  class="prefs__toggle"
                  data-key={n.key}
                  label-text={`Email me: ${n.label}`}
                  hide-label
                  toggled={n.enabled || undefined}
                ></cds-toggle>
              </div>
            ))}
          </div>
        </PermitSection>
      </div>

      <!-- ── Rail: role & access (read-only) ─────────────────────────────── -->
      <aside class="cds--css-grid-column cds--sm:col-span-4 cds--md:col-span-8 cds--lg:col-span-5">
        <cds-tile class="access">
          <h2 class="access__title t-heading-03">Role &amp; access</h2>

          <dl class="access__facts">
            <div class="access__fact">
              <dt class="stat__label t-label-01">Role</dt>
              <dd><cds-tag type="blue" size="md" id="role-tag">{u.role}</cds-tag></dd>
            </div>
            <div class="access__fact">
              <dt class="stat__label t-label-01">Permission level</dt>
              <dd><cds-tag type="cool-gray" size="md">{u.permissionLevel}</cds-tag></dd>
            </div>
          </dl>

          <h3 class="access__subhead t-heading-01">Assigned districts</h3>
          <ul class="district-list">
            {u.districts.map((d) => (
              <li class="district">
                <cds-link class="district__name" href={withBase('/district')}>{d.name}</cds-link>
                <cds-tag type="gray" size="sm">{d.parks} parks</cds-tag>
              </li>
            ))}
          </ul>

          <!-- Pending-request banner, revealed after a role change is submitted. -->
          <cds-inline-notification
            id="role-pending"
            hidden
            kind="info"
            low-contrast
            hide-close-button
            title="Role change requested"
            subtitle=""
          ></cds-inline-notification>

          <p class="access__note t-label-01">
            Your role and district assignments are managed by an administrator.
          </p>
          <cds-button id="request-role-btn" kind="tertiary" size="sm">Request role change</cds-button>
        </cds-tile>
      </aside>
    </div>

    <!-- Role-change request. The user can only REQUEST a role; an admin approves
         it — so this submits a request rather than reassigning anything. Carbon
         owns the focus trap + return and the accessible heading. -->
    <cds-modal id="role-modal" size="sm">
      <cds-modal-header>
        <cds-modal-close-button></cds-modal-close-button>
        <cds-modal-label>Role &amp; access</cds-modal-label>
        <cds-modal-heading>Request a role change</cds-modal-heading>
      </cds-modal-header>
      <cds-modal-body>
        <!-- carbon-checked: prose intro text has no cds-* component; a <p> with the
             Carbon type role is the standard pattern (see PermitHeader's modals). -->
        <p class="modal-hint t-body-01">
          Your current role is <strong id="current-role-name">{u.role}</strong>. Choose the role you're requesting;
          an administrator will review and approve it.
        </p>
        <cds-radio-button-group
          id="role-choice"
          name="requested-role"
          orientation="vertical"
          label-text="Requested role"
        >
          {requestableRoles.map((r) => (
            <cds-radio-button label-text={r.label} value={r.value}></cds-radio-button>
          ))}
        </cds-radio-button-group>
        <!-- carbon-checked: the radio group has no per-option helper-text slot, so
             this <p> is the reusable home for the selected role's description. -->
        <p class="modal-desc t-body-01" id="role-desc" hidden></p>

        <!-- District picker — shown only for a district-scoped role (lead /
             assistant), which is always the lead/assistant OF a district. -->
        <div id="role-district-wrap" class="modal-district" hidden>
          <cds-dropdown id="role-district" title-text="District" value="north-coast-redwoods" autoalign>
            {districtsSorted.map((d) => (
              <cds-dropdown-item value={d.id}>{d.name}</cds-dropdown-item>
            ))}
          </cds-dropdown>
        </div>

        <cds-textarea
          id="role-reason"
          class="modal-reason"
          label="Reason for request (optional)"
          placeholder="Briefly explain why you're requesting this role…"
          rows="3"
        ></cds-textarea>
      </cds-modal-body>
      <cds-modal-footer>
        <cds-modal-footer-button kind="secondary" data-modal-close>Cancel</cds-modal-footer-button>
        <cds-modal-footer-button kind="primary" id="role-submit">Submit request</cds-modal-footer-button>
      </cds-modal-footer>
    </cds-modal>
  </main>
</BaseLayout>

<script>
  import { currentUser, requestableRoles, accountRoleMeta } from '../data/user';
  import type { Address } from '../data/address';
  import { wireAddressFieldset } from '../lib/address-fields';
  import { wirePhoneField, formatDisplay } from '../lib/phone';
  import { pendingForUser, submitRequest, accountRoleDisplay, roleDisplay } from '../data/requests';

  // ── Personal information: edit + persist (prototype-local) ──────────────
  // A static Astro prototype has no backend, so "saved" means localStorage —
  // the same convention the permit comment thread uses. Edits survive reloads
  // and update the identity banner live.
  const form = document.getElementById('profile-form') as HTMLFormElement | null;
  const saveBtn = document.getElementById('profile-save');
  const resetBtn = document.getElementById('profile-reset');
  const editBtn = document.getElementById('profile-edit');
  const actions = document.getElementById('form-actions');
  const notice = document.getElementById('save-notice') as any;

  // Identity scalars (name / title / division / email). Phone + mailing address
  // are locale-sensitive widgets driven by their own controllers below, so
  // they're kept out of this flat list.
  const scalarIds = ['firstName', 'lastName', 'title', 'division', 'email'] as const;
  type ScalarKey = (typeof scalarIds)[number];
  const fieldEl = (k: ScalarKey) => document.getElementById(`f-${k}`) as any;
  // cds-dropdown exposes the readonly flag as `readOnly` / attr `read-only`;
  // cds-text-input uses `readonly`. One helper handles both.
  const setReadonly = (el: any, ro: boolean) => {
    if (!el) return;
    if (el.tagName === 'CDS-DROPDOWN') el.readOnly = ro;
    else el.readonly = ro;
  };

  // Country-aware controllers for the two locale-sensitive contact fields. They
  // start locked (view mode); setEditable toggles them alongside the scalars.
  const addrRoot = document.querySelector<HTMLElement>('#profile-form [data-address]');
  const phoneRoot = document.querySelector<HTMLElement>('#profile-form [data-phone]');
  const addr = addrRoot ? wireAddressFieldset(addrRoot, { readonly: true }) : null;
  const phone = phoneRoot ? wirePhoneField(phoneRoot, { readonly: true }) : null;

  // Seeded defaults; a saved edit overrides them.
  const scalarDefaults: Record<ScalarKey, string> = {
    firstName: currentUser.firstName,
    lastName: currentUser.lastName,
    title: currentUser.title,
    division: currentUser.division,
    email: currentUser.email,
  };
  const defaultPhone = currentUser.phone;                 // E.164
  const defaultAddress = currentUser.address as Address;  // generic, country-aware
  const divisionLabels: Record<string, string> = {
    'natural-resources': 'Natural Resources Division',
    'cultural-resources': 'Cultural Resources Division',
    'permitting': 'Statewide Permitting Office',
    'park-operations': 'Park Operations Division',
    'science': 'Office of Scientific Review',
  };

  // The persisted record: identity scalars + an E.164 phone + a generic address.
  interface Personal {
    firstName: string;
    lastName: string;
    title: string;
    division: string;
    email: string;
    phone: string;
    address: Address;
  }

  if (form && saveBtn && resetBtn && editBtn && actions && notice) {
    const storageKey = form.dataset.storageKey || 'profile-personal';

    const readStored = (): Partial<Personal> => {
      try {
        const parsed = JSON.parse(localStorage.getItem(storageKey) || '{}');
        return parsed && typeof parsed === 'object' ? parsed : {};
      } catch {
        return {};
      }
    };

    const setFields = (v: Personal) => {
      scalarIds.forEach((k) => {
        const el = fieldEl(k);
        if (el) el.value = v[k];
      });
      phone?.setValue(v.phone);
      addr?.setValue(v.address);
    };

    // Banner echoes the identity fields — keep it in sync so a save is visible.
    const initials = (first: string, last: string) =>
      `${first[0] ?? ''}${last[0] ?? ''}`.toUpperCase();
    const syncBanner = (v: Personal) => {
      const name = `${v.firstName} ${v.lastName}`.trim();
      const nameEl = document.getElementById('banner-name');
      const subEl = document.getElementById('banner-sub');
      const emailEl = document.getElementById('stat-email');
      const phoneEl = document.getElementById('stat-phone');
      const prefsEmailEl = document.getElementById('prefs-email');
      const avatarEl = document.querySelector('#banner-avatar .avatar');
      if (nameEl) nameEl.textContent = name;
      if (subEl) subEl.textContent = `${v.title} · ${divisionLabels[v.division] ?? ''}`;
      if (emailEl) emailEl.textContent = v.email;
      // Phone is stored E.164; show it formatted for readers.
      if (phoneEl) phoneEl.textContent = formatDisplay(v.phone);
      if (prefsEmailEl) prefsEmailEl.textContent = v.email;
      if (avatarEl) avatarEl.textContent = initials(v.firstName, v.lastName);
    };

    const current = (): Personal => {
      const out = {} as Personal;
      scalarIds.forEach((k) => {
        const el = fieldEl(k);
        (out as any)[k] = (el?.value ?? scalarDefaults[k]).toString();
      });
      out.phone = phone?.getValue() || defaultPhone;
      out.address = addr?.getValue() ?? defaultAddress;
      return out;
    };

    // The persisted truth: seeded defaults overlaid with any saved edit. Guards
    // reject a stale record from an older build (flat US address / national phone).
    const savedValues = (): Personal => {
      const s = readStored();
      const okPhone = typeof s.phone === 'string' && s.phone.startsWith('+');
      const okAddr =
        !!s.address && typeof s.address === 'object' && typeof (s.address as any).country === 'string';
      return {
        firstName: s.firstName ?? scalarDefaults.firstName,
        lastName: s.lastName ?? scalarDefaults.lastName,
        title: s.title ?? scalarDefaults.title,
        division: s.division ?? scalarDefaults.division,
        email: s.email ?? scalarDefaults.email,
        phone: okPhone ? (s.phone as string) : defaultPhone,
        address: okAddr ? (s.address as Address) : defaultAddress,
      };
    };

    // View-first, like district/permit: the fields read read-only until you
    // click Edit. Edit mode unlocks them and swaps the header Edit action for
    // the Save/Cancel footer; leaving edit mode locks them again.
    const setEditable = (on: boolean) => {
      scalarIds.forEach((k) => setReadonly(fieldEl(k), !on));
      phone?.setReadonly(!on);
      addr?.setReadonly(!on);
      actions.hidden = !on;
      editBtn.hidden = on;
    };

    // Hydrate from any previously saved edits; start locked (view mode).
    setFields(savedValues());
    syncBanner(current());
    setEditable(false);

    editBtn.addEventListener('click', () => {
      notice.hidden = true;
      setEditable(true);
      fieldEl('firstName')?.focus();
    });

    saveBtn.addEventListener('click', () => {
      const values = current();
      localStorage.setItem(storageKey, JSON.stringify(values));
      syncBanner(values);
      setEditable(false);
      notice.hidden = false;
      notice.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
    });

    // Cancel discards this edit session — revert the fields to the last saved
    // state and lock them. (A saved edit stays saved; a country switch reverts
    // via addr.setValue rebuilding the saved country's field set.)
    resetBtn.addEventListener('click', () => {
      setFields(savedValues());
      setEditable(false);
      notice.hidden = true;
    });
  }

  // ── Appearance: light/dark theme preference (device-local, global) ──────
  // Persist a single 'theme-preference' flag; BaseLayout reads it on every page
  // load and sets the matching Carbon zone class on <body> before paint. Here we
  // reflect the saved state on the toggle and apply the change live.
  const themeToggle = document.getElementById('theme-toggle') as any;
  if (themeToggle) {
    const THEME_KEY = 'theme-preference';
    const applyTheme = (dark: boolean) => {
      document.body.classList.remove('cds--white', 'cds--g10', 'cds--g90', 'cds--g100');
      document.body.classList.add(dark ? 'cds--g90' : 'cds--g10');
    };
    themeToggle.toggled = localStorage.getItem(THEME_KEY) === 'dark';
    themeToggle.addEventListener('cds-toggle-changed', () => {
      const dark = !!themeToggle.toggled;
      localStorage.setItem(THEME_KEY, dark ? 'dark' : 'light');
      applyTheme(dark);
    });
  }

  // ── Notification preferences: persist each toggle by key + channel ───────
  const prefs = document.getElementById('notification-prefs');
  if (prefs) {
    const prefsKey = prefs.dataset.storageKey || 'profile-notifications';
    const toggles = Array.from(prefs.querySelectorAll<HTMLElement>('cds-toggle'));

    const stored = (() => {
      try {
        const parsed = JSON.parse(localStorage.getItem(prefsKey) || '{}');
        return parsed && typeof parsed === 'object' ? parsed : {};
      } catch {
        return {};
      }
    })();

    const cellId = (t: HTMLElement) => t.dataset.key ?? '';

    // Apply any saved state on load.
    toggles.forEach((t) => {
      const saved = stored[cellId(t)];
      if (typeof saved === 'boolean') (t as any).toggled = saved;
    });

    const persist = () => {
      const state: Record<string, boolean> = {};
      toggles.forEach((t) => { state[cellId(t)] = !!(t as any).toggled; });
      localStorage.setItem(prefsKey, JSON.stringify(state));
    };
    prefs.addEventListener('cds-toggle-changed', persist);
  }

  // ── Role-change request (prototype-local, shared with the /users console) ──
  // The user REQUESTS one of the requestable roles; an admin resolves it in the
  // users console. The request + the resulting account role live in the shared
  // requests store (src/data/requests.ts), so this profile and that console read
  // and write the same source of truth — request here, approve there, and the
  // Role tag + pending banner below reflect it.
  const roleBtn = document.getElementById('request-role-btn');
  const roleModal = document.getElementById('role-modal') as any;
  const roleChoice = document.getElementById('role-choice') as any;
  const roleReason = document.getElementById('role-reason') as any;
  const rolePending = document.getElementById('role-pending') as any;
  const roleSubmit = document.getElementById('role-submit');
  const roleTag = document.getElementById('role-tag');
  const roleDesc = document.getElementById('role-desc');
  const districtWrap = document.getElementById('role-district-wrap');
  const districtEl = document.getElementById('role-district') as any;

  // The Role tag + modal intro reflect the shared account role — so an admin
  // approval in the users console shows up here on the next load.
  if (roleTag) roleTag.textContent = accountRoleDisplay(currentUser.id);
  const currentRoleName = document.getElementById('current-role-name');
  if (currentRoleName) currentRoleName.textContent = accountRoleDisplay(currentUser.id);

  if (roleBtn && roleModal && roleChoice && roleSubmit && rolePending) {
    const isScoped = (value: string) => !!accountRoleMeta(value)?.scoped;

    // A district role needs a district; a global one doesn't — show the picker
    // only when the chosen role is district-scoped.
    const syncForRole = (value: string) => {
      if (roleDesc) {
        const desc = requestableRoles.find((r) => r.value === value)?.description ?? '';
        roleDesc.textContent = desc;
        roleDesc.hidden = !desc;
      }
      if (districtWrap) districtWrap.hidden = !isScoped(value);
    };
    roleChoice.addEventListener('cds-radio-button-group-changed', () => syncForRole(roleChoice.value));

    // Reflect the user's open request (if any) on load — with its district.
    const showPending = (value: string, district?: string) => {
      rolePending.subtitle = `Requested: ${roleDisplay(value, district)} · Pending admin approval`;
      rolePending.hidden = false;
    };
    const existing = pendingForUser(currentUser.id);
    if (existing) showPending(existing.role, existing.district);

    roleBtn.addEventListener('click', () => {
      // Preselect a previously requested role (and district), if any.
      const open = pendingForUser(currentUser.id);
      if (open) {
        roleChoice.value = open.role;
        if (districtEl && open.district) districtEl.value = open.district;
      }
      syncForRole(roleChoice.value);
      roleModal.open = true;
    });

    roleSubmit.addEventListener('click', () => {
      const role = roleChoice.value;
      if (!role) return; // require a selection before submitting
      const district = isScoped(role) ? (districtEl?.value || 'north-coast-redwoods') : undefined;
      submitRequest(currentUser.id, role, (roleReason?.value ?? '').trim(), district);
      roleModal.open = false;
      showPending(role, district);
    });
  }
</script>

<style>
  /* Page-level LAYOUT only — component look lives in cds-* legos + --cds-* tokens.
     body already offsets the fixed ui-shell header (theme.css padding-top). */
  .page {
    padding-block: 0 6rem;
  }

  /* Identity banner — full-bleed dark g100 band, re-centered to the 2x Grid, the
     same construction as PermitHeader so the two headers read as one system. */
  .banner {
    background: var(--cds-background, #161616);
    margin-inline: calc(50% - 50vw);
    padding-block: var(--cds-spacing-07, 2rem);
  }
  .banner__inner {
    max-inline-size: 99rem;
    margin-inline: auto;
    padding-inline: var(--cds-grid-margin, 1.5rem);
  }
  .banner__crumb {
    display: block;
    margin-bottom: var(--cds-spacing-05, 1rem);
  }
  .banner__id {
    display: flex;
    align-items: center;
