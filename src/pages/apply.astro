---
/* manifest:
     shell:  PermitNav (cds-header UI Shell) — the public applicant's top bar.
     header: identity banner (g100 zone) — title, tracking id, Draft status, dates.
     spine:  main.page > .cds--css-grid  (rail col 4 = progress indicator / main col 12 = step)
     sections:
       - Progress (rail) -> vertical cds-progress-indicator, one step per page; the
                            steps are clickable so the applicant can jump around a Draft.
       - Steps (main)    -> one <section data-step> per page, only the current shown:
                            • Research team / Project information / Study areas /
                              Data collection / Additional documents -> fully built form steps
                            • Application summary -> <SummaryStep/>, a read-only review of
                              every answer with per-section Edit links and a certify-to-submit
                              gate (Submit stays disabled until the certification box is checked)
       - Wizard actions  -> Back / Withdraw / Save and continue (Submit on the summary step).
                            The draft auto-saves before any navigation, so there is no
                            explicit save action — the system always persists what's typed,
                            even when incomplete. Every page is freely reachable EXCEPT the
                            review (summary) step, which is gated on completeness: attempting
                            to continue there with required items still missing opens the
                            "Application incomplete" modal (listing the pages to fix) and
                            reveals an error banner on each of those pages. Completeness is
                            modeled by `applicationIssues` (data/application.ts).
   A new application is a Draft; the whole flow is prototype-local (no backend).
*/
import BaseLayout from '../layouts/BaseLayout.astro';
import PermitNav from '../components/PermitNav.astro';
import ResearchTeamStep from '../components/ResearchTeamStep.astro';
import ProjectInfoStep from '../components/ProjectInfoStep.astro';
import StudyAreasStep from '../components/StudyAreasStep.astro';
import DataCollectionStep from '../components/DataCollectionStep.astro';
import AdditionalDocsStep from '../components/AdditionalDocsStep.astro';
import SummaryStep from '../components/SummaryStep.astro';
import { applicationSteps, draft } from '../data/application';

// Steps with a fully-built panel; the rest render an honest placeholder.
const builtSteps = new Set([
  'research-team',
  'project-info',
  'study-areas',
  'data-collection',
  'additional-docs',
  'summary',
]);

// Home-page card metadata — the hub globs pages and reads this to self-list.
export const prototype = {
  title: 'Permit application',
  summary:
    'The public applicant flow: a member of the public creates a Scientific Research & ' +
    'Collection permit application as a multi-page Draft, starting with the research team.',
  tag: 'Public flow',
};
---

<BaseLayout title="New permit application">
  <PermitNav slot="nav" />

  <main class="page">
    <!-- Identity banner — dark g100 zone, consistent with the permit + profile headers. -->
    <header class="banner cds--g100">
      <div class="banner__inner">
        <cds-breadcrumb no-trailing-slash class="banner__crumb">
          <cds-breadcrumb-item>
            <cds-breadcrumb-link href="/">Home</cds-breadcrumb-link>
          </cds-breadcrumb-item>
          <cds-breadcrumb-item>
            <cds-breadcrumb-link href="/permits">Permits</cds-breadcrumb-link>
          </cds-breadcrumb-item>
          <cds-breadcrumb-item>
            <cds-breadcrumb-link aria-current="page">New application</cds-breadcrumb-link>
          </cds-breadcrumb-item>
        </cds-breadcrumb>

        <div class="banner__lead">
          <h1 class="banner__title t-heading-05">Scientific Research &amp; Collection Permit application</h1>
          <div class="banner__id-row">
            <span class="banner__number t-heading-03">{draft.id}</span>
            <cds-icon-indicator size="16" kind="incomplete" label={draft.status}></cds-icon-indicator>
          </div>
        </div>

        <dl class="banner__stats">
          <div class="stat">
            <dt class="stat__label t-label-01">Status</dt>
            <dd class="stat__value t-body-01">{draft.status}</dd>
          </div>
          <div class="stat">
            <dt class="stat__label t-label-01">Started</dt>
            <dd class="stat__value t-body-01">{draft.startedOn}</dd>
          </div>
          <div class="stat">
            <dt class="stat__label t-label-01">Pages</dt>
            <dd class="stat__value t-body-01">{applicationSteps.length}</dd>
          </div>
        </dl>
      </div>
    </header>

    <div class="cds--css-grid cds--css-grid--with-row-gap body">
      <!-- ── Progress rail: jump between pages of the Draft ──────────────────── -->
      <aside class="rail cds--css-grid-column cds--sm:col-span-4 cds--md:col-span-8 cds--lg:col-span-4">
        <nav class="rail__inner" aria-label="Application pages">
          <cds-progress-indicator id="wizard-progress" vertical>
            {applicationSteps.map((s, i) => (
              <cds-progress-step
                data-index={i}
                data-step-id={s.id}
                label={s.label}
                secondary-label={s.secondaryLabel}
              ></cds-progress-step>
            ))}
          </cds-progress-indicator>
        </nav>
      </aside>

      <!-- ── Step panels: only the current page is shown ────────────────────── -->
      <div class="main cds--css-grid-column cds--sm:col-span-4 cds--md:col-span-8 cds--lg:col-span-12">
        <!-- Application-wide guidance — the same on every page of the Draft. -->
        <cds-inline-notification
          class="wizard-intro"
          kind="info"
          low-contrast
          title="Filling out this application"
          subtitle="Complete the sections in any order — click a section on the left to jump to it. Your progress saves automatically before you navigate, even when a section is incomplete, so you can leave and return anytime; use Save and continue to move to the next section. Every field is marked required or optional, and you must complete all required fields before you can submit."
        ></cds-inline-notification>

        <section class="step" data-step="research-team">
          <ResearchTeamStep />
        </section>

        <section class="step" data-step="project-info" hidden>
          <ProjectInfoStep />
        </section>

        <section class="step" data-step="study-areas" hidden>
          <StudyAreasStep />
        </section>

        <section class="step" data-step="data-collection" hidden>
          <DataCollectionStep />
        </section>

        <section class="step" data-step="additional-docs" hidden>
          <AdditionalDocsStep />
        </section>

        <section class="step" data-step="summary" hidden>
          <SummaryStep />
        </section>

        {applicationSteps.filter((s) => !builtSteps.has(s.id)).map((s) => (
          <section class="step" data-step={s.id} hidden>
            <div class="placeholder">
              <h2 class="placeholder__title t-heading-04">{s.label}</h2>
              <p class="placeholder__sub t-body-02">{s.secondaryLabel}</p>
              <cds-inline-notification
                kind="info"
                low-contrast
                hide-close-button
                title={s.review ? 'Summary page' : 'Coming next'}
                subtitle={
                  s.review
                    ? 'This page will summarize every answer for a final review before submitting.'
                    : 'This page of the application is part of the flow and will be built out here.'
                }
              ></cds-inline-notification>
            </div>
          </section>
        ))}

        <!-- Shared wizard actions — Back / Withdraw on the left, Save and continue
             (Submit on the last page) on the right. The draft auto-saves before any
             navigation, so "Save and continue" persists then advances; there is no
             separate save action. Withdraw is destructive, so it's kept away from the
             primary and guarded by a confirmation modal. -->
        <footer class="wizard-actions">
          <cds-button id="wizard-back" kind="secondary" hidden>Back</cds-button>
          <cds-button id="wizard-withdraw" kind="danger--tertiary">Withdraw application</cds-button>
          <div class="wizard-actions__spacer"></div>
          <cds-button id="wizard-next">Save and continue</cds-button>
        </footer>
      </div>
    </div>

    <!-- Withdraw confirmation — destructive, so a stock cds-modal (danger) guards it. -->
    <cds-modal id="withdraw-modal" size="sm" danger>
      <cds-modal-header>
        <cds-modal-close-button></cds-modal-close-button>
        <cds-modal-label>Scientific Research &amp; Collection Permit application</cds-modal-label>
        <cds-modal-heading>Withdraw this application?</cds-modal-heading>
      </cds-modal-header>
      <cds-modal-body>
        <p class="t-body-01">
          Withdrawing discards this draft and everything saved so far. This can't be undone. Your
          answers save automatically, so you can leave and return to finish later instead.
        </p>
      </cds-modal-body>
      <cds-modal-footer>
        <cds-modal-footer-button kind="secondary" data-modal-close>Keep working</cds-modal-footer-button>
        <cds-modal-footer-button kind="danger" id="withdraw-confirm">Withdraw application</cds-modal-footer-button>
      </cds-modal-footer>
    </cds-modal>

    <!-- Application-incomplete gate — trying to continue to the review section
         while required items are still missing opens this stock cds-modal. The
         page list is filled by the script (one link per incomplete page, which
         navigates there and closes the modal). -->
    <cds-modal id="incomplete-modal" size="sm">
      <cds-modal-header>
        <cds-modal-close-button></cds-modal-close-button>
        <cds-modal-label>Scientific Research &amp; Collection Permit application</cds-modal-label>
        <cds-modal-heading>Application incomplete</cds-modal-heading>
      </cds-modal-header>
      <cds-modal-body>
        <p class="incomplete__lead t-heading-compact-02">Missing required information</p>
        <p class="t-body-01">
          This section was saved, but the application is still incomplete and can't continue to the
          review section. Please return to the following pages and fill out any missed requirements.
        </p>
        <ul id="incomplete-list" class="incomplete-list"></ul>
      </cds-modal-body>
      <cds-modal-footer>
        <cds-modal-footer-button kind="secondary" data-modal-close>Close</cds-modal-footer-button>
      </cds-modal-footer>
    </cds-modal>

    <!-- carbon-checked: the feedback IS a stock cds-toast-notification (created in
         the script below); this is only a fixed-position stacking host for it —
         Carbon ships no positioning container for toasts, so a plain host is right. -->
    <div id="toast-host" class="toast-host" aria-live="polite"></div>
  </main>
</BaseLayout>

<script>
  import { applicationSteps, applicationIssues } from '../data/application';

  const steps = applicationSteps.map((s) => s.id);
  const progress = document.getElementById('wizard-progress') as any;
  const panels = new Map(
    Array.from(document.querySelectorAll<HTMLElement>('section.step')).map((el) => [
      el.dataset.step!,
      el,
    ]),
  );
  const backBtn = document.getElementById('wizard-back') as any;
  const nextBtn = document.getElementById('wizard-next') as any;
  const withdrawBtn = document.getElementById('wizard-withdraw');
  const withdrawModal = document.getElementById('withdraw-modal') as any;
  const withdrawConfirm = document.getElementById('withdraw-confirm');
  const incompleteModal = document.getElementById('incomplete-modal') as any;
  const incompleteList = document.getElementById('incomplete-list');
  // Certification lives on the review step; Submit is gated on it being checked.
  const certify = document.getElementById('summary-certify') as any;

  // The review step can only be reached once every required item is provided.
  const reviewIndex = applicationSteps.findIndex((s) => s.review);
  const labelOf = (id: string) => applicationSteps.find((s) => s.id === id)?.label ?? id;

  let current = 0;

  const render = (scroll = true) => {
    // Panels: show only the current page.
    steps.forEach((id, i) => {
      const panel = panels.get(id);
      if (panel) panel.hidden = i !== current;
    });
    // The indicator owns step states — set currentIndex and it marks the steps
    // before/at/after as complete/current/incomplete.
    if (progress) progress.currentIndex = current;
    // Actions: Back hidden on the first page; primary becomes Submit on the last.
    backBtn.hidden = current === 0;
    const last = current === steps.length - 1;
    nextBtn.textContent = last ? 'Submit application' : 'Save and continue';
    // On the review step, Submit stays disabled until the applicant certifies the
    // application; every other step's primary is always enabled.
    nextBtn.disabled = last ? !certify?.checked : false;
    // The top of the step area is the useful scroll target when the page changes
    // (skipped on the initial load so we don't jump past the banner).
    if (scroll) {
      document.querySelector('section.step:not([hidden])')?.scrollIntoView({
        block: 'start',
        behavior: 'smooth',
      });
    }
  };

  const goTo = (i: number) => {
    current = Math.max(0, Math.min(steps.length - 1, i));
    render();
  };

  // Navigation guard: every page is freely reachable EXCEPT the review step, which
  // is gated on completeness. Attempting to enter review while items are still
  // missing surfaces the "Application incomplete" modal instead of advancing, and
  // reveals each incomplete page's error banner so the fixes are visible on return.
  const tryGoTo = (i: number) => {
    if (i >= reviewIndex && applicationIssues.length) {
      showIncomplete();
      return;
    }
    goTo(i);
  };

  // Reveal an error banner at the top of each incomplete page (idempotent). The
  // banner names exactly what is missing, so a returning applicant sees the fixes
  // in context — not just the modal's page list.
  const revealErrors = () => {
    applicationIssues.forEach((issue) => {
      const panel = panels.get(issue.stepId);
      if (!panel || panel.querySelector('.step-error')) return;
      const note = document.createElement('cds-inline-notification') as any;
      note.classList.add('step-error');
      note.kind = 'error';
      note.lowContrast = true;
      note.hideCloseButton = true;
      note.title = 'Missing required information';
      note.subtitle = issue.missing.join(' ');
      panel.insertBefore(note, panel.firstChild);
    });
  };

  // Populate the modal's page list (one link per incomplete page → navigate + close)
  // reveal the in-page banners, and open the modal.
  function showIncomplete() {
    revealErrors();
    if (incompleteList) {
      incompleteList.innerHTML = '';
      applicationIssues.forEach((issue) => {
        const li = document.createElement('li');
        const link = document.createElement('cds-link') as any;
        link.href = '#';
        link.textContent = labelOf(issue.stepId);
        link.addEventListener('click', (e: Event) => {
          e.preventDefault();
          if (incompleteModal) incompleteModal.open = false;
          goTo(steps.indexOf(issue.stepId));
        });
        li.appendChild(link);
        incompleteList.appendChild(li);
      });
    }
    if (incompleteModal) incompleteModal.open = true;
  }

  // Assigning onChange makes the steps keyboard-clickable (Carbon gates step
  // interactivity on onChange being a function) AND is the navigation callback:
  // clicking or Entering a step jumps to that page (gated only on the review step).
  if (progress) progress.onChange = (e: CustomEvent<{ index: number }>) => tryGoTo(e.detail.index);

  backBtn.addEventListener('click', () => goTo(current - 1));
  // Save and continue: the draft is ALWAYS saved — even with incomplete or invalid
  // fields — so navigation never blocks. Only the final Submit is gated on the
  // application being free of issues (represented here by the success path).
  nextBtn.addEventListener('click', () => {
    if (current === steps.length - 1) {
      // Belt-and-suspenders: the button is disabled until certified, but guard the
      // handler too so a stray click can't submit an uncertified application.
      if (!certify?.checked) return;
      toast('success', 'Application submitted', 'Your application has been sent for review.');
      return;
    }
    tryGoTo(current + 1);
  });

  // Withdraw is destructive — confirm through the modal, then discard and leave.
  withdrawBtn?.addEventListener('click', () => {
    if (withdrawModal) withdrawModal.open = true;
  });
  withdrawConfirm?.addEventListener('click', () => {
    if (withdrawModal) withdrawModal.open = false;
    toast('info', 'Application withdrawn', 'This draft has been discarded.');
    // Prototype: return to the home hub after the confirmation is seen.
    window.setTimeout(() => {
      window.location.href = '/';
    }, 1200);
  });

  // Feedback for Submit / Withdraw — a stock cds-toast-notification appended to
  // the host and auto-dismissed. Overlay-style feedback, out of grid flow.
  const host = document.getElementById('toast-host');
  function toast(kind: string, title: string, subtitle: string) {
    if (!host) return;
    const t = document.createElement('cds-toast-notification') as any;
    t.kind = kind;
    t.title = title;
    t.subtitle = subtitle;
    t.timeout = 5000;
    t.lowContrast = true;
    host.appendChild(t);
    t.addEventListener('cds-notification-closed', () => t.remove());
  }

  // Checking/unchecking the certification re-runs render so the Submit gate on the
  // review step tracks it live.
  certify?.addEventListener('cds-checkbox-changed', () => render(false));

  // Per-section "Edit" links on the review step jump back to that wizard step so
  // the applicant can fix an answer. Editing goes backward (never to the gated
  // review step), so it uses goTo directly.
  document.querySelectorAll<HTMLElement>('[data-goto-step]').forEach((el) => {
    el.addEventListener('click', () => {
      const i = steps.indexOf(el.dataset.gotoStep ?? '');
      if (i >= 0) goTo(i);
    });
  });

  // Reflect the initial state on load (no scroll).
  render(false);
</script>

<style>
  /* Page-level LAYOUT only — component look lives in cds-* legos + --cds-* tokens.
     body already offsets the fixed ui-shell header (theme.css padding-top). */
  .page {
    padding-block: 0 6rem;
  }

  /* Identity banner — full-bleed dark g100 band, re-centered to the 2x Grid, the
     same construction as PermitHeader / profile so the headers read as one system. */
  .banner {
    background: var(--cds-background, #161616);
    margin-inline: calc(50% - 50vw);
    padding-block: var(--cds-spacing-07, 2rem);
  }
  .banner__inner {
    max-inline-size: 99rem;
    margin-inline: auto;
    padding-inline: var(--cds-grid-margin, 1.5rem);
  }
  .banner__crumb {
    display: block;
    margin-bottom: var(--cds-spacing-05, 1rem);
  }
  .banner__lead {
    min-width: 0;
  }
  .banner__title {
    margin: 0;
    max-width: 46rem;
  }
  .banner__id-row {
    display: flex;
    align-items: center;
    gap: var(--cds-spacing-04, 0.75rem);
    margin-top: var(--cds-spacing-03, 0.5rem);
  }
  .banner__number {
    color: var(--cds-text-primary, #f4f4f4);
  }
  .banner__stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(9rem, 1fr));
    gap: var(--cds-spacing-06, 1.5rem);
    margin: var(--cds-spacing-06, 1.5rem) 0 0;
    padding-top: var(--cds-spacing-06, 1.5rem);
    border-top: 1px solid var(--cds-border-subtle-01, #e0e0e0);
  }
  .stat {
    min-width: 0;
  }
  .stat__label {
    margin: 0;
    color: var(--cds-text-secondary, #525252);
  }
  .stat__value {
    margin: 0.25rem 0 0;
    color: var(--cds-text-primary, #161616);
  }

  /* Body grid below the full-bleed banner. */
  .body {
    margin-top: var(--cds-spacing-07, 2rem);
  }

  /* Progress rail — sticky so the pages stay reachable while the form scrolls.
     Offset accounts for the fixed 48px UI-Shell header + a little breathing room. */
  .rail__inner {
    position: sticky;
    top: 4rem;
  }
  @media (max-width: 66rem) {
    /* Below lg the rail stacks above the form; drop the sticky so it scrolls away. */
    .rail__inner {
      position: static;
    }
  }

  .main {
    min-width: 0;
  }

  /* Application-wide guidance notification — full-measure, spaced above the step. */
  .wizard-intro {
    display: block;
    max-width: 46rem;
    margin-bottom: 2rem;
  }

  /* Placeholder pages — a plain editorial block; the notification states intent
     honestly rather than pretending the page is built. */
  .placeholder {
    max-width: 46rem;
  }
  .placeholder__title {
    margin: 0;
  }
  .placeholder__sub {
    margin: 0.25rem 0 1.5rem;
    color: var(--cds-text-secondary, #525252);
  }

  /* Wizard actions — a top hairline binds the buttons to the step above; Back and
     Withdraw sit on the left, Save and continue on the right. */
  .wizard-actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 2.75rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--cds-border-subtle-01, #e0e0e0);
  }
  .wizard-actions__spacer {
    flex: 1 1 auto;
  }
  #wizard-back[hidden] {
    display: none;
  }

  /* Per-page error banner — revealed at the top of each incomplete page when the
     applicant tries to reach review. Layout spacing only. */
  .step-error {
    display: block;
    margin-bottom: var(--cds-spacing-06, 1.5rem);
  }

  /* Incomplete-application modal — the list of pages still needing attention. */
  .incomplete__lead {
    margin: 0 0 var(--cds-spacing-03, 0.5rem);
  }
  .incomplete-list {
    display: flex;
    flex-direction: column;
    gap: var(--cds-spacing-03, 0.5rem);
    margin: var(--cds-spacing-05, 1rem) 0 0;
    padding-left: var(--cds-spacing-05, 1rem);
  }

  /* carbon-checked: fixed-position stacking host for stock cds-toast-notification
     elements (Carbon ships no toast positioning container). */
  .toast-host {
    position: fixed;
    right: 1rem;
    bottom: 1rem;
    z-index: 9000;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
</style>
