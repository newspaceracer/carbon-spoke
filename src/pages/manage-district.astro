  .field-divider { height: 1px; background: var(--cds-border-subtle-01, #e0e0e0); margin: 0.25rem 0; }
  @media (max-width: 42rem) { .field-grid { grid-template-columns: 1fr; } }

  /* Members table. */
  .table-wrap { overflow-x: auto; }
  :global(.m-name) { display: block; color: var(--cds-text-primary, #161616); }
  :global(.m-sub) { display: block; font-size: 0.75rem; color: var(--cds-text-secondary, #525252); }
  :global(.row-actions) { display: flex; gap: 0.25rem; }

  /* Member modal internals. */
  .modal-grid { display: flex; flex-direction: column; gap: 1.25rem; }
  #m-identity[hidden] { display: none; }
  .identity {
