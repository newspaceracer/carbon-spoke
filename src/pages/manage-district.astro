    margin: 0.25rem 0 0;
    color: var(--cds-text-secondary, #525252);
  }
  .identity__note { margin: 0.5rem 0 0; color: var(--cds-text-secondary, #525252); }
  #member-warning { margin-bottom: 0.5rem; }
  #member-warning[hidden], #lead-note[hidden], #autoassign-block[hidden], #specific-parks[hidden] { display: none; }
  .modal-hint { margin: 0; color: var(--cds-text-secondary, #525252); }
  /* Single-column list — always one park per row so it stays easy to scan
     no matter how long the roster grows. */
