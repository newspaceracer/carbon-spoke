  .scope__note { margin: 1rem 0 0; max-width: 48rem; color: var(--cds-text-secondary, #525252); }
  #switcher-note { margin-top: 1rem; }
  #switcher-note[hidden], #switcher-wrap[hidden], #save-notice[hidden] { display: none; }
