---
// Product landing page — the public front door for the CA State Parks
// Scientific Research & Collection Permits system. The site exists ONLY to
// receive research-permit applications, so this page's job is to let a first-time
// applicant prepare BEFORE they sign in: what the permit is, how the form works,
// what files to gather, every question they'll be asked, and the forms to sign —
// then send them into /apply.
//
// Composed from stock cds-* legos (tile, button, accordion, inline notification,
// link) on the 2x CSS Grid. The hero is a full-bleed dark theme ZONE (cds--g100)
// over the g10 page — the sanctioned light/dark-by-zone mechanic, no bespoke color.
//
// Required/optional labeling follows the house rule: required is the silent
// default; only OPTIONAL fields are marked — so the outline isn't wall-to-wall
// stars. Conditional questions carry a short "if …" note. Recurring instructions
// (power analysis, mailing address) are standardized and de-duplicated.
//
// This is a distinct screen from src/pages/index.astro (the dev prototype hub);
// it self-lists there via the `prototype` export below.
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../lib/base';

export const prototype = {
  title: 'Landing page',
  summary:
    "The application's public front door — how to apply for a scientific research " +
    'permit in California State Parks, the full question outline, and forms to download.',
  tag: 'System',
};

const guidelinesHref = '/docs/study-proposal-guidelines.pdf';

// Quick four-stage overview of the permit lifecycle (from permit.ts).
const steps = [
  { n: '1', title: 'Apply', body: 'Complete the online application and submit it for review.' },
  { n: '2', title: 'Review', body: 'District and headquarters reviewers assess your proposal.' },
  { n: '3', title: 'Decision', body: "When review is complete, we'll email you the outcome." },
  { n: '4', title: 'In the field', body: 'Carry your active permit during work, then file an annual report.' },
];

// The full application outline — every section and question, so an applicant can
// gather answers and files before signing in. Mirrors the /apply wizard's steps.
// An item is a plain string (required) or { label, optional?, when? }: `optional`
// renders "(optional)"; `when` prefixes a short condition. A group with no `name`
// renders its items with no sub-heading. `when` on a group notes when it appears.
type Item = string | { label: string; optional?: boolean; when?: string };
interface Group { name?: string; when?: string; items: Item[] }
interface Section { name: string; groups: Group[] }

const address = 'Mailing address (country, city, state, ZIP)';
const powerAnalysis = 'a power analysis to justify your sample size';

const applicationSections: Section[] = [
  {
    name: 'Research team',
    groups: [
      { name: 'Organization', items: ['Organization name', 'Phone number', 'Email', address] },
      { name: 'Principal investigator', items: ['First and last name', 'Phone number', 'Email', address, 'CV or résumé'] },
      { name: 'Person in direct charge of field work', items: ['First and last name', 'Phone number', 'Email', address, 'CV or résumé'] },
      {
        name: 'Additional participants',
        items: [
          'First and last name',
          'Email',
          { label: 'Phone number', optional: true },
          { label: 'Title', optional: true },
          { label: 'Comments', optional: true },
        ],
      },
      {
        name: 'Personnel insurance',
        items: [
          'Whether all personnel are employed or insured by the research institution',
          { label: 'Liability waiver addendum, signed by every participant', when: 'If they are' },
        ],
      },
    ],
  },
  {
    name: 'Project information',
    groups: [
      {
        items: [
          'Project category',
          'Project title',
          'Project purpose — the study rationale and significance, a summary of relevant literature, your hypotheses or objectives, and why you want to work in California State Parks',
          'Anticipated benefits to the State Park System',
          'Project start and end dates',
          'Requested permit start and end dates',
          'Tentative annual-report completion date',
          'Field investigation occurrences — start and end dates for each visit to park lands',
          { label: 'Project schedule supporting documents', optional: true },
        ],
      },
    ],
  },
  {
    name: 'Study area',
    groups: [{ items: ['Parks', { label: 'GIS location', optional: true }] }],
  },
  {
    name: 'Data collection',
    groups: [
      { name: 'What your project involves', items: ['Whether the project collects specimens', 'Whether the project involves laboratory work'] },
      {
        name: 'Specimen collection',
        when: 'If you collect specimens',
        items: [
          'Specimen types', 'Species', 'Quantity', 'Size', 'Condition',
          `Collection rationale — why collection is necessary, the disposition of specimens, and ${powerAnalysis}`,
          { label: 'Collection rationale supporting documents', optional: true },
          'Curation facility',
          'Curation responsible official — name, phone, and email',
        ],
      },
      {
        name: 'Laboratory work',
        when: 'If your project involves lab work',
        items: ['Laboratory facility', 'Laboratory responsible official — name, phone, and email', 'Lab study start and end dates'],
      },
      {
        name: 'Study design and data',
        items: [
          `Study procedures — design and sampling, field and lab methods, treatments and controls, replicates, and statistical analyses, with ${powerAnalysis}`,
          { label: 'Study procedures supporting documents', optional: true },
          "Location of the data and data products, the anticipated deliverables, and how you'll share results",
        ],
      },
    ],
  },
  {
    name: 'Additional documentation',
    groups: [
      {
        name: 'Soil disturbance',
        items: [
          'Whether the project disturbs soil (stakes, soil cores, and similar)',
          { label: `Soil disturbance details — why it's necessary, the disposition of specimens, and ${powerAnalysis}`, when: 'If yes' },
          { label: 'Soil disturbance areas and supporting documents', optional: true },
        ],
      },
      {
        name: 'Additional permits',
        items: [
          'Whether the project needs additional federal, state, or local permits',
          { label: 'Your existing additional permits and/or supporting documents', when: 'If yes' },
          { label: "Rationale, if you don't yet hold every required permit", optional: true },
        ],
      },
      {
        name: 'Supporting information',
        items: [
          { label: 'Budget', optional: true },
          { label: 'Budget supporting documents', optional: true },
          { label: 'Literature cited', optional: true },
          { label: 'Literature cited supporting documents', optional: true },
          { label: 'Study proposal (PDF)', when: 'May be required' },
        ],
      },
      {
        name: 'Agreements',
        items: ['Standard conditions agreement, signed', 'Waiver and indemnity agreement, signed'],
      },
      {
        name: 'Activities beyond simple use',
        items: [
          'Whether you conduct activities beyond simple use — drones or aircraft, boats, high-risk vehicles, diving, climbing, trapping, handling dangerous wildlife, large volunteer teams, and similar',
          { label: 'Insurance addendum, signed', when: 'If yes' },
        ],
      },
    ],
  },
];

// Downloadable forms an applicant fills out and uploads signed.
const forms = {
  required: [
    { name: 'Standard Conditions Agreement', href: '/docs/standard-conditions-agreement.pdf', body: 'Sign and upload it with your application.' },
    { name: 'Waiver and Indemnity Agreement', href: '/docs/waiver-and-indemnity-agreement.pdf', body: 'Sign and upload it with your application.' },
  ],
  optional: [
    { name: 'Insurance Addendum', href: '/docs/insurance-addendum.pdf', body: 'Required for activities beyond simple use — drones, boats, high-risk vehicles, and similar. Upload it signed.' },
    { name: 'Liability Waiver Addendum (DPR65B)', href: '/docs/liability-waiver-addendum-dpr65b.pdf', body: "Required when all personnel are employed or insured by the research institution, or at the reviewer's discretion. Every participant must sign it, so plan ahead." },
  ],
};

// Carbon `download` 16 glyph — signals the link fetches a form file.
const downloadIcon =
  '<svg slot="icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" width="16" height="16" fill="currentColor" aria-hidden="true">' +
  '<path d="M8 11 4 7 4.7 6.3 7.5 9.1 7.5 1 8.5 1 8.5 9.1 11.3 6.3 12 7z"/>' +
  '<path d="M13 14H3c-.6 0-1-.4-1-1v-3h1v3h10v-3h1v3C14 13.6 13.6 14 13 14z"/></svg>';
---

<BaseLayout title="Apply for a research permit — CA State Parks">
  <main>
    <!-- Hero: a full-bleed dark theme zone (g100) over the g10 page. -->
    <section class="hero cds--g100">
      <div class="cds--css-grid">
        <div class="hero__content cds--css-grid-column cds--sm:col-span-4 cds--md:col-span-6 cds--lg:col-span-9">
          <p class="hero__eyebrow t-label-01">California State Parks</p>
          <h1 class="hero__title t-heading-05">Apply for a scientific research permit</h1>
          <p class="hero__lede t-body-02">
            Request authorization to collect specimens and conduct field research
            across the California State Park System. A permit is valid for up to
            12 months; you can fill out the form in any order, across multiple sessions.
          </p>
          <div class="hero__actions">
            <cds-button href={withBase('/apply')}>Start an application</cds-button>
            <cds-button kind="tertiary" href={withBase('/login')}>Sign in to continue</cds-button>
          </div>
          <p class="hero__note t-label-01">Returning researchers sign in to renew or continue an application.</p>
        </div>
      </div>
    </section>

    <div class="page">
      <cds-stack gap="9">
        <!-- Public transparency — anyone can explore the register. A secondary
             purpose (the primary one is intake), but the newest, so it gets a
             clear band of its own right below the hero. -->
        <section class="cds--css-grid">
          <cds-tile class="cta cds--css-grid-column cds--sm:col-span-4 cds--md:col-span-8 cds--lg:col-span-16">
            <div class="cta__inner">
              <div>
                <h2 class="cta__title t-heading-03">See research happening in the parks</h2>
                <p class="cta__body t-body-01">
                  Anyone can browse the public register — look up active and past research
                  permits by park, district, or species. No account needed.
                </p>
              </div>
              <div class="cta__actions">
                <cds-button kind="tertiary" href={withBase('/search')}>Browse the register</cds-button>
              </div>
            </div>
          </cds-tile>
        </section>

        <!-- How it works — quick four-stage overview -->
        <section class="cds--css-grid cds--css-grid--with-row-gap">
          <div class="section-head cds--css-grid-column cds--sm:col-span-4 cds--md:col-span-8 cds--lg:col-span-16">
            <h2 class="section-head__title t-heading-03">How it works</h2>
          </div>
          {steps.map((step) => (
            <cds-tile class="cds--css-grid-column cds--sm:col-span-4 cds--md:col-span-4 cds--lg:col-span-4">
              <cds-stack gap="3">
                <span class="step__n t-heading-03" aria-hidden="true">{step.n}</span>
                <h3 class="card__title t-heading-01">{step.title}</h3>
                <p class="card__body t-body-01">{step.body}</p>
              </cds-stack>
            </cds-tile>
          ))}
        </section>

        <!-- Before you apply — deadline callout + intro + detail accordion -->
        <section class="cds--css-grid cds--css-grid--with-row-gap">
          <div class="section-head cds--css-grid-column cds--sm:col-span-4 cds--md:col-span-8 cds--lg:col-span-16">
            <h2 class="section-head__title t-heading-03">Before you apply</h2>
          </div>

          <div class="prose cds--css-grid-column cds--sm:col-span-4 cds--md:col-span-8 cds--lg:col-span-10">
            <cds-inline-notification
              kind="info"
              low-contrast
              hide-close-button
              title="Submit at least 90 days before your permit start date"
              subtitle="This gives reviewers time to reach a decision before your fieldwork begins."
            ></cds-inline-notification>

            <p class="prose__lede t-body-02">
              Thank you for your interest in conducting scientific research in
              California State Parks. Applications are evaluated on their scientific
              merit and their potential impact on park resources, operations, and
              visitors, so complete each section carefully — incomplete applications
              may be returned for revision.
            </p>

            <cds-accordion>
              <cds-accordion-item title="Permit duration and renewal">
                <p class="t-body-01">
                  Permits are issued for up to 12 months. Research that spans multiple
                  years needs a separate renewal for each year.
                </p>
                <p class="t-body-01">
                  Renew from your researcher profile — you won't need to start a new
                  application for each year of the same project.
                </p>
              </cds-accordion-item>

              <cds-accordion-item title="Completing the form">
                <ul class="list t-body-01">
                  <li>Complete the form in any order, across multiple sessions.</li>
                  <li>Fill in every field before you submit, except those marked optional.</li>
                  <li>
                    If you attach a study proposal, you can skip the form questions it
                    already answers. Otherwise, complete every field.
                  </li>
                </ul>
              </cds-accordion-item>

              <cds-accordion-item title="Study proposal (optional)">
                <p class="t-body-01">
                  You may attach your study proposal as a PDF in addition to filling
                  out the form. Follow the
                  <cds-link href={withBase(guidelinesHref)} target="_blank" rel="noopener">Study Proposal Guidelines</cds-link>
                  for research in California State Parks.
                </p>
              </cds-accordion-item>
            </cds-accordion>
          </div>
        </section>

        <!-- What you'll need — the files to gather -->
        <section class="cds--css-grid cds--css-grid--with-row-gap">
          <div class="section-head cds--css-grid-column cds--sm:col-span-4 cds--md:col-span-8 cds--lg:col-span-16">
            <h2 class="section-head__title t-heading-03">What you'll need</h2>
          </div>
          <div class="cds--css-grid-column cds--sm:col-span-4 cds--md:col-span-8 cds--lg:col-span-10">
            <p class="prose__lede t-body-01">Gather these before you start — you don't need an account to review the list:</p>
            <cds-tile>
              <ul class="checklist t-body-01">
                <li>A CV or résumé for the Principal Investigator, and for the field lead if that's a different person.</li>
                <li>Study-area locations, with coordinates and/or GIS files.</li>
                <li>Any additional local, state, or federal permits that apply.</li>
                <li>
                  All information described in the
                  <cds-link href={withBase(guidelinesHref)} target="_blank" rel="noopener">Study Proposal Guidelines</cds-link>.
                </li>
                <li>For renewals: a summary of activities under your previous permit.</li>
              </ul>
            </cds-tile>
          </div>
        </section>

        <!-- What the application asks — the full question outline, by section -->
        <section class="cds--css-grid cds--css-grid--with-row-gap">
          <div class="section-head cds--css-grid-column cds--sm:col-span-4 cds--md:col-span-8 cds--lg:col-span-16">
            <h2 class="section-head__title t-heading-03">What the application asks</h2>
          </div>
          <div class="cds--css-grid-column cds--sm:col-span-4 cds--md:col-span-8 cds--lg:col-span-11">
            <p class="prose__lede t-body-01">
              Review every question before you begin. Fields are required unless
              marked <span class="opt">(optional)</span>; some appear only when they apply to your project.
            </p>
            <cds-accordion>
              {applicationSections.map((section) => (
                <cds-accordion-item title={section.name}>
                  {section.groups.map((group) => (
                    <div class="qgroup">
                      {group.name && <h3 class="qgroup__name t-heading-compact-01">{group.name}</h3>}
                      {group.when && <p class="qgroup__when t-label-01">{group.when}</p>}
                      <ul class="qlist t-body-01">
                        {group.items.map((item) => {
                          const label = typeof item === 'string' ? item : item.label;
                          const optional = typeof item !== 'string' && item.optional;
                          const when = typeof item !== 'string' ? item.when : undefined;
                          return (
                            <li>
                              {when && <span class="qlist__when">{when}: </span>}
                              {label}
                              {optional && <span class="opt"> (optional)</span>}
                            </li>
                          );
                        })}
                      </ul>
                    </div>
                  ))}
                </cds-accordion-item>
              ))}
            </cds-accordion>
          </div>
        </section>

        <!-- Forms to download — sign and upload with the application -->
        <section class="cds--css-grid cds--css-grid--with-row-gap">
          <div class="section-head cds--css-grid-column cds--sm:col-span-4 cds--md:col-span-8 cds--lg:col-span-16">
            <h2 class="section-head__title t-heading-03">Forms to download</h2>
          </div>

          <div class="forms-head cds--css-grid-column cds--sm:col-span-4 cds--md:col-span-8 cds--lg:col-span-16">
            <h3 class="forms-head__title t-heading-01">Required</h3>
          </div>
          {forms.required.map((form) => (
            <cds-tile class="cds--css-grid-column cds--sm:col-span-4 cds--md:col-span-4 cds--lg:col-span-5">
              <cds-stack gap="3">
                <h4 class="card__title t-heading-01">{form.name}</h4>
                <p class="card__body t-body-01">{form.body}</p>
                <cds-link href={withBase(form.href)} target="_blank" rel="noopener">
                  Download form (PDF)
                  <Fragment set:html={downloadIcon} />
                </cds-link>
              </cds-stack>
            </cds-tile>
          ))}

          <div class="forms-head cds--css-grid-column cds--sm:col-span-4 cds--md:col-span-8 cds--lg:col-span-16">
            <h3 class="forms-head__title t-heading-01">Only if they apply</h3>
          </div>
          {forms.optional.map((form) => (
            <cds-tile class="cds--css-grid-column cds--sm:col-span-4 cds--md:col-span-4 cds--lg:col-span-5">
              <cds-stack gap="3">
                <h4 class="card__title t-heading-01">{form.name}</h4>
                <p class="card__body t-body-01">{form.body}</p>
                <cds-link href={withBase(form.href)} target="_blank" rel="noopener">
                  Download form (PDF)
                  <Fragment set:html={downloadIcon} />
                </cds-link>
              </cds-stack>
            </cds-tile>
          ))}
        </section>

        <!-- Need help -->
        <section class="cds--css-grid cds--css-grid--with-row-gap">
          <div class="section-head cds--css-grid-column cds--sm:col-span-4 cds--md:col-span-8 cds--lg:col-span-16">
            <h2 class="section-head__title t-heading-03">Need help?</h2>
          </div>
          <div class="cds--css-grid-column cds--sm:col-span-4 cds--md:col-span-8 cds--lg:col-span-10">
            <p class="prose__lede t-body-01">
              Email
              <cds-link href="mailto:nrd.research@parks.ca.gov?subject=Research%20permit%20question">nrd.research@parks.ca.gov</cds-link>
              and put your question in the subject line — a clear subject helps us
              respond faster. Attach any relevant screenshots.
            </p>
          </div>
        </section>

        <!-- Closing call to action -->
        <section class="cds--css-grid">
          <cds-tile class="cta cds--css-grid-column cds--sm:col-span-4 cds--md:col-span-8 cds--lg:col-span-16">
            <div class="cta__inner">
              <div>
                <h2 class="cta__title t-heading-03">Ready to apply?</h2>
                <p class="cta__body t-body-01">Start a new application, or sign in to pick up where you left off.</p>
              </div>
              <div class="cta__actions">
                <cds-button href={withBase('/apply')}>Start an application</cds-button>
                <cds-button kind="tertiary" href={withBase('/login')}>Sign in</cds-button>
              </div>
            </div>
          </cds-tile>
        </section>
      </cds-stack>
    </div>
  </main>
</BaseLayout>

<style>
  /* Page-level layout only — component look lives in cds-* + --cds-* tokens.
     The hero band is full-bleed; the rest sits on the centered 2x Grid. */

  .hero {
    padding-block: var(--cds-spacing-10, 4rem);
  }
  .hero__eyebrow {
    margin: 0;
    text-transform: uppercase;
    color: var(--cds-text-secondary, #c6c6c6);
  }
  .hero__title {
    margin: var(--cds-spacing-03, 0.5rem) 0 0;
    max-inline-size: 24ch;
  }
  .hero__lede {
    margin: var(--cds-spacing-05, 1rem) 0 0;
    color: var(--cds-text-secondary, #c6c6c6);
  }
  .hero__actions {
    margin-block-start: var(--cds-spacing-07, 2rem);
    display: flex;
    flex-wrap: wrap;
    gap: var(--cds-spacing-03, 0.5rem);
  }
  .hero__note {
    margin: var(--cds-spacing-05, 1rem) 0 0;
    color: var(--cds-text-secondary, #c6c6c6);
  }

  .page {
    padding-block: var(--cds-spacing-10, 4rem) var(--cds-spacing-12, 6rem);
  }
  .section-head {
    margin-block-end: var(--cds-spacing-03, 0.5rem);
  }
  .section-head__title {
    margin: 0;
  }

  /* Step + card tiles */
  .card__title {
    margin: 0;
    color: var(--cds-text-primary, #161616);
  }
  .card__body {
    margin: 0;
    color: var(--cds-text-secondary, #525252);
  }
  .step__n {
    display: block;
    font-family: 'IBM Plex Mono', ui-monospace, monospace;
    color: var(--cds-text-secondary, #525252);
  }

  /* Instructional prose column */
  .prose__lede {
    margin: var(--cds-spacing-05, 1rem) 0 var(--cds-spacing-06, 1.5rem);
    color: var(--cds-text-secondary, #525252);
    max-inline-size: 64ch;
  }
  .prose cds-inline-notification {
    max-inline-size: 100%;
  }
  cds-accordion-item p {
    margin: 0 0 var(--cds-spacing-04, 0.75rem);
    color: var(--cds-text-secondary, #525252);
  }
  cds-accordion-item p:last-child {
    margin-bottom: 0;
  }
  .list {
    margin: 0;
    padding-inline-start: 1.25rem;
    color: var(--cds-text-secondary, #525252);
  }
  .list li {
    margin-block: 0.25rem;
  }

  /* Materials checklist — check marker via token color, content styling only. */
  .checklist {
    margin: 0;
    padding: 0;
    list-style: none;
    color: var(--cds-text-primary, #161616);
  }
  .checklist li {
    position: relative;
    padding-inline-start: 1.75rem;
    margin-block: var(--cds-spacing-04, 0.75rem);
  }
  .checklist li:first-child { margin-block-start: 0; }
  .checklist li:last-child { margin-block-end: 0; }
  .checklist li::before {
    content: '';
    position: absolute;
    inset-inline-start: 0;
    inset-block-start: 0.35em;
    inline-size: 0.85rem;
    block-size: 0.45rem;
    border-inline-start: 2px solid var(--cds-support-success, #24a148);
    border-block-end: 2px solid var(--cds-support-success, #24a148);
    transform: rotate(-45deg);
  }

  /* Application-outline groups inside each accordion item */
  .qgroup { margin-block-end: var(--cds-spacing-06, 1.5rem); }
  .qgroup:last-child { margin-block-end: 0; }
  .qgroup__name {
    margin: 0 0 var(--cds-spacing-02, 0.25rem);
    color: var(--cds-text-primary, #161616);
  }
  .qgroup__when {
    margin: 0 0 var(--cds-spacing-03, 0.5rem);
    color: var(--cds-text-secondary, #525252);
    font-style: italic;
  }
  .qlist {
    margin: 0;
    padding-inline-start: 1.25rem;
    color: var(--cds-text-primary, #161616);
  }
  .qlist li { margin-block: 0.375rem; }
  .qlist__when {
    color: var(--cds-text-secondary, #525252);
    font-style: italic;
  }
  .opt { color: var(--cds-text-secondary, #525252); }

  /* Forms-to-download subsection headers span the full grid row. */
  .forms-head { margin-block-start: var(--cds-spacing-03, 0.5rem); }
  .forms-head__title { margin: 0; }

  /* Closing CTA */
  .cta__inner {
    display: flex;
    flex-wrap: wrap;
