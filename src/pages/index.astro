---
// Spoke hub — the front door. Two jobs:
//   1. Auto-list every prototype. import.meta.glob picks up src/pages/**; each
//      page's `export const prototype` supplies its card copy. Add a screen and
//      it appears here — no manual list to maintain.
//   2. A short design-system orientation (the carbon-first rule + token theming),
//      composed from cds-* legos. Deep guidance lives in CLAUDE.md + the skill.
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../lib/base';

// Glob sibling pages eagerly so we can read each one's `prototype` export.
const modules = import.meta.glob('./**/*.astro', { eager: true });

const prototypes = Object.entries(modules)
  .filter(([path]) => path !== './index.astro')
  .map(([path, mod]) => {
    const route = path.replace(/^\.\//, '').replace(/\.astro$/, '').replace(/\/index$/, '');
    const href = withBase('/' + route);
    const slug = route.split('/').filter(Boolean).pop() ?? route;
    const meta = (mod as Record<string, any>).prototype ?? {};
    return {
      href,
      title: meta.title ?? slug.replace(/[-_]/g, ' ').replace(/^\w/, (c: string) => c.toUpperCase()),
      summary: meta.summary ?? '',
      tag: meta.tag ?? '',
    };
  })
  .sort((a, b) => a.title.localeCompare(b.title));

// Orientation cards — the three rules this spoke runs on.
const principles = [
  {
    title: 'Carbon-first',
    body: 'Every control is a stock cds-* web component. Walk the catalog before building anything — it almost always exists.',
  },
  {
    title: 'Reskin via tokens',
    body: 'Theme by overriding --cds-* tokens and switching light/dark zones. Never hand-roll component CSS.',
  },
  {
    title: 'Compose, fast',
    body: 'Assemble screens from Carbon legos. A section no single component covers becomes a small src/components/* piece.',
  },
];
---

<BaseLayout title="Carbon Spoke">
  <main class="page">
    <cds-stack gap="8">
      <header class="head cds--css-grid">
        <div class="cds--css-grid-column cds--sm:col-span-4 cds--md:col-span-6 cds--lg:col-span-10">
          <p class="head__eyebrow">Carbon Spoke</p>
          <h1 class="head__title">Prototypes</h1>
          <p class="head__lede">
            A design workspace for building UIs fast by composing the Carbon Design
            System's stock, accessible <code>cds-*</code> components. Every screen below
            is assembled from that catalog — no bespoke controls.
          </p>
        </div>
      </header>

      <!-- Prototype directory (auto-generated from src/pages/**). Each card is a
           2x-Grid column: 4 cols wide → 4-up at lg, 2-up at md, 1-up at sm. -->
      <section class="cds--css-grid cds--css-grid--with-row-gap">
        <div class="section-head cds--css-grid-column cds--sm:col-span-4 cds--md:col-span-8 cds--lg:col-span-16">
          <h2 class="section-head__title">Screens</h2>
          <cds-tag type="cool-gray">{prototypes.length} prototype{prototypes.length === 1 ? '' : 's'}</cds-tag>
        </div>

        {prototypes.length === 0 ? (
          <p class="muted cds--css-grid-column cds--sm:col-span-4 cds--md:col-span-8 cds--lg:col-span-16">No prototypes yet. Add a page under <code>src/pages/</code> and it shows up here.</p>
        ) : (
          prototypes.map((proto) => (
            <a class="proto cds--css-grid-column cds--sm:col-span-4 cds--md:col-span-4 cds--lg:col-span-4" href={proto.href}>
              <cds-tile>
                <cds-stack gap="3">
                  {proto.tag && <cds-tag type="teal">{proto.tag}</cds-tag>}
                  <h3 class="proto__name">{proto.title}</h3>
                  {proto.summary && <p class="proto__summary">{proto.summary}</p>}
                  <span class="proto__go">Open&nbsp;→</span>
                </cds-stack>
              </cds-tile>
            </a>
          ))
        )}
      </section>

      <!-- Orientation: how this spoke works -->
      <section class="cds--css-grid cds--css-grid--with-row-gap">
        <div class="section-head cds--css-grid-column cds--sm:col-span-4 cds--md:col-span-8 cds--lg:col-span-16">
          <h2 class="section-head__title">How this spoke works</h2>
        </div>
        {principles.map((rule) => (
          <cds-tile class="cds--css-grid-column cds--sm:col-span-4 cds--md:col-span-4 cds--lg:col-span-4">
            <cds-stack gap="3">
              <h3 class="proto__name">{rule.title}</h3>
              <p class="proto__summary">{rule.body}</p>
            </cds-stack>
          </cds-tile>
        ))}
        <p class="muted foot cds--css-grid-column cds--sm:col-span-4 cds--md:col-span-8 cds--lg:col-span-12">
          Full detail lives in <code>CLAUDE.md</code> and the <code>carbon-first</code> skill.
          To add a screen: create <code>src/pages/&lt;slug&gt;.astro</code> and give it an
          <code>export const prototype</code> — it lists itself here.
        </p>
      </section>
    </cds-stack>
  </main>
</BaseLayout>

<style>
  /* Page-level layout only — component styling lives in the cds-* legos. Width
     + horizontal margins are owned by the 2x Grid (.cds--css-grid on each
     section: Carbon responsive margins, centered, capped at 99rem). This wrapper
     only sets vertical padding. */
  .page {
    padding-block: 3rem 6rem;
  }
  .head__eyebrow {
    margin: 0;
    font-family: 'IBM Plex Mono', ui-monospace, monospace;
    font-size: 0.75rem;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--cds-text-secondary, #525252);
  }
  .head__title {
    margin: 0.25rem 0 0;
    font-size: 2.5rem;
    font-weight: 400;
    line-height: 1.1;
  }
  .head__lede {
    margin: 0.75rem 0 0;
    max-width: 42rem;
    color: var(--cds-text-secondary, #525252);
  }
  /* Row-gap on the section grid handles the space below this heading. */
  .section-head {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .section-head__title {
    margin: 0;
    font-size: 1.25rem;
    font-weight: 400;
  }
  /* The whole card is a link; the cds-tile inside carries the surface + tokens. */
  .proto {
    text-decoration: none;
    color: inherit;
    display: block;
    transition: transform 120ms ease;
  }
  .proto:hover {
    transform: translateY(-2px);
  }
  .proto__name {
    margin: 0;
    font-size: 1.125rem;
    font-weight: 500;
    color: var(--cds-text-primary, #161616);
  }
  .proto__summary {
    margin: 0;
    color: var(--cds-text-secondary, #525252);
  }
  .proto__go {
    color: var(--cds-link-primary, #0f62fe);
    font-size: 0.875rem;
  }
  .muted {
    margin: 0;
    color: var(--cds-text-secondary, #525252);
  }
  .foot {
    margin-top: 1rem;
    font-size: 0.875rem;
  }
  code {
    font-family: 'IBM Plex Mono', ui-monospace, monospace;
    font-size: 0.9em;
  }
</style>
