---
import { withBase } from '../lib/base';
/* manifest:
     shell:  PermitNav (cds-header UI Shell) — Admin tools › "Manage internal users".
     header: identity banner (g100) — "Users" system-admin console + crumb.
     spine:  main.page > .cds--css-grid (single full-width column)
     sections:
       - Role change requests -> the pending inbox. A cds-table (user, current role,
                                 requested role, reason) with per-row Approve / Deny.
                                 Approving promotes the user's account role. Empty
                                 state when the queue is clear.
       - All users            -> the account directory: a cds-table (user, account
                                 role, affiliation) with per-row "Manage" opening a
                                 cds-modal to set the account role directly.
   This is the ACCOUNT axis — a user's global role lives here, not on any one
   district. (District MEMBERSHIP is edited per-district in /manage-district.)
   Prototype-local: requests + role changes persist to localStorage via
   src/data/requests.ts, shared with the profile page that submits requests.
*/
import BaseLayout from '../layouts/BaseLayout.astro';
import PermitNav from '../components/PermitNav.astro';
import PermitSection from '../components/PermitSection.astro';
import { directory, accountRoleOptions, expertiseOptions } from '../data/user';
import { districtDirectory } from '../data/district';

export const prototype = {
  title: 'Users',
  summary:
    'The system-admin console for user accounts — review and approve role-change ' +
    'requests, and manage every user’s global account role in one place.',
  tag: 'Internal tool',
};

// Dropdown options render alphabetically. (expertiseOptions is already A–Z with
// "Other" pinned last at the source, so it's rendered as-authored.)
const rolesSorted = [...accountRoleOptions].sort((a, b) => a.label.localeCompare(b.label));
const districtsSorted = [...districtDirectory].sort((a, b) => a.name.localeCompare(b.name));
---

<BaseLayout title="Users">
  <PermitNav slot="nav" />

  <main class="page">
    <header class="banner cds--g100">
      <div class="banner__inner">
        <cds-breadcrumb no-trailing-slash class="banner__crumb">
          <cds-breadcrumb-item>
            <cds-breadcrumb-link href={withBase('/')}>Home</cds-breadcrumb-link>
          </cds-breadcrumb-item>
          <cds-breadcrumb-item>
            <cds-breadcrumb-link aria-current="page">Users</cds-breadcrumb-link>
          </cds-breadcrumb-item>
        </cds-breadcrumb>

        <p class="banner__eyebrow t-label-01">System administration</p>
        <h1 class="banner__name t-heading-05">Users</h1>
      </div>
    </header>

    <div class="cds--css-grid cds--css-grid--with-row-gap body">
      <div class="col cds--css-grid-column cds--sm:col-span-4 cds--md:col-span-8 cds--lg:col-span-16">
        <!-- Action confirmation. -->
        <cds-inline-notification
          id="admin-notice"
          hidden
          kind="success"
          low-contrast
          title=""
          subtitle=""
        ></cds-inline-notification>

        <!-- ── Role change requests (the inbox) ─────────────────────────────── -->
        <PermitSection title="Role change requests">
          <p class="section-hint t-body-01">
            Role changes reviewers requested from their profile. Approving
            <strong>promotes the user’s account role</strong> to the one requested; denying it
            closes the request.
          </p>

          <!-- carbon-checked: empty-state copy is prose, not a control — a <p> with a
               Carbon type role is the house pattern (see manage-district hints). -->
          <p id="requests-empty" class="empty t-body-01" hidden>No pending role change requests.</p>

          <div class="table-wrap" id="requests-wrap">
            <cds-table>
              <cds-table-head>
                <cds-table-header-row>
                  <cds-table-header-cell>User</cds-table-header-cell>
                  <cds-table-header-cell>Current role</cds-table-header-cell>
                  <cds-table-header-cell>Requested role</cds-table-header-cell>
                  <cds-table-header-cell>Reason</cds-table-header-cell>
                  <cds-table-header-cell>Actions</cds-table-header-cell>
                </cds-table-header-row>
              </cds-table-head>
              <cds-table-body id="requests-tbody"></cds-table-body>
            </cds-table>
          </div>
        </PermitSection>

        <!-- ── All users (the account directory) ────────────────────────────── -->
        <PermitSection title="All users">
          <cds-tag slot="aside" type="cool-gray" id="users-count">{directory.length}</cds-tag>
          <cds-button slot="aside" kind="tertiary" size="sm" id="add-user-btn">
            Add user
            <svg slot="icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" width="16" height="16" aria-hidden="true">
              <path d="M17 15L17 8 15 8 15 15 8 15 8 17 15 17 15 24 17 24 17 17 24 17 24 15z"></path>
            </svg>
          </cds-button>
          <p class="section-hint t-body-01">
            Every account and its global role. Use <strong>Manage</strong> to set a role, or
            <strong>Add user</strong> to create one. Per-district assignments are edited on the
            district’s management screen, not here.
          </p>
          <div class="table-wrap">
            <cds-table>
              <cds-table-head>
                <cds-table-header-row>
                  <cds-table-header-cell>User</cds-table-header-cell>
                  <cds-table-header-cell>Account role</cds-table-header-cell>
                  <cds-table-header-cell>Expertise</cds-table-header-cell>
                  <cds-table-header-cell>Affiliation</cds-table-header-cell>
                  <cds-table-header-cell>Actions</cds-table-header-cell>
                </cds-table-header-row>
              </cds-table-head>
              <cds-table-body id="users-tbody"></cds-table-body>
            </cds-table>
          </div>
        </PermitSection>
      </div>
    </div>

    <!-- ── Manage-user modal: set the account role directly ─────────────────── -->
    <cds-modal id="user-modal" size="sm">
      <cds-modal-header>
        <cds-modal-close-button></cds-modal-close-button>
        <cds-modal-label>User account</cds-modal-label>
        <cds-modal-heading>Manage user</cds-modal-heading>
      </cds-modal-header>
      <cds-modal-body>
        <div class="modal-grid">
          <!-- Identity is owned by the user's account (read-only here). -->
          <div class="identity">
            <p class="identity__name t-heading-compact-01" id="u-name"></p>
            <p class="identity__meta t-body-01">
              <span id="u-email"></span>
              <span id="u-affil"></span>
            </p>
            <p class="identity__note t-label-01">Identity comes from this user’s account — only their role is set here.</p>
          </div>

          <!-- autoalign: Floating UI positions the open menu so it escapes the
               modal's scroll container instead of being clipped/faded at the
               bottom (Carbon drops the modal's mask fade when a dropdown auto-aligns). -->
          <cds-dropdown id="u-role" title-text="Account role" autoalign>
            {rolesSorted.map((r) => (
              <cds-dropdown-item value={r.value}>{r.label}</cds-dropdown-item>
            ))}
          </cds-dropdown>
          <!-- carbon-checked: the dropdown has no per-option helper slot; this <p>
               is the reusable home for the selected role's description. -->
          <p class="modal-desc t-label-01" id="u-role-desc"></p>

          <!-- District picker — shown only for a district-scoped role (lead /
               assistant), which is always the lead/assistant OF a district. -->
          <div id="u-district-wrap" hidden>
            <cds-dropdown id="u-district" title-text="District" autoalign>
              {districtsSorted.map((d) => (
                <cds-dropdown-item value={d.id}>{d.name}</cds-dropdown-item>
              ))}
            </cds-dropdown>
          </div>

          <!-- Areas of expertise — required (≥1) for HQ technical reviewers. -->
          <div>
            <cds-multi-select id="u-expertise" title-text="Areas of expertise" label="Select areas" autoalign>
              {expertiseOptions.map((e) => (
                <cds-multi-select-item value={e.value}>{e.label}</cds-multi-select-item>
              ))}
            </cds-multi-select>
            <p class="modal-hint t-label-01" id="u-expertise-hint"></p>
          </div>
        </div>
      </cds-modal-body>
      <cds-modal-footer>
        <cds-modal-footer-button kind="secondary" data-modal-close>Cancel</cds-modal-footer-button>
        <cds-modal-footer-button kind="primary" id="u-save">Save role</cds-modal-footer-button>
      </cds-modal-footer>
    </cds-modal>

    <!-- ── Add-user modal: create an account, set its role + expertise ───────── -->
    <cds-modal id="add-modal" size="sm">
      <cds-modal-header>
        <cds-modal-close-button></cds-modal-close-button>
        <cds-modal-label>User account</cds-modal-label>
        <cds-modal-heading>Add user</cds-modal-heading>
      </cds-modal-header>
      <cds-modal-body>
        <div class="modal-grid">
          <div class="name-row">
            <cds-text-input id="au-first" label="First name" placeholder="e.g. Jordan"></cds-text-input>
            <cds-text-input id="au-last" label="Last name" placeholder="e.g. Rivera"></cds-text-input>
          </div>
          <cds-text-input id="au-email" type="email" label="Email" placeholder="name@parks.ca.gov"></cds-text-input>
          <cds-text-input id="au-phone" label="Phone" placeholder="(916) 555-0100"></cds-text-input>

          <cds-dropdown id="au-role" title-text="Account role" label="Select a role" autoalign>
            {rolesSorted.map((r) => (
              <cds-dropdown-item value={r.value}>{r.label}</cds-dropdown-item>
            ))}
          </cds-dropdown>
          <p class="modal-desc t-label-01" id="au-role-desc"></p>

          <!-- District — required for a district-scoped role. -->
          <div id="au-district-wrap" hidden>
            <cds-dropdown id="au-district" title-text="District" autoalign>
              {districtsSorted.map((d) => (
                <cds-dropdown-item value={d.id}>{d.name}</cds-dropdown-item>
              ))}
            </cds-dropdown>
          </div>

          <!-- Areas of expertise — required (≥1) for HQ technical reviewers. -->
          <div>
            <cds-multi-select id="au-expertise" title-text="Areas of expertise" label="Select areas" autoalign>
              {expertiseOptions.map((e) => (
                <cds-multi-select-item value={e.value}>{e.label}</cds-multi-select-item>
              ))}
            </cds-multi-select>
            <p class="modal-hint t-label-01" id="au-expertise-hint"></p>
          </div>
        </div>
      </cds-modal-body>
      <cds-modal-footer>
        <cds-modal-footer-button kind="secondary" data-modal-close>Cancel</cds-modal-footer-button>
        <cds-modal-footer-button kind="primary" id="au-save">Add user</cds-modal-footer-button>
      </cds-modal-footer>
    </cds-modal>
  </main>
</BaseLayout>

<script>
  import { accountRoleOptions, accountRoleMeta, findUser, expertiseLabel } from '../data/user';
  import {
    pendingRequests,
    decideRequest,
    accountRoleOf,
    accountRoleDisplay,
    setAccountRole,
    roleLabel,
    roleDisplay,
    affiliationOf,
    expertiseOf,
    setExpertise,
    listUsers,
    resolveUser,
    addUser,
  } from '../data/requests';
  import { avatarHTML } from '../lib/avatar';

  const $ = (id: string) => document.getElementById(id);
  const esc = (s = '') =>
    s.replace(/[&<>"']/g, (m) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[m] as string));
  // A User cell: shared initials chip + name/email — one source (src/lib/avatar.ts).
  const userCellHTML = (name: string, email: string) =>
    `<div class="u-id">${avatarHTML(name, 'sm')}` +
    `<span class="u-idtext"><span class="u-name">${esc(name)}</span><span class="u-sub">${esc(email)}</span></span></div>`;

  const notice = $('admin-notice') as any;
  const flash = (title: string, subtitle: string) => {
    if (!notice) return;
    notice.title = title;
    notice.subtitle = subtitle;
    notice.hidden = false;
    notice.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
  };

  // ── Requests inbox ──────────────────────────────────────────────────────────
  const renderRequests = () => {
    const tbody = $('requests-tbody');
    const empty = $('requests-empty');
    const wrap = $('requests-wrap');
    if (!tbody) return;

    const rows = pendingRequests();
    if (empty) empty.hidden = rows.length > 0;
    if (wrap) wrap.hidden = rows.length === 0;

    tbody.replaceChildren(
      ...rows.map((req) => {
        const user = findUser(req.userId);
        const row = document.createElement('cds-table-row');

        const userCell = document.createElement('cds-table-cell');
        userCell.innerHTML = userCellHTML(user?.name ?? '(unknown user)', user?.email ?? '');

        const currentCell = document.createElement('cds-table-cell');
        currentCell.innerHTML = `<cds-tag type="cool-gray" size="sm">${esc(accountRoleDisplay(req.userId))}</cds-tag>`;

        const requestedCell = document.createElement('cds-table-cell');
        requestedCell.innerHTML = `<cds-tag type="blue" size="sm">${esc(roleDisplay(req.role, req.district))}</cds-tag>`;

        const reasonCell = document.createElement('cds-table-cell');
        reasonCell.innerHTML = `<span class="u-reason">${esc(req.reason || '—')}</span>`;

        const actionCell = document.createElement('cds-table-cell');
        const wrapEl = document.createElement('div');
        wrapEl.className = 'row-actions';
        const approve = document.createElement('cds-button');
        approve.setAttribute('kind', 'primary'); approve.setAttribute('size', 'sm');
        approve.textContent = 'Approve';
        approve.addEventListener('click', () => {
          decideRequest(req.id, 'approved');
          renderRequests();
          renderUsers();
          flash('Request approved', `${user?.name ?? 'The user'} is now ${roleDisplay(req.role, req.district)}.`);
        });
        const deny = document.createElement('cds-button');
        deny.setAttribute('kind', 'danger-ghost'); deny.setAttribute('size', 'sm');
        deny.textContent = 'Deny';
        deny.addEventListener('click', () => {
          decideRequest(req.id, 'denied');
          renderRequests();
          flash('Request denied', `${user?.name ?? 'The user'}’s request for ${roleLabel(req.role)} was denied.`);
        });
        wrapEl.append(approve, deny);
        actionCell.appendChild(wrapEl);

        row.append(userCell, currentCell, requestedCell, reasonCell, actionCell);
        return row;
      }),
    );
  };

  // ── User directory ──────────────────────────────────────────────────────────
  // Expertise cell: one quiet chip per area, or an em dash when none.
  const expertiseCellHTML = (values: string[]) =>
    values.length
      ? `<div class="u-expertise">${values
          .map((v) => `<cds-tag type="cool-gray" size="sm">${esc(expertiseLabel(v))}</cds-tag>`)
          .join('')}</div>`
      : '<span class="u-sub">—</span>';

  const renderUsers = () => {
    const tbody = $('users-tbody');
    if (!tbody) return;
    const users = listUsers();
    const count = $('users-count');
    if (count) count.textContent = String(users.length);

    tbody.replaceChildren(
      ...users.map((u) => {
        const row = document.createElement('cds-table-row');

        const userCell = document.createElement('cds-table-cell');
        userCell.innerHTML = userCellHTML(u.name, u.email);

        const roleCell = document.createElement('cds-table-cell');
        // Just the role label — the district already lives in the Affiliation
        // column, so repeating it here (accountRoleDisplay adds it) is redundant.
        roleCell.textContent = roleLabel(accountRoleOf(u.id).role);

        const expertiseCell = document.createElement('cds-table-cell');
        expertiseCell.innerHTML = expertiseCellHTML(expertiseOf(u.id));

        // District for a district-scoped role, else "HQ" — derived from the role.
        const affilCell = document.createElement('cds-table-cell');
        affilCell.textContent = affiliationOf(u.id);

        const actionCell = document.createElement('cds-table-cell');
        const manage = document.createElement('cds-button');
        manage.setAttribute('kind', 'ghost'); manage.setAttribute('size', 'sm');
        manage.textContent = 'Manage';
        manage.addEventListener('click', () => openUserModal(u.id));
        actionCell.appendChild(manage);

        row.append(userCell, roleCell, expertiseCell, affilCell, actionCell);
        return row;
      }),
    );
  };

  // ── Manage-user modal ─────────────────────────────────────────────────────────
  const modal = $('user-modal') as any;
  const roleEl = $('u-role') as any;
  const roleDesc = $('u-role-desc');
  const districtWrap = $('u-district-wrap');
  const districtEl = $('u-district') as any;
  const expertiseEl = $('u-expertise') as any;
  const expertiseHint = $('u-expertise-hint');
  let editingUserId = '';

  const HQ = 'hq-technical';
  const isScoped = (value: string) => !!accountRoleMeta(value)?.scoped;
  const expertiseHintText = (value: string) =>
    value === HQ
      ? 'Required — HQ technical reviewers need at least one area of expertise.'
      : 'Optional — the reviewer’s resource-domain expertise.';

  // A district role needs a district; a global one doesn't — show the picker and
  // the role's description to match the current selection. Expertise is required
  // for the HQ technical reviewer role, optional otherwise.
  const syncForRole = (value: string) => {
    if (roleDesc) roleDesc.textContent = accountRoleMeta(value)?.description ?? '';
    if (districtWrap) districtWrap.hidden = !isScoped(value);
    if (expertiseHint) {
      expertiseHint.textContent = expertiseHintText(value);
      expertiseHint.removeAttribute('data-error');
    }
  };

  const openUserModal = (userId: string) => {
    editingUserId = userId;
    const u = resolveUser(userId);
    if ($('u-name')) $('u-name')!.textContent = u?.name ?? '';
    if ($('u-email')) $('u-email')!.textContent = u?.email ?? '';
    if ($('u-affil')) $('u-affil')!.textContent = affiliationOf(userId);

    const { role, district } = accountRoleOf(userId);
    if (roleEl) roleEl.value = role || accountRoleOptions[0].value;
    if (districtEl) districtEl.value = district || 'north-coast-redwoods';
    // Setting the multi-select's comma-joined value reconciles its checkboxes.
    if (expertiseEl) expertiseEl.value = expertiseOf(userId).join(',');
    syncForRole(roleEl?.value);
    modal.open = true;
  };

  roleEl?.addEventListener('cds-dropdown-selected', () => syncForRole(roleEl.value));

  $('u-save')?.addEventListener('click', () => {
    const value = roleEl?.value;
    if (!value || !editingUserId) return;
    const district = isScoped(value) ? (districtEl?.value || 'north-coast-redwoods') : undefined;
    const expertise = (expertiseEl?.value || '').split(',').filter(Boolean);
    // Enforce the HQ-technical expertise rule before committing.
    if (value === HQ && expertise.length === 0) {
      if (expertiseHint) {
        expertiseHint.textContent = 'HQ technical reviewers need at least one area of expertise.';
        expertiseHint.setAttribute('data-error', '');
      }
      return;
    }
    setAccountRole(editingUserId, value, district);
    setExpertise(editingUserId, expertise);
    modal.open = false;
    renderUsers();
    renderRequests(); // current-role column may reference this user
    const u = resolveUser(editingUserId);
    flash('Role updated', `${u?.name ?? 'The user'} is now ${roleDisplay(value, district)}.`);
  });

  // ── Add-user modal ──────────────────────────────────────────────────────────
  const addModal = $('add-modal') as any;
  const auFirst = $('au-first') as any;
  const auLast = $('au-last') as any;
  const auEmail = $('au-email') as any;
  const auPhone = $('au-phone') as any;
  const auRole = $('au-role') as any;
  const auRoleDesc = $('au-role-desc');
  const auDistrictWrap = $('au-district-wrap');
  const auDistrict = $('au-district') as any;
  const auExpertise = $('au-expertise') as any;
  const auExpertiseHint = $('au-expertise-hint');

  const clearInvalid = (el: any) => { if (el) el.invalid = false; };

  const auSyncForRole = (value: string) => {
    if (auRoleDesc) auRoleDesc.textContent = accountRoleMeta(value)?.description ?? '';
    if (auDistrictWrap) auDistrictWrap.hidden = !isScoped(value);
    if (auExpertiseHint) {
      auExpertiseHint.textContent = expertiseHintText(value);
      auExpertiseHint.removeAttribute('data-error');
    }
  };

  const openAddModal = () => {
    if (auFirst) { auFirst.value = ''; clearInvalid(auFirst); }
    if (auLast) { auLast.value = ''; clearInvalid(auLast); }
    if (auEmail) { auEmail.value = ''; clearInvalid(auEmail); }
    if (auPhone) auPhone.value = '';
    if (auRole) { auRole.value = ''; clearInvalid(auRole); }
    if (auDistrict) auDistrict.value = 'north-coast-redwoods';
    if (auExpertise) auExpertise.value = '';
    auSyncForRole('');
    addModal.open = true;
  };

  $('add-user-btn')?.addEventListener('click', openAddModal);
  auRole?.addEventListener('cds-dropdown-selected', () => { clearInvalid(auRole); auSyncForRole(auRole.value); });
  auFirst?.addEventListener('input', () => clearInvalid(auFirst));
  auLast?.addEventListener('input', () => clearInvalid(auLast));
  auEmail?.addEventListener('input', () => clearInvalid(auEmail));

  $('au-save')?.addEventListener('click', () => {
    const first = (auFirst?.value || '').trim();
    const last = (auLast?.value || '').trim();
    const name = [first, last].filter(Boolean).join(' ');
    const email = (auEmail?.value || '').trim();
    const phone = (auPhone?.value || '').trim();
    const role = auRole?.value || '';
    const district = isScoped(role) ? (auDistrict?.value || 'north-coast-redwoods') : undefined;
    const expertise = (auExpertise?.value || '').split(',').filter(Boolean);

    let ok = true;
    if (!first) { if (auFirst) { auFirst.invalid = true; auFirst.invalidText = 'Enter a first name.'; } ok = false; }
    if (!last) { if (auLast) { auLast.invalid = true; auLast.invalidText = 'Enter a last name.'; } ok = false; }
    if (!email) { if (auEmail) { auEmail.invalid = true; auEmail.invalidText = 'Enter an email address.'; } ok = false; }
    if (!role) { if (auRole) { auRole.invalid = true; auRole.invalidText = 'Select an account role.'; } ok = false; }
    if (role === HQ && expertise.length === 0) {
      if (auExpertiseHint) {
        auExpertiseHint.textContent = 'HQ technical reviewers need at least one area of expertise.';
        auExpertiseHint.setAttribute('data-error', '');
      }
      ok = false;
    }
    if (!ok) return;

    addUser({ name, email, phone, role, district, expertise });
    addModal.open = false;
    renderUsers();
    flash('User added', `${name} was added as ${roleDisplay(role, district)}.`);
  });

  // ── Init ──────────────────────────────────────────────────────────────────────
  renderRequests();
  renderUsers();
</script>

<style>
  .page { padding-block: 0 6rem; }

  /* Identity banner — same construction as the other admin screens. */
  .banner {
    background: var(--cds-background, #161616);
    margin-inline: calc(50% - 50vw);
    padding-block: var(--cds-spacing-07, 2rem);
  }
  .banner__inner {
    max-inline-size: 99rem;
    margin-inline: auto;
    padding-inline: var(--cds-grid-margin, 1.5rem);
  }
  .banner__crumb { display: block; margin-bottom: var(--cds-spacing-05, 1rem); }
  .banner__eyebrow { margin: 0 0 var(--cds-spacing-02, 0.25rem); color: var(--cds-text-secondary, #525252); }
  .banner__name { margin: 0; }

  .body { margin-top: var(--cds-spacing-07, 2rem); }
  .col {
    display: flex;
    flex-direction: column;
    gap: 2.75rem;
    min-width: 0;
  }

  .section-hint {
    margin: 0 0 1.25rem;
    max-width: 52rem;
    color: var(--cds-text-secondary, #525252);
  }
  .empty {
    margin: 0;
    padding: 1.5rem 0;
    color: var(--cds-text-secondary, #525252);
  }
  .empty[hidden], #requests-wrap[hidden], #admin-notice[hidden] { display: none; }
  #admin-notice { margin-bottom: 1.25rem; max-width: 52rem; }

  /* Tables — client-rendered cells use global classes. */
  .table-wrap { overflow-x: auto; }
  :global(.u-id) { display: flex; align-items: center; gap: 0.625rem; }
  :global(.u-idtext) { min-width: 0; }
  /* The identity chip (.avatar) is styled globally in theme.css — one source. */
