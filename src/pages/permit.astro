---
/* manifest:
     shell:  cds-header (ui-shell)  — name + nav + Admin tools menu + cds-search
             + profile/logout global actions
     spine:  main.page > cds-stack(gap 6)
     Editorial layout: sections are headings + whitespace, NOT boxed tiles. Data
     records (contacts, people, sites, dates) render as editorial blocks /
     structured lists / tables — cds-tag only for genuine classifications.
     sections:
       - breadcrumb    -> cds-breadcrumb  (Permits / 26-635-017)
       - permit header -> PermitHeader.astro  (title, status indicator, actions,
                          classification badges, at-a-glance labeled fact row)
       - tabs          -> cds-tabs + cds-tab x6, panels toggled on cds-tabs-selected
           overview      -> Application summary (prose), Analysis team (person
                            blocks), Comments (thread), Application history
                            (cds-progress-indicator, vertical)
           study areas   -> Parks (list), Collection sites (place blocks)
           special cond. -> standard conditions (numbered list)
           project info  -> Research team (contact blocks + participants structured
                            list), Project details (FactGrid + prose), Field
                            occurrences (date list)
           data collect. -> facts (FactGrid), specimens (cds-table)
           add. docs     -> compliance (FactGrid), files (cds-table)
*/
import BaseLayout from '../layouts/BaseLayout.astro';
import PermitHeader from '../components/PermitHeader.astro';
import PermitSection from '../components/PermitSection.astro';
import FactGrid from '../components/FactGrid.astro';
import ContactCard from '../components/ContactCard.astro';
import Avatar from '../components/Avatar.astro';
import { permit } from '../data/permit';

export const prototype = {
  title: 'Permit detail',
  summary:
    'A reviewer opens a single scientific research & collection permit — status, ' +
    'requested dates, at-a-glance flags — and works through six tabbed sections.',
  tag: 'Internal tool',
};

const tabs = [
  { value: 'overview', label: 'Overview' },
  { value: 'study-areas', label: 'Study areas' },
  { value: 'special-conditions', label: 'Special conditions' },
  { value: 'project-information', label: 'Project information' },
  { value: 'data-collection', label: 'Data collection' },
  { value: 'additional-documentation', label: 'Additional documentation' },
];

const stats = [
  { label: 'Requested window', value: `${permit.activeWindow.start} – ${permit.activeWindow.end}` },
  { label: 'Submitted', value: 'Jul 9, 2026' },
];

const t = permit.researchTeam;
---

<BaseLayout title={`${permit.id} — ${permit.name}`}>
  <!-- Nav bar (ui-shell header) -->
  <cds-header aria-label="CA State Parks Scientific Research and Collection Permits">
    <cds-header-name href="#" prefix="CA State Parks">Research &amp; Collection Permits</cds-header-name>

    <cds-header-nav menu-bar-label="Primary navigation">
      <cds-header-nav-item href="#">Resource category tags</cds-header-nav-item>
      <cds-header-nav-item href="#">Districts</cds-header-nav-item>
      <cds-header-nav-item href="#">Help</cds-header-nav-item>
      <cds-header-menu menu-label="Admin tools" trigger-content="Admin tools">
        <cds-header-menu-item href="#">User management</cds-header-menu-item>
        <cds-header-menu-item href="#">Permit templates</cds-header-menu-item>
        <cds-header-menu-item href="#">Resource categories</cds-header-menu-item>
        <cds-header-menu-item href="#">Audit log</cds-header-menu-item>
        <cds-header-menu-item href="#">System settings</cds-header-menu-item>
      </cds-header-menu>
    </cds-header-nav>

    <div class="header__search">
      <cds-search id="site-search" size="lg" label-text="Search" placeholder="Search permits, applicants, sites"></cds-search>
    </div>

    <cds-header-global-action aria-label="Profile" tooltip-text="Profile">
      <svg slot="icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" width="20" height="20" aria-hidden="true">
        <path d="M16,4a5,5,0,1,1-5,5,5,5,0,0,1,5-5m0-2a7,7,0,1,0,7,7A7,7,0,0,0,16,2Z"/>
        <path d="M26,30H24V25a5,5,0,0,0-5-5H13a5,5,0,0,0-5,5v5H6V25a7,7,0,0,1,7-7h6a7,7,0,0,1,7,7Z"/>
      </svg>
    </cds-header-global-action>
    <cds-header-global-action aria-label="Log out" tooltip-text="Log out">
      <svg slot="icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" width="20" height="20" aria-hidden="true">
        <path d="M6,30H18a2.0023,2.0023,0,0,0,2-2V25H18v3H6V4H18V7h2V4a2.0023,2.0023,0,0,0-2-2H6A2.0023,2.0023,0,0,0,4,4V28A2.0023,2.0023,0,0,0,6,30Z"/>
        <path d="M20.586 20.586 24.172 17 10 17 10 15 24.172 15 20.586 11.414 22 10 28 16 22 22 20.586 20.586z"/>
      </svg>
    </cds-header-global-action>
  </cds-header>

  <main class="page">
    <cds-stack gap="6">
      <PermitHeader
        id={permit.id}
        name={permit.name}
        organization={permit.researchTeam.organization.name}
        status={permit.status}
        infoTags={permit.infoTags}
        flagTags={permit.flagTags}
        stats={stats}
      >
        <cds-breadcrumb slot="breadcrumb">
          <cds-breadcrumb-item>
            <cds-breadcrumb-link href="#">Permits</cds-breadcrumb-link>
          </cds-breadcrumb-item>
          <cds-breadcrumb-item>
            <cds-breadcrumb-link aria-current="page">{permit.id}</cds-breadcrumb-link>
          </cds-breadcrumb-item>
        </cds-breadcrumb>

        <cds-tabs slot="tabs" id="permit-tabs" value="overview">
          {tabs.map((tab) => (
            <cds-tab id={`tab-${tab.value}`} value={tab.value}>{tab.label}</cds-tab>
          ))}
        </cds-tabs>
      </PermitHeader>

      <section>
        <div class="panels">
          <!-- ── Overview ─────────────────────────────────────────────── -->
          <div class="panel" data-panel="overview" role="tabpanel" aria-labelledby="tab-overview">
            <div class="overview-grid">
              <div class="overview-main">
              <PermitSection title="Application summary">
                <p class="lede t-body-02">{permit.projectInfo.purpose}</p>
              </PermitSection>

              <PermitSection title="Analysis team">
                <span slot="aside" class="internal-flag t-label-01">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" width="16" height="16" fill="currentColor" aria-hidden="true">
                    <path d="M2.6,11.3l0.7-0.7C2.6,9.8,1.9,9,1.5,8c1-2.5,3.8-4.5,6.5-4.5c0.7,0,1.4,0.1,2,0.4l0.8-0.8C9.9,2.7,9,2.5,8,2.5 C4.7,2.6,1.7,4.7,0.5,7.8c0,0.1,0,0.2,0,0.3C1,9.3,1.7,10.4,2.6,11.3z"/>
                    <path d="M6,7.9c0.1-1,0.9-1.8,1.8-1.8l0.9-0.9C7.2,4.7,5.5,5.6,5.1,7.2C5,7.7,5,8.3,5.1,8.8L6,7.9z"/>
                    <path d="M15.5,7.8c-0.6-1.5-1.6-2.8-2.9-3.7L15,1.7L14.3,1L1,14.3L1.7,15l2.6-2.6c1.1,0.7,2.4,1,3.7,1.1c3.3-0.1,6.3-2.2,7.5-5.3 C15.5,8.1,15.5,7.9,15.5,7.8z M10,8c0,1.1-0.9,2-2,2c-0.3,0-0.7-0.1-1-0.3L9.7,7C9.9,7.3,10,7.6,10,8z M8,12.5c-1,0-2.1-0.3-3-0.8 l1.3-1.3c1.4,0.9,3.2,0.6,4.2-0.8c0.7-1,0.7-2.4,0-3.4l1.4-1.4c1.1,0.8,2,1.9,2.6,3.2C13.4,10.5,10.6,12.5,8,12.5z"/>
                  </svg>
                  Internal only
                </span>
                <ul class="roster">
                  {permit.overview.analysisTeam.map((m) => (
                    <li class:list={['roster__row', m.highlight && 'roster__row--active']}>
                      <div class="roster__person">
                        <p class="roster__name t-heading-compact-01">{m.name}</p>
                        <p class="roster__role t-body-01">{m.role}</p>
                        {m.detail && <p class="roster__detail t-body-01">{m.detail}</p>}
                      </div>
                      <span class="roster__status t-body-01">{m.status}</span>
                    </li>
                  ))}
                </ul>
              </PermitSection>

              <PermitSection title="Comments">
                <ul class="thread">
                  {permit.overview.comments.map((c) => (
                    <li class="comment">
                      <Avatar name={c.author} size="sm" />
                      <div class="comment__body">
                        <p class="comment__meta t-label-01"><span class="comment__author">{c.author}</span> · {c.time}</p>
                        <p class="comment__text t-body-01">{c.text}</p>
                      </div>
                    </li>
                  ))}
                </ul>
              </PermitSection>
              </div>

              <aside class="overview-aside">
                <PermitSection title="Application history">
                  <div class="phases">
                    {permit.overview.history.map((phase) => (
                      <div class="phase">
                        <h3 class="phase__title t-heading-01">{phase.phase}</h3>
                        <cds-progress-indicator vertical>
                          {phase.steps.map((s) => (
                            <cds-progress-step
                              complete={s.state === 'complete'}
                              current={s.state === 'current'}
                              label={s.label}
                              secondary-label-text={[s.decision, s.date].filter(Boolean).join(' · ')}
                            ></cds-progress-step>
                          ))}
                        </cds-progress-indicator>
                      </div>
                    ))}
                  </div>
                </PermitSection>
              </aside>
            </div>
          </div>

          <!-- ── Study areas ──────────────────────────────────────────── -->
          <div class="panel" data-panel="study-areas" role="tabpanel" aria-labelledby="tab-study-areas" hidden>
            <div class="stack">
              <PermitSection title="Authorized parks" editable>
                <p class="section-hint t-body-01">Parks where research and collection are authorized, grouped by administering district and its research coordinator.</p>
                <cds-structured-list>
                  <cds-structured-list-head>
                    <cds-structured-list-header-row>
                      <cds-structured-list-header-cell>District</cds-structured-list-header-cell>
                      <cds-structured-list-header-cell>Parks</cds-structured-list-header-cell>
                      <cds-structured-list-header-cell>Research coordinator</cds-structured-list-header-cell>
                    </cds-structured-list-header-row>
                  </cds-structured-list-head>
                  <cds-structured-list-body>
                    {permit.studyAreas.districts.map((d) => (
                      <cds-structured-list-row>
                        <cds-structured-list-cell>
                          <span class="district-cell">
                            {d.name}
                            <cds-tag type="gray" size="sm">{d.parks.length}</cds-tag>
                          </span>
                        </cds-structured-list-cell>
                        <cds-structured-list-cell>
                          <ul class="cell-list">
                            {d.parks.map((p) => <li>{p}</li>)}
                          </ul>
                        </cds-structured-list-cell>
                        <cds-structured-list-cell>
                          <span class="coord__name">{d.coordinator.name}</span>
                          <cds-link href={`mailto:${d.coordinator.email}`}>{d.coordinator.email}</cds-link>
                        </cds-structured-list-cell>
                      </cds-structured-list-row>
                    ))}
                  </cds-structured-list-body>
                </cds-structured-list>
              </PermitSection>

              <PermitSection title="Collection sites">
                <div class="site-grid">
                  {permit.studyAreas.sites.map((s) => (
                    <div class="site">
                      <p class="site__name t-heading-compact-01">{s.name}</p>
                      <p class="site__coords t-body-01">{s.coords}</p>
                      <p class="site__note t-body-01">{s.note}</p>
                    </div>
                  ))}
                </div>
              </PermitSection>
            </div>
          </div>

          <!-- ── Special conditions ───────────────────────────────────── -->
          <div class="panel" data-panel="special-conditions" role="tabpanel" aria-labelledby="tab-special-conditions" hidden>
            <div class="stack">
              <PermitSection title="Universal conditions" editable>
                <p class="section-hint t-body-01">Apply to all locations covered by this permit.</p>
                <cds-contained-list id="universal-conditions" label={`${permit.specialConditions.length} conditions`} kind="on-page">
                  <cds-search
                    slot="action"
                    size="lg"
                    placeholder="Filter conditions"
                    label-text="Filter universal conditions"
                    close-button-label-text="Clear filter"
                  ></cds-search>
                  {permit.specialConditions.map((c) => (
                    <cds-contained-list-item class="condition-item">{c}</cds-contained-list-item>
                  ))}
                </cds-contained-list>
              </PermitSection>

              <PermitSection title="District special conditions">
                <p class="section-hint t-body-01">Additional conditions apply within each district. Expand a district to review them.</p>
                <div class="district-conditions">
                  {permit.studyAreas.districts.map((d) => (
                    <cds-contained-list kind="on-page">
                      <div slot="label" class="district-label">
                        <span class="district-label__name">{d.name}</span>
                        <span class="district-label__count t-label-01">{d.parks.length} parks where research activities are permitted</span>
                      </div>
                      {d.conditions.map((c) => (
                        <cds-contained-list-item>{c}</cds-contained-list-item>
                      ))}
                    </cds-contained-list>
                  ))}
                </div>
              </PermitSection>
            </div>
          </div>

          <!-- ── Project information ──────────────────────────────────── -->
          <div class="panel" data-panel="project-information" role="tabpanel" aria-labelledby="tab-project-information" hidden>
            <div class="stack">
              <PermitSection title="Research team" editable>
                <div class="contact-grid">
                  <ContactCard role="Organization" contact={t.organization} />
                  <ContactCard role="Principal investigator" contact={t.principalInvestigator} />
                  <ContactCard role="Person in charge of field work" contact={t.fieldLead} />
                </div>
                <h3 class="subhead t-heading-01">Additional participants</h3>
                <cds-structured-list condensed>
                  <cds-structured-list-head>
                    <cds-structured-list-header-row>
                      <cds-structured-list-header-cell>Name</cds-structured-list-header-cell>
                      <cds-structured-list-header-cell>Phone</cds-structured-list-header-cell>
                      <cds-structured-list-header-cell>Email</cds-structured-list-header-cell>
                    </cds-structured-list-header-row>
                  </cds-structured-list-head>
                  <cds-structured-list-body>
                    {t.participants.map((p) => (
                      <cds-structured-list-row>
                        <cds-structured-list-cell>{p.name}</cds-structured-list-cell>
                        <cds-structured-list-cell>{p.phone || '—'}</cds-structured-list-cell>
                        <cds-structured-list-cell>
                          <cds-link href={`mailto:${p.email}`}>{p.email}</cds-link>
                        </cds-structured-list-cell>
                      </cds-structured-list-row>
                    ))}
                  </cds-structured-list-body>
                </cds-structured-list>
              </PermitSection>

              <PermitSection title="Project details" editable>
                <FactGrid rows={permit.projectInfo.details} />
                <h3 class="subhead t-heading-01">Project purpose</h3>
                <p class="lede t-body-02">{permit.projectInfo.purpose}</p>
                <h3 class="subhead t-heading-01">Anticipated benefits to the State Park System</h3>
                <p class="lede t-body-02">{permit.projectInfo.benefits}</p>
              </PermitSection>

              <PermitSection title="Field investigation occurrences">
                <cds-contained-list class="field-dates" label="Scheduled field dates" kind="on-page">
                  {permit.projectInfo.fieldOccurrences.map((d) => (
                    <cds-contained-list-item>{d}</cds-contained-list-item>
                  ))}
                </cds-contained-list>
              </PermitSection>
            </div>
          </div>

          <!-- ── Data collection ──────────────────────────────────────── -->
          <div class="panel" data-panel="data-collection" role="tabpanel" aria-labelledby="tab-data-collection" hidden>
            <div class="stack">
              <PermitSection title="Collection & facilities" editable>
                <FactGrid rows={permit.dataCollection.facts} min="20rem" />
              </PermitSection>

              <PermitSection title="Specimens to be collected">
                <cds-table>
                  <cds-table-head>
                    <cds-table-header-row>
                      <cds-table-header-cell>Species</cds-table-header-cell>
                      <cds-table-header-cell>Quantity</cds-table-header-cell>
                      <cds-table-header-cell>Portion</cds-table-header-cell>
                      <cds-table-header-cell>Condition</cds-table-header-cell>
                    </cds-table-header-row>
                  </cds-table-head>
                  <cds-table-body>
                    {permit.dataCollection.specimens.map((s) => (
                      <cds-table-row>
                        <cds-table-cell><em>{s.species}</em></cds-table-cell>
                        <cds-table-cell>{s.quantity}</cds-table-cell>
                        <cds-table-cell>{s.portion}</cds-table-cell>
                        <cds-table-cell>{s.condition}</cds-table-cell>
                      </cds-table-row>
                    ))}
                  </cds-table-body>
                </cds-table>
              </PermitSection>
            </div>
          </div>

          <!-- ── Additional documentation ─────────────────────────────── -->
          <div class="panel" data-panel="additional-documentation" role="tabpanel" aria-labelledby="tab-additional-documentation" hidden>
            <div class="stack">
              <PermitSection title="Compliance" editable>
                <FactGrid rows={permit.additionalDocs.facts} min="20rem" />
              </PermitSection>

              <PermitSection title="Uploaded files">
                <cds-table>
                  <cds-table-head>
                    <cds-table-header-row>
                      <cds-table-header-cell>File</cds-table-header-cell>
                      <cds-table-header-cell>Type</cds-table-header-cell>
                      <cds-table-header-cell>Size</cds-table-header-cell>
                      <cds-table-header-cell>Uploaded by</cds-table-header-cell>
                      <cds-table-header-cell>Date</cds-table-header-cell>
                    </cds-table-header-row>
                  </cds-table-head>
                  <cds-table-body>
                    {permit.additionalDocs.files.map((f) => (
                      <cds-table-row>
                        <cds-table-cell>{f.name}</cds-table-cell>
                        <cds-table-cell>{f.type}</cds-table-cell>
                        <cds-table-cell>{f.size}</cds-table-cell>
                        <cds-table-cell>{f.by}</cds-table-cell>
                        <cds-table-cell>{f.date}</cds-table-cell>
                      </cds-table-row>
                    ))}
                  </cds-table-body>
                </cds-table>
              </PermitSection>
            </div>
          </div>
        </div>
      </section>
    </cds-stack>
  </main>
</BaseLayout>

<script>
  // cds-tabs renders only the tab strip; panel visibility is the app's job.
  const tabsEl = document.getElementById('permit-tabs') as any;
  const panels = Array.from(document.querySelectorAll<HTMLElement>('.panel'));

  function showPanel(value: string) {
    panels.forEach((p) => { p.hidden = p.dataset.panel !== value; });
  }
  tabsEl?.addEventListener('cds-tabs-selected', () => showPanel(tabsEl.value));

  // Header (site) search: submitting a query takes the reviewer to the results page.
  const siteSearch = document.getElementById('site-search') as any;
  siteSearch?.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key !== 'Enter') return;
    const q = (siteSearch.value ?? '').trim();
    window.location.href = q ? `/search?q=${encodeURIComponent(q)}` : '/search';
  });

  // Universal conditions: filter the contained-list items by the header search.
  const conditionsList = document.getElementById('universal-conditions');
  const conditionItems = Array.from(
    conditionsList?.querySelectorAll<HTMLElement>('.condition-item') ?? [],
  );
  conditionsList?.addEventListener('cds-search-input', (e) => {
    const q = ((e as CustomEvent).detail?.value ?? '').trim().toLowerCase();
    conditionItems.forEach((item) => {
      item.hidden = q !== '' && !(item.textContent ?? '').toLowerCase().includes(q);
    });
  });
</script>

<style>
  /* Page-level LAYOUT only — component look lives in cds-* legos + --cds-* tokens.
     body already offsets the fixed ui-shell header (theme.css padding-top). */
  .page {
    max-width: 68rem;
    margin: 0 auto;
    padding: 1.5rem 1.5rem 6rem;
  }
  .header__search {
    margin-left: auto;
    max-width: 22rem;
    width: 100%;
  }
  .panels { margin-top: 1.5rem; }

  /* Editorial rhythm — sections separated by whitespace, not boxes. */
  .stack {
    display: flex;
    flex-direction: column;
    gap: 2.75rem;
  }
  /* Overview: main content column + Application-history rail down the right.
     The rail runs the full height of the panel alongside summary/team/comments. */
  .overview-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.75rem;
  }
  .overview-main {
    display: flex;
    flex-direction: column;
    gap: 2.75rem;
    min-width: 0;
  }
  @media (min-width: 60rem) {
    .overview-grid {
      grid-template-columns: minmax(0, 1fr) 18rem;
      gap: 3rem;
      align-items: start;
    }
  }

  .lede {
    margin: 0 0 1.25rem;
    max-width: 48rem;
    color: var(--cds-text-secondary, #525252);
  }
  .subhead {
    margin: 1.5rem 0 0.75rem;
  }

  /* "Internal only" section flag (eye-off icon + label). */
  .internal-flag {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    color: var(--cds-text-secondary, #525252);
  }

  /* Analysis team — a full-width reviewer roster. Name over role over detail on
     the left; sign-off status/date on the right. The active reviewer (you) is
     lifted onto a raised surface; the rest sit on the page with hairline rules. */
  .roster {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .roster__row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.875rem 0;
  }
  .roster__row + .roster__row {
    border-top: 1px solid var(--cds-border-subtle-01, #e0e0e0);
  }
  /* Active reviewer (you): a raised layer surface — value contrast only, no
     shadow or hue. The fill bleeds horizontally so the text stays aligned with
     the other rows. */
  .roster__row--active {
    background: var(--cds-layer-01, #f4f4f4);
    padding: 0.875rem 1rem;
    margin: 0 -1rem;
  }
  /* No divider directly under the raised active row. */
  .roster__row--active + .roster__row {
    border-top: 0;
  }
  .roster__person {
    min-width: 0;
  }
  .roster__name {
    margin: 0;
  }
  .roster__role {
    margin: 0.125rem 0 0;
    color: var(--cds-text-secondary, #525252);
  }
  .roster__detail {
    margin: 0.0625rem 0 0;
    color: var(--cds-text-secondary, #525252);
  }
  .roster__status {
    flex: 0 0 auto;
    color: var(--cds-text-secondary, #525252);
    white-space: nowrap;
  }

  /* Application history — phases (Presubmittal, In review, …), each a labeled
     group with its own vertical cds-progress-indicator. Layout/spacing only;
     the step rail, dots, and states are Carbon's. */
  .phases {
    display: flex;
