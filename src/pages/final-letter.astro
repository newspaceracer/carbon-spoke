---
/* manifest:
     shell:  PermitNav (cds-header UI Shell) — same app bar as the permit detail page
     header: PermitHeader.astro — the SAME identity header as the permit detail page
             (g100 banner, org/title/status/tags/facts + compact-bar-on-scroll)
     spine:  main.page
               wiz-track  (grid, col 16) -> horizontal cds-progress-indicator, one per STEP
               page-head  (grid, col 16) -> Step N of M + title (JS-updated)
               step 0     (grid) -> application review (col 10) + conditions rail (col 6)
               step 1     (grid) -> letter-feeding fields (col 7) + live letter (col 9)
               step 2     (grid) -> the finished package + send (col 12, centered)
               wiz-actions(grid, col 16) -> Back / Cancel / Continue-or-Send
     purpose:
       ONE review journey, not two. The analyst reviews the permit BY WALKING the
       wizard; the letter is the running output of that walk. The right rail changes
       job per step — conditions while reviewing, the letter while finalizing —
       because *which* conditions apply is driven by what's in the application, so
       application ↔ conditions belong side by side, and the letter is downstream
       of both.

         ① Review & conditions — the application in the submitter's own summary
            format. The applicant's IDENTITY (research team, institution,
            participants, submitted dates) is fixed from the submission and shown
            read-only; what the analyst may still set for the permit is EDITABLE
            INLINE here — project title, category, the authorized parks per
            district, and the collected specimens — while curating the special
            conditions in the right rail.
         ② Finalize the letter — the internal review items that shape the letter
            (permit type, valid dates, report-due, authorized parks + district
            contacts, signer, an optional note), with the real letter regenerating
            live alongside. The applicant identity is shown read-only here (it's
            fixed from the application), so there's one source of truth.
         ③ Review & send — the finished package (a recap of what was set + the full
            letter), then sent for signature.

       Thesis: everything on the letter is a field, so nothing is hand-edited on the
       PDF. The letterhead (Governor / Director) is admin/template-level and changes
       rarely, so it is fixed here (a template concern, not a per-permit field).

     Preview vs. PDF: the right pane is a live HTML rendition; a real build mints the
     signed PDF ONCE at send, from the same template, so they can't diverge.

     State is prototype-local (localStorage), shared with the rest of the spoke:
       permit-final-${id}            confirmed dates, applicant + signer fields, note
       permit-parks-${id}            edited authorized-parks set
       permit-conditions-${id}       applied conditions (shared with the permit tab)
       permit-finalize-step-${id}    resume position in the wizard
       permit-status-${id}           lifecycle status (shared with PermitHeader)
*/
import BaseLayout from '../layouts/BaseLayout.astro';
import PermitNav from '../components/PermitNav.astro';
import PermitHeader from '../components/PermitHeader.astro';
import ApplicationReview from '../components/ApplicationReview.astro';
import ContactCard from '../components/ContactCard.astro';
import { permit } from '../data/permit';
import { parks } from '../data/parks';
import { districtKey } from '../data/conditions';
import { userDirectory } from '../data/user';
import { withBase } from '../lib/base';

export const prototype = {
  title: 'Final letter — finalize wizard',
  summary:
    'One review journey: the analyst reviews the application and sets the conditions, ' +
    'finalizes the letter as it regenerates live, then reviews the full package and ' +
    'sends it for signature.',
  tag: 'Internal tool',
};

const t = permit.researchTeam;
const isMultiDistrict = permit.infoTags.some((tag) => tag.label === 'Multi-district');
const responsibleAnalyst = permit.overview.analysisTeam.find((m) => m.highlight);

// ── Permit header props ─── mirror the permit detail page so the finalize view
// carries the identical header (same classification badges + at-a-glance facts).
const involvementTags = [
  ...(permit.dataCollection.involvesCollection ? [{ label: 'Specimen collection', type: 'blue' }] : []),
  ...(permit.dataCollection.involvesLaboratory ? [{ label: 'Laboratory work', type: 'blue' }] : []),
];
const headerInfoTags = [...permit.infoTags, ...involvementTags];
const headerStats = [
  { label: 'Requested window', value: `${permit.activeWindow.start} – ${permit.activeWindow.end}` },
  { label: 'Submitted', value: 'Jul 9, 2026' },
  { label: 'Responsible analyst', value: responsibleAnalyst?.name ?? '—' },
];

// ── Seed the letter fields from the application record ──────────────────────
// Split "Dr. Alena Reyes" → salutation + name; "Cal Poly Humboldt — Dept. of …"
// → institution + department; "1 Harpst St, Arcata, CA 95521" → street + rest.
// These feed the client state; the editable inputs themselves live in
// ApplicationReview and are filled by the script below.
const saluteMatch = t.principalInvestigator.name.match(/^(Dr\.|Mr\.|Ms\.|Mrs\.)\s+(.*)$/);
const [orgInstitution, orgDepartment] = t.organization.name.split('—').map((s) => s.trim());
const addr = t.organization.address ?? '';
const firstComma = addr.indexOf(',');
const street = firstComma > -1 ? addr.slice(0, firstComma).trim() : addr;
const cityStateZip = firstComma > -1 ? addr.slice(firstComma + 1).trim() : '';

const pages = [
  { id: 'review', label: 'Review & conditions', secondaryLabel: 'Check the application, set the conditions' },
  { id: 'letter', label: 'Finalize the letter', secondaryLabel: 'Confirm what prints, review the letter' },
  { id: 'package', label: 'Review & send', secondaryLabel: 'The full package, then send for signature' },
];

// Candidate district contacts come from the user directory, scoped to the users
// associated with that district (`detail` = the district name). The current
// coordinator is always a selectable option — if they aren't in the directory,
// prepend them so the current contact is still representable and pre-selected.
const districtContactOptions = (districtName: string, coordinator: { name: string; email?: string; phone?: string }) => {
  const key = districtKey(districtName);
  const fromDirectory = userDirectory
    .filter((u) => u.detail === districtName)
    .map((u) => ({ id: u.id, name: u.name, role: u.role, email: u.email, phone: '' }));
  const match = fromDirectory.find((o) => o.email === (coordinator.email ?? ''));
  if (match) match.phone = coordinator.phone ?? ''; // keep the coordinator's phone on the default pick
  const options = match
    ? fromDirectory
    : [{ id: `coord-${key}`, name: coordinator.name, role: 'District coordinator', email: coordinator.email ?? '', phone: coordinator.phone ?? '' }, ...fromDirectory];
  return { options, selectedId: (match ?? options[0]).id };
};

const districts = permit.studyAreas.districts.map((d) => {
  const { options, selectedId } = districtContactOptions(d.name, d.coordinator);
  return {
    name: d.name,
    key: districtKey(d.name),
    coordinator: d.coordinator,
    officePhone: d.coordinator.phone ?? '',
    parks: d.parks,
    available: parks
      .filter((p) => p.district === d.name && !d.parks.includes(p.name))
      .map((p) => ({ id: p.id, name: p.name })),
    contactOptions: options,
    selectedContactId: selectedId,
  };
});

// One flat parks list for step ②'s authorized-parks control (single list, not one
// per district). Scoped to this permit's districts — the state parks directory for
// those districts plus any already-authorized units the directory doesn't list, so
// the current selection is always representable. Mirrors step ①'s Study areas.
const permitDistrictNames = permit.studyAreas.districts.map((d) => d.name);
const directoryParkOptions = parks
  .filter((p) => permitDistrictNames.includes(p.district))
  .map((p) => ({ name: p.name, district: p.district }));
const directoryParkNames = new Set(directoryParkOptions.map((p) => p.name));
const seededParkExtras = permit.studyAreas.districts.flatMap((d) =>
  d.parks.filter((name) => !directoryParkNames.has(name)).map((name) => ({ name, district: d.name })),
);
const allParkOptions = [...directoryParkOptions, ...seededParkExtras].sort((a, b) => a.name.localeCompare(b.name));

// A permit that ORIGINALLY authorizes a single district is locked to it: the
// analyst may add/remove parks within that district but can't add parks from any
// other district (that would make it a multi-district permit). A permit that
// started multi-district can be pared down freely (with confirmation — see the
// drop-district modal). "Originally" = the districts the submitted parks span.
const originalDistrictsWithParks = permit.studyAreas.districts.filter((d) => d.parks.length > 0).map((d) => d.name);
const originallySingle = originalDistrictsWithParks.length === 1;
const soleDistrict = originallySingle ? originalDistrictsWithParks[0] : null;
// When locked to one district, only that district's parks are offered.
const scopedParkOptions = originallySingle ? allParkOptions.filter((p) => p.district === soleDistrict) : allParkOptions;

const letterData = {
  permitId: permit.id,
  window: permit.activeWindow,
  districtKeys: districts.map((d) => d.key),
  districts,
  // Park-locking rule (see above): originally-single permits can't gain other
  // districts' parks.
  originallySingle,
  soleDistrict,
  pages: pages.map((p) => ({ id: p.id, label: p.label, secondaryLabel: p.secondaryLabel })),
  permitUrl: withBase('/permit'),
  // The reviewer comment thread — SHARED with the permit detail page (same
  // storage key + seed), so the analyst reads the team's existing comments and
  // adds to the same conversation from anywhere in the wizard.
  comments: permit.overview.comments.map((c) => ({ author: c.author, time: c.time, text: c.text })),
  currentUser: responsibleAnalyst?.name ?? 'You',
  // Specimen seed — the authorized taxa/quantities, editable on step ① and
  // printed on the letter as the authorized collection.
  specimens: permit.dataCollection.specimens.map((s) => ({ ...s })),
  // Editable field seeds. Identity (salutation/piName/department/institution/
  // street/cityStateZip) is now FIXED from the application — it still seeds the
  // letter, but there are no inputs for it. Editable on step ①: projectTitle,
  // category. Editable on step ②: signer, permitType.
  seed: {
    salutation: saluteMatch ? saluteMatch[1] : 'Dr.',
    piName: saluteMatch ? saluteMatch[2] : t.principalInvestigator.name,
    department: orgDepartment ?? '',
    institution: orgInstitution ?? t.organization.name,
    street,
    cityStateZip,
    projectTitle: permit.name,
    category: permit.category,
    permitType: isMultiDistrict ? 'multi-district' : 'single-district',
    signerName: responsibleAnalyst?.name ?? '',
    signerClassification: 'Environmental Scientist',
  },
};
---

<BaseLayout title={`Finalize ${permit.id}`}>
  <PermitNav slot="nav" />

  <main class="page">
    <PermitHeader
      id={permit.id}
      name={permit.name}
      organization={permit.researchTeam.organization.name}
      status={permit.status}
      infoTags={headerInfoTags}
      flagTags={permit.flagTags}
      stats={headerStats}
      requestedWindow={permit.activeWindow}
      analysisTeam={permit.overview.analysisTeam}
      directory={userDirectory}
      context="finalize"
    >
      <cds-breadcrumb slot="breadcrumb" no-trailing-slash>
        <cds-breadcrumb-item><cds-breadcrumb-link href={withBase('/permits')}>Permits</cds-breadcrumb-link></cds-breadcrumb-item>
        <cds-breadcrumb-item><cds-breadcrumb-link href={withBase('/permit')}>{permit.id}</cds-breadcrumb-link></cds-breadcrumb-item>
        <cds-breadcrumb-item><cds-breadcrumb-link aria-current="page">Finalize</cds-breadcrumb-link></cds-breadcrumb-item>
      </cds-breadcrumb>
    </PermitHeader>

    <!-- Horizontal progress track — full width, so the side-by-side content keeps
         its room. Steps are a tracker, not a gate; position resumes on return. -->
    <nav class="wiz-track cds--css-grid" aria-label="Finalize steps">
      <!-- The grid-column classes go on this wrapper, NOT on the progress indicator:
           a col-span class forces `display:block` on its element, which would defeat
           `cds-progress-indicator`'s own `:host{display:flex}` and collapse the steps
           (space-equally has no flex row to distribute across). -->
      <div class="cds--css-grid-column cds--sm:col-span-4 cds--md:col-span-8 cds--lg:col-span-16">
        <cds-progress-indicator id="wiz-progress" space-equally>
          {pages.map((p) => (
            <cds-progress-step label={p.label} secondary-label={p.secondaryLabel}></cds-progress-step>
          ))}
        </cds-progress-indicator>
      </div>
    </nav>

    <div class="page-head cds--css-grid">
      <header class="page-head__inner cds--css-grid-column cds--sm:col-span-4 cds--md:col-span-8 cds--lg:col-span-16">
        <p id="page-head-eyebrow" class="page-head__eyebrow t-label-01">Step 1 of {pages.length}</p>
        <h2 id="page-head-title" class="page-head__title t-heading-04">{pages[0].label}</h2>
        <p id="page-head-sub" class="page-head__sub t-body-02">{pages[0].secondaryLabel}</p>
      </header>
    </div>

    <!-- ① Review & conditions ─ application (editable identity fields) + rail. -->
    <section class="step cds--css-grid cds--css-grid--with-row-gap" data-step="0">
      <div class="col-main cds--css-grid-column cds--sm:col-span-4 cds--md:col-span-8 cds--lg:col-span-10">
        <ApplicationReview />
      </div>
      <aside class="col-rail cds--css-grid-column cds--sm:col-span-4 cds--md:col-span-8 cds--lg:col-span-6" aria-label="Special conditions">
        <div class="rail">
          <h3 class="rail__title t-heading-03">Special conditions</h3>
          <p class="rail__sub t-label-01">Standard conditions from headquarters and each district attach automatically. Add the conditional ones (e.g. Western Snowy Plover) from the catalog, or remove any that don't apply to this permit.</p>
          <div id="conditions-input"></div>
        </div>
      </aside>
    </section>

    <!-- ② Finalize the letter ─ letter-feeding fields + the live letter. -->
    <section class="step cds--css-grid cds--css-grid--with-row-gap" data-step="1" hidden>
      <div class="col-fields cds--css-grid-column cds--sm:col-span-4 cds--md:col-span-8 cds--lg:col-span-7">
        <cds-inline-notification
          kind="info" low-contrast hide-close-button
          title="These set the letter"
          subtitle="The internal review items that shape the letter. The applicant's identity is fixed from the submitted application."
        ></cds-inline-notification>

        <!-- Read-only recap of the applicant identity — fixed from the application. -->
        <div class="field-group">
          <h3 class="field-group__title t-heading-compact-01">Addressed to</h3>
          <div id="identity-recap" class="recap"></div>
        </div>

        <div class="field-group">
          <h3 class="field-group__title t-heading-compact-01">Permit type</h3>
          <p id="fb-permittype" class="derived-value t-body-01">—</p>
          <p class="field-hint t-label-01">Set automatically from the authorized parks — multi-district when they span more than one district.</p>
        </div>

        <div class="field-group">
          <h3 class="field-group__title t-heading-compact-01">Permit window</h3>
          <cds-date-picker id="fb-window" date-format="m/d/Y">
            <cds-date-picker-input kind="from" label-text="Permit start" placeholder="mm/dd/yyyy"></cds-date-picker-input>
            <cds-date-picker-input kind="to" label-text="Permit end" placeholder="mm/dd/yyyy"></cds-date-picker-input>
          </cds-date-picker>
        </div>

        <div class="field-group">
          <h3 class="field-group__title t-heading-compact-01">Summary report due</h3>
          <cds-date-picker id="fb-report" date-format="m/d/Y">
            <cds-date-picker-input kind="single" label-text="Report due" placeholder="mm/dd/yyyy"></cds-date-picker-input>
          </cds-date-picker>
          <p class="field-hint t-label-01">Defaults to one year after the start date. Change it to override.</p>
        </div>

        <div class="field-group">
          <h3 class="field-group__title t-heading-compact-01">Authorized parks</h3>
          <p class="field-hint t-label-01">Every park this permit authorizes, across all districts — the same set as Study areas on the previous step. Add or remove a park and the letter's contact list and permit type update to match.</p>
          <!-- One flat list (not one per district). Same mechanic as step ①'s Study
               areas: a filterable cds-multi-select over every in-scope park + a single
               roster with a District column. The shell is static; the page script sets
               the multi-select's value and repaints the roster — never rebuilding the
               web component (which would lose filter text/focus). -->
          <cds-multi-select
            id="fb-parks-select"
            filterable
            selection-feedback="fixed"
            title-text="Add parks"
            label="Search by park or district name"
          >
            {scopedParkOptions.map((p) => (
              <cds-multi-select-item value={p.name} data-district={p.district}>{p.name} — {p.district}</cds-multi-select-item>
            ))}
          </cds-multi-select>
          <div class="selected">
            <p class="selected__label t-label-01">Authorized parks <span id="fb-parks-count"></span></p>
            <cds-table class="ro-table">
              <cds-table-head>
                <cds-table-header-row>
                  <cds-table-header-cell>Park</cds-table-header-cell>
                  <cds-table-header-cell>District</cds-table-header-cell>
                  <cds-table-header-cell>Remove</cds-table-header-cell>
                </cds-table-header-row>
              </cds-table-head>
              <cds-table-body id="fb-parks-body"></cds-table-body>
            </cds-table>
            <p class="field-hint t-label-01" id="fb-parks-empty" hidden>No parks authorized yet — add one above.</p>
          </div>
        </div>

        <div class="field-group">
          <h3 class="field-group__title t-heading-compact-01">District contacts</h3>
          <p class="field-hint t-label-01">The coordinator each district authorizes applicants to contact before field work — shown as a contact tile. Reassign it to another person in that district and the letter's contact list updates to match.</p>
          <!-- One group per district: a ContactCard tile per candidate (only the
               selected one shown) + a picker to reassign. Rendering the tiles up
               front lets the script swap the visible one by toggling display —
               matching the ContactCard pattern used for every other contact. -->
          <div id="contacts-input">
            {districts.map((d) => (
              <div class="contact-group" data-contact-group={d.name}>
                <div class="contact-group__tiles">
                  {d.contactOptions.map((c) => (
                    <div data-contact-tile={c.id} style={c.id === d.selectedContactId ? '' : 'display:none'}>
                      <ContactCard role={d.name} contact={{ name: c.name, phone: c.phone, email: c.email }} />
                    </div>
                  ))}
                </div>
                <cds-dropdown class="contact-picker" data-contact-picker title-text="Change contact" value={d.selectedContactId}>
                  {d.contactOptions.map((c) => (
                    <cds-dropdown-item value={c.id}>{c.name} — {c.role}</cds-dropdown-item>
                  ))}
                </cds-dropdown>
              </div>
            ))}
          </div>
        </div>

        <div class="field-group">
          <h3 class="field-group__title t-heading-compact-01">Signature</h3>
          <cds-text-input id="fb-signername" data-field="signerName" label="Signer name" placeholder="ES or EG name"></cds-text-input>
          <cds-text-input id="fb-signerclass" data-field="signerClassification" label="Classification" placeholder="e.g. Environmental Scientist"></cds-text-input>
        </div>

        <div class="field-group">
          <h3 class="field-group__title t-heading-compact-01">Reviewer note</h3>
          <p class="field-hint t-label-01">Optional. Appears on the letter under the conditions. Captured with the permit, so it can't drift from the record.</p>
          <cds-textarea id="fb-note" label="Note to the applicant" placeholder="e.g. Please pay particular attention to the Western Snowy Plover condition when working in coastal areas." rows="4"></cds-textarea>
        </div>
      </div>

      <aside class="preview cds--css-grid-column cds--sm:col-span-4 cds--md:col-span-8 cds--lg:col-span-9" aria-label="Final letter preview">
        <p class="preview__label t-label-01">Final letter — updates as you go</p>
        <article class="sheet cds--white letter-host" aria-label={`Final permit letter for ${permit.id}`}></article>
      </aside>
    </section>

    <!-- ③ Review & send ─ the finished package: recap + the full letter. -->
    <section class="step cds--css-grid cds--css-grid--with-row-gap" data-step="2" hidden>
      <div class="col-package cds--css-grid-column cds--sm:col-span-4 cds--md:col-span-8 cds--lg:col-span-12 cds--lg:col-start-3">
        <cds-inline-notification
          kind="info" low-contrast hide-close-button
          title="Review the full package, then send"
          subtitle="This is the letter as it will be issued. Confirm the summary below and read the letter through, then send it for signature."
        ></cds-inline-notification>

        <section class="pkg-recap">
          <h3 class="pkg-recap__title t-heading-03">What you're issuing</h3>
          <div id="package-recap" class="recap"></div>
        </section>

        <section class="pkg-letter">
          <p class="preview__label t-label-01">The letter</p>
          <article class="sheet cds--white letter-host" aria-label={`Final permit letter for ${permit.id}`}></article>
        </section>
      </div>
    </section>

    <!-- Actions sit UNDER the left content section, not full-bleed — so the column
         span tracks the active step's main column (set in render()): step ① col-10,
         step ② col-7, step ③ col-12 offset by col-start-3. -->
    <footer class="wiz-actions cds--css-grid">
      <div class="wiz-actions__inner cds--css-grid-column cds--sm:col-span-4 cds--md:col-span-8 cds--lg:col-span-10">
        <cds-button id="wiz-back" kind="secondary" hidden>Back</cds-button>
        <cds-button kind="ghost" href={withBase('/permit')}>Cancel</cds-button>
        <div class="wiz-actions__spacer"></div>
        <cds-button id="wiz-next">Save and continue</cds-button>
      </div>
    </footer>
  </main>

  <cds-modal id="send-modal" size="sm">
    <cds-modal-header>
      <cds-modal-close-button></cds-modal-close-button>
      <cds-modal-label>Permit {permit.id}</cds-modal-label>
      <cds-modal-heading>Send this letter for signature?</cds-modal-heading>
    </cds-modal-header>
    <cds-modal-body>
      <p class="t-body-01">
        The letter is locked from further edits and routed to the signers. The
        permit moves to <strong>Out for signature</strong>. You can still record the
        signed permit from the permit page once it comes back.
      </p>
    </cds-modal-body>
    <cds-modal-footer>
      <cds-modal-footer-button kind="secondary" data-modal-close>Keep editing</cds-modal-footer-button>
      <cds-modal-footer-button kind="primary" id="send-confirm" data-modal-close>Send for signature</cds-modal-footer-button>
    </cds-modal-footer>
  </cds-modal>

  <!-- Confirmation when removing a park would clear the LAST park in its district —
       that drops the district (and its contact) from the permit, and may flip the
       permit type from multi- to single-district. The body copy is set by the
       script from which districts empty. Closing without confirming reverts. -->
  <cds-modal id="drop-district-modal" size="sm" alert>
    <cds-modal-header>
      <cds-modal-close-button></cds-modal-close-button>
      <cds-modal-label>Permit {permit.id}</cds-modal-label>
      <cds-modal-heading id="drop-district-heading">Drop this district from the permit?</cds-modal-heading>
    </cds-modal-header>
    <cds-modal-body>
      <p class="t-body-01" id="drop-district-body"></p>
    </cds-modal-body>
    <cds-modal-footer>
      <cds-modal-footer-button kind="secondary" data-modal-close>Keep park</cds-modal-footer-button>
      <cds-modal-footer-button kind="danger" id="drop-district-confirm">Remove park</cds-modal-footer-button>
    </cds-modal-footer>
  </cds-modal>

  <!-- Add / edit a special condition — the same modal pattern as the permit
       detail page (src/pages/permit.astro): one dialog per scope that adds catalog
       picks and/or a written-from-scratch condition, and edits an existing one.
       The rich-text body IS the condition that prints; the title is an optional
       label for the builder list. -->
  <cds-modal id="cond-modal" size="md">
    <cds-modal-header>
      <cds-modal-close-button></cds-modal-close-button>
      <cds-modal-label id="cond-modal-owner">Headquarters</cds-modal-label>
      <cds-modal-heading id="cond-modal-heading">Add condition</cds-modal-heading>
    </cds-modal-header>
    <cds-modal-body has-scrolling-content>
      <cds-inline-notification
        id="cond-modal-warning"
        hidden
        kind="warning"
        low-contrast
        hide-close-button
        title="Add a condition first"
        subtitle="Pick a condition from the catalog or write one below."
      ></cds-inline-notification>

      <cds-stack gap="6">
        <div id="cond-pick-block">
          <cds-multi-select
            id="cond-pick"
            title-text="Add from the catalog"
            label="Select saved conditions"
            filterable
          ></cds-multi-select>
          <p class="cond-or t-label-01">or write a new one</p>
        </div>

        <div>
          <p class="cond-field-label t-label-01">Condition text</p>
          <sc-rich-text id="cond-body" placeholder="The exact wording that will print on the permit. Use the toolbar for bold, italics, lists, or a link…"></sc-rich-text>
        </div>

        <cds-checkbox id="cond-save-catalog" label-text="Also save to the catalog for reuse"></cds-checkbox>
      </cds-stack>
    </cds-modal-body>
    <cds-modal-footer>
      <cds-modal-footer-button kind="secondary" data-modal-close>Cancel</cds-modal-footer-button>
      <cds-modal-footer-button kind="primary" id="cond-modal-save">Save condition</cds-modal-footer-button>
    </cds-modal-footer>
  </cds-modal>

  <!-- Add / edit a specimen — the SAME construction as the application form's
       specimen dialog (src/components/DataCollectionStep.astro): four fields that
       add a row or edit one in place. -->
  <cds-modal id="specimen-modal" size="md">
    <cds-modal-header>
      <cds-modal-close-button></cds-modal-close-button>
      <cds-modal-label>Authorized collection</cds-modal-label>
      <cds-modal-heading id="specimen-modal-heading">Add a specimen type</cds-modal-heading>
    </cds-modal-header>
    <cds-modal-body>
      <div class="spec-fields">
        <div class="spec-fields__wide">
          <cds-text-input id="ns-species" label="Species"></cds-text-input>
        </div>
        <cds-text-input id="ns-quantity" label="Quantity"></cds-text-input>
        <cds-text-input id="ns-portion" label="Portion"></cds-text-input>
        <div class="spec-fields__wide">
          <cds-text-input id="ns-condition" label="Condition"></cds-text-input>
        </div>
      </div>
    </cds-modal-body>
    <cds-modal-footer>
      <cds-modal-footer-button kind="secondary" data-modal-close>Cancel</cds-modal-footer-button>
      <cds-modal-footer-button kind="primary" id="ns-save">Add specimen</cds-modal-footer-button>
    </cds-modal-footer>
  </cds-modal>

  <!-- Persistent comments trigger — fixed so it's reachable from ANY step and at
       any scroll position. carbon-checked: Carbon ships no floating-action host;
       this is only a fixed positioning wrapper (same pattern as apply's toast-host)
       around a stock cds-button. -->
  <div class="comments-fab">
    <cds-button id="comments-open" kind="ghost" size="md">
      Comments
      <span id="comments-count" class="comments-count" hidden></span>
    </cds-button>
  </div>

  <!-- Comments thread — a non-blocking slide-over so the analyst can read the
       team's comments and add their own while still viewing any step.
       carbon-checked: cds-side-panel is the stock overlay, but it's a heavy,
       animation/focus-managed component that misbehaved here; this is a documented
       bespoke drawer SHELL (fixed positioning only) whose controls are all stock
       cds-* (textarea, buttons, icon-button). Toggled by adding .drawer--open. -->
  <aside id="comments-panel" class="drawer" aria-label="Comments" aria-hidden="true">
    <div class="drawer__head">
      <h2 class="drawer__title t-heading-03">Comments</h2>
      <cds-icon-button id="comments-close" kind="ghost" size="sm" align="left">
        <svg slot="icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" width="16" height="16" aria-hidden="true"><path d="M17.4141 16 24 9.4141 22.5859 8 16 14.5859 9.4143 8 8 9.4141 14.5859 16 8 22.5859 9.4143 24 16 17.4141 22.5859 24 24 22.5859 17.4141 16z"/></svg>
        <span slot="tooltip-content">Close comments</span>
      </cds-icon-button>
    </div>
    <p class="comments-note t-label-01">Shared with the permit's review thread. Newest first.</p>
    <ul id="comments-thread" class="comments-thread"></ul>
    <div class="comments-composer">
      <cds-textarea id="comments-input" label="Add a comment" placeholder="Note something for the team… (⌘/Ctrl+Enter to post)" rows="3"></cds-textarea>
      <cds-button id="comments-add" kind="primary" size="md">Add comment</cds-button>
    </div>
  </aside>

  <script type="application/json" id="letter-data" set:html={JSON.stringify(letterData)}></script>

  <script>
    import {
      loadPermitConditions, savePermitConditions, loadInventory, saveInventory,
      ownerLabel, newConditionId, plainText,
      type PermitCondition, type ConditionOwner,
    } from '../data/conditions';
    // Same rich-text condition editor the permit detail page uses in its
    // add/edit-condition modal — registered here so <sc-rich-text> upgrades.
    import '../components/sc-rich-text.ts';

    interface ContactOption { id: string; name: string; role: string; email: string; phone: string }
    interface DistrictSeed {
      name: string; key: string;
      coordinator: { name: string; email?: string; phone?: string };
      officePhone: string; parks: string[];
      available: { id: string; name: string }[];
      contactOptions: ContactOption[];
      selectedContactId: string;
    }
    interface Specimen { species: string; quantity: string; portion: string; condition: string }
    interface LetterData {
      permitId: string;
      window: { start: string; end: string; startISO: string; endISO: string };
      districtKeys: string[]; districts: DistrictSeed[];
      originallySingle: boolean; soleDistrict: string | null;
      pages: { id: string; label: string; secondaryLabel: string }[];
      permitUrl: string;
      comments: { author: string; time: string; text: string }[];
      currentUser: string;
      specimens: Specimen[];
      seed: {
        salutation: string; piName: string; department: string; institution: string;
        street: string; cityStateZip: string; projectTitle: string; category: string;
        permitType: string; signerName: string; signerClassification: string;
      };
    }

    const data: LetterData = JSON.parse(document.getElementById('letter-data')?.textContent || '{}');
    const { permitId, districts } = data;

    const finalKey = `permit-final-${permitId}`;
    const parksKey = `permit-parks-${permitId}`;
    const statusKey = `permit-status-${permitId}`;
    const stepKey = `permit-finalize-step-${permitId}`;
    const reviewStartedKey = `permit-review-started-${permitId}`;

    // Guard: the wizard is only viewable once a reviewer has started their review
    // (the permit page's Start review sets the flag). A direct hit without it goes
    // back to the permit, which shows the gate instead.
    if (permitId && !localStorage.getItem(reviewStartedKey)) {
      window.location.replace(data.permitUrl);
    }

    const parseISO = (iso: string) => { const [y, m, d] = iso.split('-').map(Number); return new Date(y, m - 1, d); };
    const fmt = (iso: string) => parseISO(iso).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
    const toISO = (d: Date) => `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`;
    const plusYear = (iso: string) => { const d = parseISO(iso); return toISO(new Date(d.getFullYear() + 1, d.getMonth(), d.getDate())); };
    const esc = (s: string) => s.replace(/&/g, '&amp;').replace(/</g, '&lt;');

    // ── State ──────────────────────────────────────────────────────────────────
    const persistedFinal = JSON.parse(localStorage.getItem(finalKey) || '{}');
    const fld = persistedFinal.fields || {};
    const state = {
      startISO: (persistedFinal.startISO || data.window.startISO) as string,
      endISO: (persistedFinal.endISO || data.window.endISO) as string,
      reportISO: (persistedFinal.reportISO || plusYear(persistedFinal.startISO || data.window.startISO)) as string,
      reportOverridden: Boolean(persistedFinal.reportISO),
      parks: { ...Object.fromEntries(districts.map((d) => [d.name, d.parks])), ...JSON.parse(localStorage.getItem(parksKey) || '{}') } as Record<string, string[]>,
      // Chosen district contact (a contactOptions id) per district — persisted edits
      // win over the seeded coordinator.
      contactIds: { ...Object.fromEntries(districts.map((d) => [d.name, d.selectedContactId])), ...(persistedFinal.contactIds || {}) } as Record<string, string>,
      conditions: loadPermitConditions(permitId, data.districtKeys) as PermitCondition[],
      note: (persistedFinal.note || '') as string,
      // Editable letter fields — persisted seeds win over the application seed.
      fields: { ...data.seed, ...fld } as Record<string, string>,
      // Authorized specimens — persisted edits win over the application seed.
      specimens: (Array.isArray(persistedFinal.specimens) ? persistedFinal.specimens : data.specimens.map((s) => ({ ...s }))) as Specimen[],
    };

    const $ = (id: string) => document.getElementById(id);
    const persistParks = () => localStorage.setItem(parksKey, JSON.stringify(state.parks));
    const persistConditions = () => savePermitConditions(permitId, state.conditions);
    const persistFinal = () => localStorage.setItem(finalKey, JSON.stringify({
      ...persistedFinal, startISO: state.startISO, endISO: state.endISO, reportISO: state.reportISO,
      note: state.note, fields: state.fields, specimens: state.specimens, contactIds: state.contactIds,
    }));

    // Trash glyph for row-level DELETE actions (remove a park / specimen /
    // condition) — matches the application form's convention (StudyAreasStep,
    // DataCollectionStep, …), where removing a data row is a trashcan, not an X.
    const trashIcon =
      '<svg slot="icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" width="16" height="16" fill="currentColor" aria-hidden="true"><path d="M12 12H14V24H12zM18 12H20V24H18z"/><path d="M4 6V8H6V28a2 2 0 002 2H24a2 2 0 002-2V8h2V6zM8 28V8H24V28zM12 2H20V4H12z"/></svg>';

    // ── Editable letter fields (delegated input) ────────────────────────────────
    // cds-text-input retargets its inner input's `input` event to the host, which
    // carries data-field; read the host's value into state and re-render. The
    // project title lives in ApplicationReview (step ①); the signer inputs on
    // step ② — both are found by this one query.
    document.querySelectorAll<HTMLElement>('cds-text-input[data-field]').forEach((el) => {
      (el as any).value = state.fields[el.dataset.field!] ?? '';
      el.addEventListener('input', () => { state.fields[el.dataset.field!] = (el as any).value; persistFinal(); renderPreview(); });
    });
    // Dropdowns keyed by data-field — category (step ①). Permit type is no longer
    // an input; it's derived from the authorized parks (see refreshPermitType).
    document.querySelectorAll<HTMLElement>('cds-dropdown[data-field]').forEach((el) => {
      const field = el.dataset.field!;
      (el as any).value = state.fields[field];
      el.addEventListener('cds-dropdown-selected', (e: any) => {
        state.fields[field] = e.detail?.item?.value || state.fields[field]; persistFinal(); renderPreview();
      });
    });

    // ── Authorized parks ────────────────────────────────────────────────────────
    // ONE authorized-parks set (state.parks, keyed by district) drives two editors
    // and the letter — both now a SINGLE flat list (not one control per district):
    //   • Study areas (step ①) — a filterable multi-select + Park/District roster.
    //   • Authorized parks (step ②) — the SAME control, so both stay identical.
    // A change in either re-syncs the other via syncParks(), so they never drift.
    // Both shells are static markup; the script only sets each multi-select's value
    // and repaints its roster — the web components are never rebuilt (rebuilding
    // would lose filter text/focus and re-upgrade the element).
    const saSelect = $('sa-select') as any;   // step ①
    const fbSelect = $('fb-parks-select') as any; // step ②
    // Map every option's park name to its district, so a flat selection can be
    // regrouped into the district-keyed state.parks the letter needs. Both lists
    // carry the same options; read from either.
    const parkDistrict = new Map<string, string>();
    [saSelect, fbSelect].forEach((sel: any) => sel?.querySelectorAll('cds-multi-select-item').forEach((it: any) => {
      parkDistrict.set(it.getAttribute('value') || '', it.dataset.district || '');
    }));
    const selectedNames = () => Object.values(state.parks).flat();

    // Render one park editor (select + roster) from the shared selection. `count`
    // and `empty` are optional per editor.
    const renderParkList = (sel: any, body: Element | null, count: Element | null, empty: HTMLElement | null) => {
      const names = selectedNames();
      if (sel) sel.value = names.join(',');
      if (count) count.textContent = names.length ? `(${names.length})` : '';
      if (empty) empty.hidden = names.length > 0;
      if (body) {
        body.innerHTML = names
          .slice()
          .sort((a, b) => a.localeCompare(b))
          .map((name) => `
            <cds-table-row>
              <cds-table-cell>${esc(name)}</cds-table-cell>
              <cds-table-cell>${esc(parkDistrict.get(name) || '')}</cds-table-cell>
              <cds-table-cell>
                <cds-icon-button kind="ghost" size="sm" align="left" data-remove-park="${encodeURIComponent(name)}">
                  ${trashIcon}<span slot="tooltip-content">Remove ${esc(name)}</span>
                </cds-icon-button>
              </cds-table-cell>
            </cds-table-row>`).join('');
      }
    };
    const renderStudyAreas = () => renderParkList(saSelect, $('sa-body'), $('sa-count'), $('sa-empty') as HTMLElement | null);
    const renderFbParks = () => renderParkList(fbSelect, $('fb-parks-body'), $('fb-parks-count'), $('fb-parks-empty') as HTMLElement | null);

    // ── Permit type — DERIVED from the parks, not chosen. Multi-district when the
    // authorized parks span more than one district; single-district otherwise. ────
    const permitTypeEl = $('fb-permittype');
    const refreshPermitType = () => {
      const spanned = districts.filter((d) => (state.parks[d.name] || []).length > 0).length;
      const type = spanned >= 2 ? 'multi-district' : 'single-district';
      state.fields.permitType = type;
      if (permitTypeEl) permitTypeEl.textContent = type === 'multi-district' ? 'Multi-district permit' : 'Single-district permit';
    };

    // Re-render BOTH editors + the derived type + the letter from the single source.
    const syncParks = () => { refreshPermitType(); renderStudyAreas(); renderFbParks(); renderPreview(); };

    // Group a flat list of names into a NEW district→names map (pure — doesn't
    // touch state, so a change can be previewed/confirmed before it's committed).
    const groupNames = (names: string[]) => {
      const grouped: Record<string, string[]> = Object.fromEntries(districts.map((d) => [d.name, []]));
      names.forEach((name) => {
        const district = parkDistrict.get(name);
        if (district && grouped[district]) grouped[district].push(name);
      });
      return grouped;
    };
    const countWithParks = (parksMap: Record<string, string[]>) =>
      districts.filter((d) => (parksMap[d.name] || []).length > 0).length;

    const commitParks = (grouped: Record<string, string[]>) => {
      state.parks = grouped;
      persistParks(); syncParks();
    };

    // A change that clears the LAST park of a district needs confirmation: that
    // district (and its contact) drops off the permit, and the type may flip from
    // multi- to single-district. The change is held until the user confirms.
    const dropModal = $('drop-district-modal') as any;
    const dropBody = $('drop-district-body');
    const dropHeading = $('drop-district-heading');
    let pendingParks: Record<string, string[]> | null = null;

    const requestParksChange = (grouped: Record<string, string[]>) => {
      const emptied = districts
        .filter((d) => (state.parks[d.name] || []).length > 0 && (grouped[d.name] || []).length === 0)
        .map((d) => d.name);
      if (!emptied.length) { commitParks(grouped); return; }

      const after = countWithParks(grouped);
      const flips = countWithParks(state.parks) >= 2 && after === 1;
      const plural = emptied.length > 1;
      const list = emptied.join(' and ');
      let msg = `This clears the last authorized park in ${list}. ${plural ? 'Those districts' : 'That district'} will drop off the permit, so ${plural ? 'their' : 'its'} district contact is no longer listed on the letter.`;
      if (flips) msg += ' It also changes this from a multi-district to a single-district permit.';
      else if (after === 0) msg += ' No districts would remain authorized.';
      if (dropHeading) dropHeading.textContent = flips ? 'Make this a single-district permit?' : (plural ? 'Drop these districts from the permit?' : 'Drop this district from the permit?');
      if (dropBody) dropBody.textContent = msg;
      pendingParks = grouped;
      if (dropModal) dropModal.open = true;
    };
    $('drop-district-confirm')?.addEventListener('click', () => {
      if (pendingParks) { commitParks(pendingParks); pendingParks = null; }
      if (dropModal) dropModal.open = false;
    });
    // Any close that ISN'T a confirm (Keep park / X / Esc) reverts the pending
    // change by re-syncing the editors from the unchanged state.
    dropModal?.addEventListener('cds-modal-closed', () => {
      if (pendingParks) { pendingParks = null; syncParks(); }
    });

    // Both lists share the add path: read the flat multi-select value, then apply.
    // Rule: an originally single-district permit can't gain another district's parks
    // (the offered options are already scoped, so this only guards a stray value).
    const onParksSelected = (sel: any) => {
      const v = (sel?.value ?? '') as string;
      const names = v ? v.split(',').filter(Boolean) : [];
      if (data.originallySingle && names.some((n) => parkDistrict.get(n) !== data.soleDistrict)) {
        syncParks(); // reject: revert the selection to the current parks
        return;
      }
      requestParksChange(groupNames(names));
    };
    saSelect?.addEventListener('cds-multi-select-selected', () => onParksSelected(saSelect));
    fbSelect?.addEventListener('cds-multi-select-selected', () => onParksSelected(fbSelect));

    // Roster remove — either list. No district attribute; resolve it from the map.
    const onRosterRemove = (e: Event) => {
      const btn = (e.target as HTMLElement).closest?.('[data-remove-park]') as HTMLElement | null;
      if (!btn) return;
      const name = decodeURIComponent(btn.dataset.removePark || '');
      const district = parkDistrict.get(name);
      if (!district) return;
      const grouped = Object.fromEntries(districts.map((d) => [d.name, [...(state.parks[d.name] || [])]]));
      grouped[district] = grouped[district].filter((p) => p !== name);
      requestParksChange(grouped);
    };
    $('sa-body')?.addEventListener('click', onRosterRemove);
    $('fb-parks-body')?.addEventListener('click', onRosterRemove);

    // ── District contacts (step ②) ───────────────────────────────────────────────
    // Each district shows the selected contact as a ContactCard tile (one tile per
    // candidate, only the selected one visible) + a picker to reassign. Options are
    // the users associated with that district.
    const contactFor = (districtName: string): ContactOption | null => {
      const d = districts.find((x) => x.name === districtName);
      if (!d) return null;
      return d.contactOptions.find((c) => c.id === state.contactIds[districtName])
        ?? d.contactOptions.find((c) => c.id === d.selectedContactId)
        ?? null;
    };
    const contactGroups = [...document.querySelectorAll<HTMLElement>('[data-contact-group]')];
    const renderContacts = () => {
      contactGroups.forEach((group) => {
        const name = group.dataset.contactGroup!;
        const selId = state.contactIds[name];
        const dd = group.querySelector('[data-contact-picker]') as any;
        if (dd) dd.value = selId;
        group.querySelectorAll<HTMLElement>('[data-contact-tile]').forEach((tile) => {
          tile.style.display = tile.dataset.contactTile === selId ? '' : 'none';
        });
      });
    };
    contactGroups.forEach((group) => {
      const name = group.dataset.contactGroup!;
      const dd = group.querySelector('[data-contact-picker]') as any;
      dd?.addEventListener('cds-dropdown-selected', (e: any) => {
        const id = e.detail?.item?.value;
        if (!id) return;
        state.contactIds[name] = id;
        persistFinal(); renderContacts(); renderPreview();
      });
    });

    // ── Specimens input (step ①) ─────────────────────────────────────────────────
    // Reuses the application form's specimen pattern (DataCollectionStep.astro): a
    // display cds-table plus an "Add specimen" modal. Extended with per-row Edit
    // (the modal doubles as an editor, the same way the condition modal does), so
    // the analyst can correct a row without deleting and re-adding it. Every change
    // persists and flows to the letter's authorized-collection table.
    const specBody = $('specimen-body');
    const specEmpty = $('specimen-empty');
    const specModal = $('specimen-modal') as any;
    const specHeading = $('specimen-modal-heading');
    const specSaveBtn = $('ns-save') as any;
    const NS_IDS = ['ns-species', 'ns-quantity', 'ns-portion', 'ns-condition'] as const;
    let editingSpecIndex: number | null = null;

    const renderSpecimensInput = () => {
      if (!specBody) return;
      specBody.innerHTML = state.specimens.map((s, i) => `
        <cds-table-row>
          <cds-table-cell>${esc(s.species) || '—'}</cds-table-cell>
          <cds-table-cell>${esc(s.quantity) || '—'}</cds-table-cell>
          <cds-table-cell>${esc(s.portion) || '—'}</cds-table-cell>
          <cds-table-cell>${esc(s.condition) || '—'}</cds-table-cell>
          <cds-table-cell>
            <cds-icon-button kind="ghost" size="sm" data-edit-specimen="${i}">
              ${editIcon}<span slot="tooltip-content">Edit specimen</span>
            </cds-icon-button>
            <cds-icon-button kind="ghost" size="sm" data-remove-specimen="${i}">
              ${trashIcon}<span slot="tooltip-content">Remove specimen</span>
            </cds-icon-button>
          </cds-table-cell>
        </cds-table-row>`).join('');
      if (specEmpty) (specEmpty as HTMLElement).hidden = state.specimens.length > 0;
    };

    const openSpecimenModal = (index: number | null) => {
      editingSpecIndex = index;
      const s = index !== null ? state.specimens[index] : null;
      if (specHeading) specHeading.textContent = index !== null ? 'Edit specimen' : 'Add a specimen type';
      if (specSaveBtn) specSaveBtn.textContent = index !== null ? 'Save specimen' : 'Add specimen';
      ($('ns-species') as any).value = s?.species ?? '';
      ($('ns-quantity') as any).value = s?.quantity ?? '';
      ($('ns-portion') as any).value = s?.portion ?? '';
      ($('ns-condition') as any).value = s?.condition ?? '';
      if (specModal) specModal.open = true;
    };

    $('add-specimen')?.addEventListener('click', () => openSpecimenModal(null));
    if (specBody) {
      specBody.addEventListener('click', (e) => {
        const ed = (e.target as HTMLElement).closest?.('[data-edit-specimen]') as HTMLElement | null;
        if (ed) { openSpecimenModal(Number(ed.dataset.editSpecimen)); return; }
        const rm = (e.target as HTMLElement).closest?.('[data-remove-specimen]') as HTMLElement | null;
        if (rm) {
          state.specimens.splice(Number(rm.dataset.removeSpecimen), 1);
          persistFinal(); renderSpecimensInput(); renderPreview();
        }
      });
    }
    specSaveBtn?.addEventListener('click', () => {
      const val = (id: string) => (($(id) as any)?.value ?? '').toString().trim();
      const species = val('ns-species');
      // Species is the identifying field — bail to it if empty, so no blank row.
      if (!species) { ($('ns-species') as any)?.focus(); return; }
      const entry = { species, quantity: val('ns-quantity'), portion: val('ns-portion'), condition: val('ns-condition') };
      if (editingSpecIndex !== null) state.specimens[editingSpecIndex] = entry;
      else state.specimens.push(entry);
      if (specModal) specModal.open = false;
      persistFinal(); renderSpecimensInput(); renderPreview();
    });

    // ── Conditions builder ───────────────────────────────────────────────────────
    // A condition is fundamentally the TEXT that prints — the title is only a
    // catalog label. So each applied condition shows its actual text (the analyst
    // sees what will print), with full control per scope: remove defaults, add
    // from the catalog, WRITE one from scratch, and REORDER — for HQ and each
    // district. Numbers mirror the letter's continuous numbering exactly.
    const conditionsInput = $('conditions-input')!;
    const owners = ['hq', ...data.districtKeys];
    // Which scope sections are expanded. Starts all-open (unchanged view), and
    // survives the innerHTML rebuilds in renderConditionsInput so collapsing a
    // section sticks across add / edit / remove / reorder.
    const openGroups = new Set(owners);

    const chevronUp = '<svg slot="icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" width="16" height="16" fill="currentColor" aria-hidden="true"><path d="M8 5 13 10 12.3 10.7 8 6.4 3.7 10.7 3 10z"/></svg>';
    const chevronDown = '<svg slot="icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" width="16" height="16" fill="currentColor" aria-hidden="true"><path d="M8 11 3 6 3.7 5.3 8 9.6 12.3 5.3 13 6z"/></svg>';

    // Text preview of a condition — resolves the annual-report date the same way
    // the letter does, so the builder and the letter agree.
    const condDisplayHtml = (c: PermitCondition) =>
      c.inventoryId === 'hq-annual'
        ? `<p>A summary report is due by ${fmt(state.reportISO)}.</p>`
        : c.body;
    const condPreview = (c: PermitCondition) => plainText(condDisplayHtml(c));

    const editIcon = '<svg slot="icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" width="16" height="16" fill="currentColor" aria-hidden="true"><path d="M2 26H30V28H2zM25.4 9c.8-.8.8-2 0-2.8l-3.6-3.6c-.8-.8-2-.8-2.8 0l-15 15V24h6.4L25.4 9zM20.4 4L24 7.6l-3 3L17.4 7zM8 22v-3.6l10-10L21.6 12l-10 10z"/></svg>';

    const renderConditionsInput = () => {
      // Continuous letter numbering across HQ then each district, in owner order.
      let running = 0;
      const numById: Record<string, number> = {};
      for (const owner of owners) for (const c of state.conditions.filter((x) => x.owner === owner)) numById[c.id] = ++running;

      conditionsInput.innerHTML = `<cds-accordion>${owners.map((owner) => {
        const applied = state.conditions.filter((c) => c.owner === owner);
        const cards = applied.map((c, i) => `
          <li class="cond">
            <div class="cond__bar">
              <span class="cond__num">${numById[c.id]}</span>
              <div class="cond__actions">
                <cds-icon-button kind="ghost" size="sm" data-move-cond="${c.id}" data-dir="-1" ${i === 0 ? 'disabled' : ''}>
                  ${chevronUp}<span slot="tooltip-content">Move up</span>
                </cds-icon-button>
                <cds-icon-button kind="ghost" size="sm" data-move-cond="${c.id}" data-dir="1" ${i === applied.length - 1 ? 'disabled' : ''}>
                  ${chevronDown}<span slot="tooltip-content">Move down</span>
                </cds-icon-button>
                <cds-icon-button kind="ghost" size="sm" data-edit-cond="${c.id}">
                  ${editIcon}<span slot="tooltip-content">Edit condition</span>
                </cds-icon-button>
                <cds-icon-button kind="ghost" size="sm" data-remove-cond="${c.id}">
                  ${trashIcon}<span slot="tooltip-content">Remove condition</span>
                </cds-icon-button>
              </div>
            </div>
            <p class="cond__text t-body-01">${esc(condPreview(c))}</p>
          </li>`).join('');
        return `
          <cds-accordion-item data-cond-group="${owner}" ${openGroups.has(owner) ? 'open' : ''}>
            <div slot="title" class="cond-acc__title">
              <span class="subgroup__name t-heading-compact-01">${ownerLabel(owner)}</span>
              <cds-tag type="gray" size="sm">${applied.length}</cds-tag>
            </div>
            <ul class="cond-list">${cards || '<li class="cond cond--empty t-label-01">No conditions applied.</li>'}</ul>
            <cds-button kind="tertiary" size="sm" data-add-cond="${owner}">Add condition</cds-button>
          </cds-accordion-item>`;
      }).join('')}</cds-accordion>`;
    };

    // Reorder WITHIN an owner scope (a district condition can't jump into HQ).
    const moveCondition = (id: string, dir: number) => {
      const item = state.conditions.find((c) => c.id === id);
      if (!item) return;
      const group = state.conditions.filter((c) => c.owner === item.owner);
      const gi = group.findIndex((c) => c.id === id);
      const ni = gi + dir;
      if (ni < 0 || ni >= group.length) return;
      [group[gi], group[ni]] = [group[ni], group[gi]];
      // Write the reordered group back into the slots it already occupied.
      let g = 0;
      state.conditions = state.conditions.map((c) => (c.owner === item.owner ? group[g++] : c));
      persistConditions(); renderConditionsInput(); renderPreview();
    };

    // ── Add / edit modal ─ the SAME pattern as the permit detail page: ONE dialog
    // per scope that adds catalog picks and/or a written-from-scratch condition,
    // and edits an existing one. Catalog picker + save-to-catalog show only when
    // adding. A condition IS its text — the rich-text body is the whole thing.
    const condModal = $('cond-modal') as any;
    const pickEl = () => $('cond-pick') as any;
    const pickBlock = $('cond-pick-block') as HTMLElement | null;
    const bodyModalEl = () => $('cond-body') as any;
    const saveCatalogEl = () => $('cond-save-catalog') as any;
    const warnEl = $('cond-modal-warning') as any;
    const ownerLabelEl = $('cond-modal-owner');
    const headingEl = $('cond-modal-heading');
    let modalOwner: ConditionOwner = 'hq';
    let editingId: string | null = null;

    // A short plain-text preview identifies a catalog item in the picker.
    const previewText = (html: string) => { const s = plainText(html); return s.length > 90 ? `${s.slice(0, 89)}…` : s; };

    // The owner's saved catalog items not already applied to this permit.
    const buildPicker = (owner: ConditionOwner) => {
      const el = pickEl();
      if (!el) return;
      const appliedInvIds = new Set(state.conditions.filter((c) => c.inventoryId).map((c) => c.inventoryId));
      const available = loadInventory(owner)
        .filter((it) => !appliedInvIds.has(it.id))
        .sort((a, b) => plainText(a.body).localeCompare(plainText(b.body)));
      el.innerHTML = available.map((it) => `<cds-multi-select-item value="${it.id}">${esc(previewText(it.body))}</cds-multi-select-item>`).join('');
    };

    const openConditionModal = (owner: ConditionOwner, id: string | null) => {
      modalOwner = owner;
      editingId = id;
      const editing = id !== null;
      const c = editing ? state.conditions.find((x) => x.id === id) ?? null : null;
      if (headingEl) headingEl.textContent = editing ? 'Edit condition' : 'Add condition';
      if (ownerLabelEl) ownerLabelEl.textContent = ownerLabel(owner);
      if (warnEl) warnEl.hidden = true;
      // Catalog picker + save-to-catalog only make sense when adding.
      if (pickBlock) pickBlock.hidden = editing;
      if (saveCatalogEl()) { saveCatalogEl().hidden = editing; saveCatalogEl().checked = false; }
      if (!editing) buildPicker(owner);
      if (bodyModalEl()) bodyModalEl().value = c?.body ?? '';
      if (condModal) condModal.open = true;
    };

    const selectedInventoryIds = (): string[] => {
      const el = pickEl();
      if (!el) return [];
      return Array.from(el.querySelectorAll('cds-multi-select-item'))
        .filter((i: any) => i.selected)
        .map((i: any) => i.getAttribute('value') || '')
        .filter(Boolean);
    };

    const saveFromModal = () => {
      const body = (bodyModalEl()?.value ?? '').toString().trim();

      // Edit mode — update the existing condition's text in place.
      if (editingId !== null) {
        if (body) {
          state.conditions = state.conditions.map((c) => (c.id === editingId ? { ...c, body } : c));
          persistConditions();
        }
        if (condModal) condModal.open = false;
        renderConditionsInput(); renderPreview();
        return;
      }

      // Add mode — catalog picks and/or a written condition.
      const inventory = loadInventory(modalOwner);
      const additions: PermitCondition[] = [];
      selectedInventoryIds().forEach((invId) => {
        const it = inventory.find((x) => x.id === invId);
        if (it && !state.conditions.some((c) => c.inventoryId === invId)) {
          additions.push({ id: newConditionId(modalOwner === 'hq' ? 'hq' : modalOwner), owner: modalOwner,
            source: 'inventory', inventoryId: it.id, body: it.body,
            addedBy: data.currentUser, addedAt: 'Finalizing' });
        }
      });
      if (body) {
        additions.push({ id: newConditionId(modalOwner === 'hq' ? 'hq' : modalOwner), owner: modalOwner,
          source: 'custom', body, addedBy: data.currentUser, addedAt: 'Finalizing' });
        if (saveCatalogEl()?.checked) {
          const inv = loadInventory(modalOwner);
          inv.push({ id: newConditionId(modalOwner === 'hq' ? 'hq' : modalOwner), owner: modalOwner,
            body, isDefault: false });
          saveInventory(modalOwner, inv);
        }
      }
      if (!additions.length) { if (warnEl) warnEl.hidden = false; return; }
      state.conditions = [...state.conditions, ...additions];
      persistConditions();
      if (condModal) condModal.open = false;
      renderConditionsInput(); renderPreview();
    };
    $('cond-modal-save')?.addEventListener('click', saveFromModal);

    conditionsInput.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      const rm = target.closest?.('[data-remove-cond]') as HTMLElement | null;
      if (rm) {
        state.conditions = state.conditions.filter((c) => c.id !== rm.dataset.removeCond);
        persistConditions(); renderConditionsInput(); renderPreview();
        return;
      }
      const mv = target.closest?.('[data-move-cond]') as HTMLElement | null;
      if (mv) { moveCondition(mv.dataset.moveCond!, Number(mv.dataset.dir)); return; }
      const ed = target.closest?.('[data-edit-cond]') as HTMLElement | null;
      if (ed) {
        const c = state.conditions.find((x) => x.id === ed.dataset.editCond);
        if (c) openConditionModal(c.owner, c.id);
        return;
      }
      const ad = target.closest?.('[data-add-cond]') as HTMLElement | null;
      if (ad) { openConditionModal(ad.dataset.addCond!, null); return; }
    });

    // Remember which scope sections are collapsed so a rebuild doesn't reopen them.
    conditionsInput.addEventListener('cds-accordion-item-toggled', (e: any) => {
      const owner = (e.target as HTMLElement)?.dataset?.condGroup;
      if (!owner) return;
      if (e.detail.open) openGroups.add(owner);
      else openGroups.delete(owner);
    });

    // ── Date pickers ──────────────────────────────────────────────────────────────
    const windowPicker = $('fb-window') as any;
    const reportPicker = $('fb-report') as any;
    if (windowPicker) windowPicker.value = `${state.startISO}/${state.endISO}`;
    if (reportPicker) reportPicker.value = state.reportISO;
    windowPicker?.addEventListener('cds-date-picker-changed', (e: any) => {
      const dates: Date[] = e.detail?.selectedDates || [];
      if (dates[0]) state.startISO = toISO(dates[0]);
      if (dates[1]) state.endISO = toISO(dates[1]);
      if (!state.reportOverridden) { state.reportISO = plusYear(state.startISO); if (reportPicker) reportPicker.value = state.reportISO; }
      persistFinal(); renderPreview();
    });
    reportPicker?.addEventListener('cds-date-picker-changed', (e: any) => {
      const d: Date | undefined = e.detail?.selectedDates?.[0];
      if (d) { state.reportISO = toISO(d); state.reportOverridden = true; persistFinal(); renderPreview(); }
    });

    // ── Reviewer note ─────────────────────────────────────────────────────────────
    const noteEl = $('fb-note') as any;
    if (noteEl) noteEl.value = state.note;
    noteEl?.addEventListener('input', () => { state.note = noteEl.value; persistFinal(); renderPreview(); });

    // ── Live letter preview (modeled on the real template) ──────────────────────
    // Rendered into EVERY .letter-host — the finalize step's live preview AND the
    // package step's read-through — so they can never show different letters.
    const letterHosts = [...document.querySelectorAll<HTMLElement>('.letter-host')];
    const identityRecap = $('identity-recap');
    const packageRecap = $('package-recap');
    const today = new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
    const conditionBody = (c: PermitCondition) =>
      c.inventoryId === 'hq-annual'
        ? `<p>A summary report is due by <strong>${fmt(state.reportISO)}</strong>.</p>`
        : c.body;

    const renderPreview = () => {
      const f = state.fields;
      // Standard (HQ) conditions numbered continuously, then district-specific
      // sections that continue the numbering — as the template lays it out.
      let n = 0;
      const hqItems = state.conditions.filter((c) => c.owner === 'hq')
        .map((c) => `<li value="${++n}">${conditionBody(c)}</li>`).join('');
      const districtCondBlocks = data.districtKeys.map((key) => {
        const applied = state.conditions.filter((c) => c.owner === key);
        if (!applied.length) return '';
        const name = districts.find((d) => d.key === key)?.name ?? ownerLabel(key);
        const lis = applied.map((c) => `<li value="${++n}">${conditionBody(c)}</li>`).join('');
        return `<p class="ltr__cond-owner t-label-01">Special Conditions for ${name}</p><ol class="ltr__conditions">${lis}</ol>`;
      }).join('');

      // Contact List for Parks — a block per district (name + office phone, the
      // coordinator, and the authorized parks the applicant may work in).
      const contactBlocks = districts.map((d) => {
        const current = state.parks[d.name] || [];
        const c = contactFor(d.name);
        const coordLine = c ? `${c.name}${c.phone ? ` · ${c.phone}` : ''}${c.email ? ` · ${c.email}` : ''}` : '';
        return `
          <div class="ltr__contact">
            <div class="ltr__contact-head">
              <p class="ltr__district-name t-heading-compact-01">${d.name}</p>
              ${d.officePhone ? `<p class="ltr__coord t-label-01">District Office: ${d.officePhone}</p>` : ''}
              ${coordLine ? `<p class="ltr__coord t-label-01">${esc(coordLine)}</p>` : ''}
            </div>
            <ul class="ltr__parks">${current.map((p) => `<li class="t-body-01">${p}</li>`).join('') || '<li class="t-body-01">—</li>'}</ul>
          </div>`;
      }).join('');

      const noteSection = state.note.trim()
        ? `<p class="ltr__body t-body-01"><em>${esc(state.note).replace(/\n/g, '<br>')}</em></p>`
        : '';

      // Authorized collection — the taxa/quantities table (step ① specimens).
      const specimenRows = state.specimens
        .map((s) => `<tr><td>${esc(s.species) || '—'}</td><td>${esc(s.quantity) || '—'}</td><td>${esc(s.portion) || '—'}</td><td>${esc(s.condition) || '—'}</td></tr>`)
        .join('');
      const collectionSection = state.specimens.length
        ? `<hr class="ltr__pagebreak">
           <p class="ltr__h t-heading-compact-01">AUTHORIZED COLLECTION</p>
           <p class="ltr__body t-body-01">Collection is limited to the following taxa and quantities:</p>
           <table class="ltr__specimens">
             <thead><tr><th>Species</th><th>Quantity</th><th>Portion</th><th>Condition</th></tr></thead>
             <tbody>${specimenRows}</tbody>
           </table>`
        : '';

      const letterHTML = `
        <header class="ltr__letterhead">
          <p class="t-label-01">State of California — Natural Resources Agency · Gavin Newsom, Governor</p>
          <p class="ltr__dept t-heading-compact-01">DEPARTMENT OF PARKS AND RECREATION</p>
          <p class="t-label-01">Armando Quintero, Director · P.O. Box 942896, Sacramento, CA 94296-0001</p>
        </header>

        <p class="ltr__date t-body-01">${today}</p>
        <address class="ltr__to t-body-01">${esc(f.piName)}<br>${esc(f.department)}<br>${esc(f.institution)}<br>${esc(f.street)}<br>${esc(f.cityStateZip)}</address>
        <p class="ltr__body t-body-01">Dear ${esc(f.salutation)} ${esc(f.piName)}:</p>
        <p class="ltr__body t-body-01">Enclosed is your ${esc(f.permitType)} permit for studying <strong>${esc(f.projectTitle)}</strong> within selected units of the California State Park System. It is a policy of this office to issue permits annually, so this permit is valid from <strong>${fmt(state.startISO)}</strong> to <strong>${fmt(state.endISO)}</strong>. Each year, you may request a renewal of this permit before it expires.</p>
        <p class="ltr__body t-body-01">Please read all the conditions that apply to this permit carefully. You are prohibited from conducting research activities in any park units until you contact the appropriate district permit coordinator (see the attached list of contacts) and receive permission to begin field work.</p>
        <p class="ltr__body t-body-01">As a reminder, you are required to submit a summary report of your activities by <strong>${fmt(state.reportISO)}</strong>, as well as a final report and any associated data products within one month of their completion.</p>
        <p class="ltr__body t-body-01">Sincerely,</p>
        <div class="ltr__signer t-body-01">
          <div class="ltr__sig-line"></div>
          ${esc(f.signerName)}<br>${esc(f.signerClassification)}<br>Natural Resources Division<br>California Department of Parks and Recreation<br>nrd.research@parks.ca.gov
        </div>

        <hr class="ltr__pagebreak">
        <p class="ltr__h t-heading-compact-01">SPECIAL PERMIT CONDITIONS</p>
        <p class="ltr__body t-body-01">${esc(f.piName)}, ${esc(f.institution)}<br>${esc(f.projectTitle)} · ${esc(f.category)}<br>Permit valid from ${fmt(state.startISO)} through ${fmt(state.endISO)}</p>
        <p class="ltr__body t-body-01">In addition to the Standard Conditions and Restrictions stated on the Application and Permit to Conduct Scientific Research and Collections, the following conditions are applied:</p>
        <ol class="ltr__conditions">${hqItems}</ol>
        ${districtCondBlocks}
        ${noteSection}
        ${collectionSection}

        <hr class="ltr__pagebreak">
        <p class="ltr__h t-heading-compact-01">Contact List for Parks</p>
        <p class="ltr__body t-body-01">You MUST notify the district contacts identified below prior to activities in their respective park units. Two weeks' notice is required. Districts retain final approval authority.</p>
        ${contactBlocks}`;

      letterHosts.forEach((h) => (h.innerHTML = letterHTML));

      // Read-only identity recap on the finalize step (reflects step ① edits).
      if (identityRecap) {
        identityRecap.innerHTML = `
          <p class="recap__line t-body-01"><strong>${esc(f.salutation)} ${esc(f.piName)}</strong></p>
          <p class="recap__line t-body-01">${esc(f.department)}</p>
          <p class="recap__line t-body-01">${esc(f.institution)}</p>
          <p class="recap__line t-body-01">${esc(f.street)}, ${esc(f.cityStateZip)}</p>
          <p class="recap__line recap__line--muted t-label-01">Project: ${esc(f.projectTitle)}</p>`;
      }

      // Package recap on the send step — the key facts being issued.
      if (packageRecap) {
        const total = state.conditions.length;
        const parkCount = Object.values(state.parks).reduce((a, p) => a + p.length, 0);
        const typeLabel = f.permitType === 'single-district' ? 'Single-district permit' : 'Multi-district permit';
        const specCount = state.specimens.length;
        const rows: [string, string][] = [
          ['Permit type', typeLabel],
          ['Category', esc(f.category)],
          ['Valid window', `${fmt(state.startISO)} – ${fmt(state.endISO)}`],
          ['Summary report due', fmt(state.reportISO)],
          ['Special conditions', `${total} attached`],
          ['Authorized parks', `${parkCount} across ${districts.length} district${districts.length === 1 ? '' : 's'}`],
          ['Authorized specimens', `${specCount} ${specCount === 1 ? 'taxon' : 'taxa'}`],
          ['Signed by', `${esc(f.signerName)} · ${esc(f.signerClassification)}`],
        ];
        packageRecap.innerHTML = rows.map(([k, v]) => `
          <div class="recap__row">
            <span class="recap__key t-label-01">${k}</span>
            <span class="recap__val t-body-01">${v}</span>
          </div>`).join('');
      }
    };

    // ── Send for signature ──────────────────────────────────────────────────────
    const sendModal = $('send-modal') as any;
    $('send-confirm')?.addEventListener('click', () => {
      persistFinal(); persistParks(); persistConditions();
      localStorage.setItem(statusKey, 'Out for signature');
      window.location.href = data.permitUrl;
    });

    // ── Wizard paging ────────────────────────────────────────────────────────────
    const PAGES = data.pages.length;
    const progress = $('wiz-progress') as any;
    const panels = [...document.querySelectorAll<HTMLElement>('.step')];
    const backBtn = $('wiz-back') as any;
    const nextBtn = $('wiz-next') as any;
    // The action bar sits under the left content section, so its column tracks each
    // step's main column: ① review col-10, ② letter col-7, ③ package col-12/start-3.
    const actionsInner = document.querySelector<HTMLElement>('.wiz-actions__inner');
    const ACTION_COLS = [['cds--lg:col-span-10'], ['cds--lg:col-span-7'], ['cds--lg:col-span-12', 'cds--lg:col-start-3']];
    const ALL_ACTION_COLS = ['cds--lg:col-span-10', 'cds--lg:col-span-7', 'cds--lg:col-span-12', 'cds--lg:col-start-3'];
    const headEyebrow = $('page-head-eyebrow');
    const headTitle = $('page-head-title');
    const headSub = $('page-head-sub');
    let current = Math.min(PAGES - 1, Math.max(0, parseInt(localStorage.getItem(stepKey) || '0', 10) || 0));

    const render = (scroll = false) => {
      panels.forEach((p) => (p.hidden = Number(p.dataset.step) !== current));
      if (progress) progress.currentIndex = current;
      const page = data.pages[current];
      if (headEyebrow) headEyebrow.textContent = `Step ${current + 1} of ${PAGES}`;
      if (headTitle) headTitle.textContent = page.label;
      if (headSub) headSub.textContent = page.secondaryLabel;
      if (backBtn) backBtn.hidden = current === 0;
      if (actionsInner) { actionsInner.classList.remove(...ALL_ACTION_COLS); actionsInner.classList.add(...ACTION_COLS[current]); }
      const last = current === PAGES - 1;
      if (nextBtn) nextBtn.textContent = last ? 'Send for signature' : 'Save and continue';
      if (scroll) window.scrollTo({ top: 0, behavior: 'smooth' });
    };
    const goTo = (i: number) => { current = Math.min(PAGES - 1, Math.max(0, i)); localStorage.setItem(stepKey, String(current)); render(true); };
    if (progress) progress.onChange = (e: CustomEvent<{ index: number }>) => goTo(e.detail.index);
    backBtn?.addEventListener('click', () => goTo(current - 1));
    nextBtn?.addEventListener('click', () => { if (current === PAGES - 1) { sendModal.open = true; return; } goTo(current + 1); });
    // The header's "Approve permit" action jumps to the "Review & send" step —
    // the last step, where the package is confirmed and sent for signature.
    const sendStep = data.pages.findIndex((p) => p.id === 'package');
    document.addEventListener('permit:approve', () => goTo(sendStep < 0 ? PAGES - 1 : sendStep));

    // ── Comments: always-available thread, shared with the permit tab ───────────
    // Stored under the SAME key the permit detail page uses, so it's one
    // conversation. New comments also record the wizard step they were written on,
    // so the team can see (and jump to) the context — while seed/permit-tab
    // comments simply carry no step tag.
    interface StoredComment { author: string; time: string; text: string; page?: number }
    const commentsKey = `permit-comments-${permitId}`;
    const panel = $('comments-panel') as any;
    const thread = $('comments-thread')!;
    const countEl = $('comments-count')!;
    const commentInput = $('comments-input') as any;
    const loadComments = (): StoredComment[] => {
      try { const a = JSON.parse(localStorage.getItem(commentsKey) || '[]'); return Array.isArray(a) ? a : []; }
      catch { return []; }
    };
    const initials = (name: string) => name.replace(/^(Dr\.?|Prof\.?)\s+/i, '').split(/\s+/).filter(Boolean).slice(0, 2).map((w) => w[0]?.toUpperCase() ?? '').join('');
    // Mirror the permit page's comment pattern: avatar + a single "author · time"
    // meta line, then the text (and an optional step-jump chip).
    const buildComment = (c: StoredComment): HTMLElement => {
      const li = document.createElement('li'); li.className = 'comment';
      const av = document.createElement('span'); av.className = 'comment__avatar'; av.textContent = initials(c.author); av.setAttribute('aria-hidden', 'true');
      const body = document.createElement('div'); body.className = 'comment__body';
      const meta = document.createElement('p'); meta.className = 'comment__meta t-label-01';
      const who = document.createElement('span'); who.className = 'comment__author'; who.textContent = c.author;
      meta.append(who, document.createTextNode(` · ${c.time}`));
      const text = document.createElement('p'); text.className = 'comment__text t-body-01'; text.textContent = c.text;
      body.append(meta, text);
      // Step context (new comments only) — a jump chip back to where it was written.
      if (typeof c.page === 'number' && data.pages[c.page]) {
        const chip = document.createElement('cds-button') as any;
        chip.setAttribute('kind', 'ghost'); chip.setAttribute('size', 'sm'); chip.className = 'comment__page';
        chip.textContent = `on ${data.pages[c.page].label}`;
        chip.addEventListener('click', () => { goTo(c.page as number); closePanel(); });
        body.append(chip);
      }
      li.append(av, body);
      return li;
    };
    const paintCount = () => {
      const n = data.comments.length + loadComments().length;
      countEl.textContent = String(n);
      (countEl as HTMLElement).hidden = n === 0;
    };
    const renderThread = () => {
      thread.innerHTML = '';
      // Newest-first: stored (already unshifted newest-first) above the seed thread.
      [...loadComments(), ...data.comments].forEach((c) => thread.appendChild(buildComment(c)));
      paintCount();
    };
    const addComment = () => {
      const text = (commentInput.value ?? '').trim();
      if (!text) { commentInput.focus(); return; }
      const time = new Date().toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
      const list = loadComments();
      list.unshift({ author: data.currentUser, time, text, page: current });
      localStorage.setItem(commentsKey, JSON.stringify(list));
      commentInput.value = '';
      renderThread();
      commentInput.focus();
    };
    const openPanel = () => {
      panel.classList.add('drawer--open');
      panel.setAttribute('aria-hidden', 'false');
      commentInput?.focus?.();
    };
    const closePanel = () => {
      panel.classList.remove('drawer--open');
      panel.setAttribute('aria-hidden', 'true');
      ($('comments-open') as any)?.focus?.();
    };
    $('comments-open')?.addEventListener('click', openPanel);
    $('comments-close')?.addEventListener('click', closePanel);
    $('comments-add')?.addEventListener('click', addComment);
    commentInput?.addEventListener('keydown', (e: KeyboardEvent) => {
      if ((e.metaKey || e.ctrlKey) && e.key === 'Enter') { e.preventDefault(); addComment(); }
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && panel.classList.contains('drawer--open')) closePanel();
    });
    renderThread();

    refreshPermitType();
    renderStudyAreas();
    renderFbParks();
    renderContacts();
    renderSpecimensInput();
    renderConditionsInput();
    renderPreview();
    render(false);
  </script>

  <style>
    .page { padding-block: 0 var(--cds-spacing-10, 4rem); }

    /* The identity header is the shared PermitHeader component (its own g100
       banner + compact-bar-on-scroll behavior + styles). */

    .wiz-track { margin-top: var(--cds-spacing-07, 2rem); }

    .page-head { margin-top: var(--cds-spacing-07, 2rem); }
    .page-head__inner { max-width: 46rem; padding-bottom: var(--cds-spacing-05, 1rem); border-bottom: 1px solid var(--cds-border-subtle-01, #e0e0e0); }
    .page-head__eyebrow { margin: 0 0 var(--cds-spacing-02, 0.25rem); color: var(--cds-text-secondary, #525252); }
    .page-head__title { margin: 0; }
    .page-head__sub { margin: 0.25rem 0 0; color: var(--cds-text-secondary, #525252); }

    /* Each step is its own grid, toggled one at a time. A hidden step collapses
       (the [hidden] attr-selector out-specifies .cds--css-grid's display:grid). */
    .step { margin-top: var(--cds-spacing-07, 2rem); }
    .step[hidden] { display: none; }
    .col-main, .col-fields, .col-package { min-width: 0; }

    /* Conditions rail (step ①) — the analyst's working panel, on a raised layer. */
    .col-rail { min-width: 0; }
    .rail { background: var(--cds-layer-01, #f4f4f4); border: 1px solid var(--cds-border-subtle-01, #e0e0e0); padding: var(--cds-spacing-06, 1.5rem); }
    @media (min-width: 66.01rem) { .rail { position: sticky; top: 4rem; } }
    @media (min-width: 66.01rem) { .rail { max-height: calc(100vh - 5rem); overflow-y: auto; } }
    .rail__title { margin: 0 0 var(--cds-spacing-03, 0.5rem); }
    .rail__sub { margin: 0 0 var(--cds-spacing-05, 1rem); color: var(--cds-text-secondary, #525252); }

    /* Condition cards — the TEXT is the content, shown in full; a source pill and
       optional label caption it, reorder handles on the left, remove on the right. */
    /* Conditions cards are built in the client script via innerHTML, so they never
       carry Astro's scope attribute — style them through :global under the stable
       #conditions-input host (same pattern as the .sheet :global(.ltr__*) rules). */
    #conditions-input :global(.cond-list) { list-style: none; margin: 0 0 var(--cds-spacing-04, 0.75rem); padding: 0; display: grid; gap: var(--cds-spacing-03, 0.5rem); }
    #conditions-input :global(.cond) { display: block; padding: var(--cds-spacing-03, 0.5rem); background: var(--cds-layer-02, #fff); border: 1px solid var(--cds-border-subtle-02, #e0e0e0); }
    #conditions-input :global(.cond--empty) { color: var(--cds-text-secondary, #525252); background: none; border: 0; padding: var(--cds-spacing-02, 0.25rem) 0; }
    #conditions-input :global(.cond__bar) { display: flex; align-items: center; gap: var(--cds-spacing-03, 0.5rem); margin: 0 0 var(--cds-spacing-02, 0.25rem); }
    #conditions-input :global(.cond__num) { display: inline-grid; place-items: center; min-inline-size: 1.25rem; block-size: 1.25rem; padding: 0 0.25rem; border-radius: 0.25rem; background: var(--cds-layer-accent-01, #e0e0e0); color: var(--cds-text-primary, #161616); font-weight: 600; }
    #conditions-input :global(.cond__text) { margin: 0; color: var(--cds-text-primary, #161616); }
    #conditions-input :global(.cond__actions) { display: flex; margin-inline-start: auto; }
    /* Scope sections are collapsible cds-accordion-items; the header title slot
       carries the scope name + count tag inline, filling the toggle's width. */
    #conditions-input :global(.cond-acc__title) { display: flex; align-items: center; gap: var(--cds-spacing-03, 0.5rem); inline-size: 100%; }
    #conditions-input :global(.cond-acc__title .subgroup__name) { margin-inline-end: auto; }

    /* Add/edit modal — "or write a new one" divider + rich-text field label. */
    .cond-or { margin: var(--cds-spacing-03, 0.5rem) 0 0; color: var(--cds-text-secondary, #525252); }
    .cond-field-label { margin: 0 0 var(--cds-spacing-03, 0.5rem); color: var(--cds-text-secondary, #525252); }

    .field-group { display: grid; gap: var(--cds-spacing-04, 0.75rem); margin-bottom: var(--cds-spacing-07, 2rem); }
    .field-group__title { margin: 0; padding-bottom: var(--cds-spacing-02, 0.25rem); border-bottom: 1px solid var(--cds-border-subtle-01, #e0e0e0); }
    .field-hint { margin: 0; color: var(--cds-text-secondary, #525252); }

    /* Read-only identity recap on the finalize step. */
    .recap__head { display: flex; align-items: baseline; justify-content: space-between; gap: var(--cds-spacing-03, 0.5rem); }
    .recap__head .field-group__title { flex: 1 1 auto; }
    .recap { display: grid; gap: 0.125rem; }
    .recap__line { margin: 0; color: var(--cds-text-primary, #161616); }
    .recap__line--muted { margin-top: var(--cds-spacing-02, 0.25rem); color: var(--cds-text-secondary, #525252); }

    /* Permit type is derived, shown read-only. */
    .derived-value { margin: 0; color: var(--cds-text-primary, #161616); }

    /* District contacts (step ②) — a ContactCard tile per district + a reassignment
       picker below it. One group per district. */
    #contacts-input { display: grid; gap: var(--cds-spacing-05, 1rem); }
    .contact-group { display: grid; gap: var(--cds-spacing-04, 0.75rem); }

    .subgroup { display: grid; gap: var(--cds-spacing-03, 0.5rem); margin-bottom: var(--cds-spacing-05, 1rem); }
    .subgroup__head { display: flex; align-items: center; gap: var(--cds-spacing-03, 0.5rem); }
    .subgroup__name { margin: 0; }
    /* Step ② authorized parks reuses step ①'s Study-areas mechanic: a filterable
       multi-select over a selected-parks roster (one flat list). Layout only — the
       controls are stock cds-*. */
    .selected { margin-top: var(--cds-spacing-03, 0.5rem); }
    .selected__label { margin: 0 0 var(--cds-spacing-03, 0.5rem); color: var(--cds-text-secondary, #525252); }
    .col-fields .ro-table { display: block; }

    /* Package step (③) — recap of what's issued, then the letter. */
    .pkg-recap { margin-top: var(--cds-spacing-06, 1.5rem); }
    .pkg-recap__title { margin: 0 0 var(--cds-spacing-05, 1rem); }
    .pkg-letter { margin-top: var(--cds-spacing-08, 2.5rem); }
    .recap__row { display: grid; grid-template-columns: minmax(9rem, 15rem) 1fr; gap: 0.5rem 1.5rem; padding: 0.625rem 0; border-top: 1px solid var(--cds-border-subtle-01, #e0e0e0); }
    .recap__row:first-child { border-top: 0; padding-top: 0; }
    .recap__key { color: var(--cds-text-secondary, #525252); }
    .recap__val { color: var(--cds-text-primary, #161616); }
    @media (max-width: 42rem) { .recap__row { grid-template-columns: 1fr; gap: 0.125rem; } }

    .wiz-actions { margin-top: var(--cds-spacing-08, 2.5rem); }
    .wiz-actions__inner { display: flex; align-items: center; gap: var(--cds-spacing-03, 0.5rem); padding-top: var(--cds-spacing-05, 1rem); border-top: 1px solid var(--cds-border-subtle-01, #e0e0e0); }
    .wiz-actions__spacer { flex: 1 1 auto; }
    #wiz-back[hidden] { display: none; }

    /* carbon-checked: fixed positioning host for a stock cds-button — Carbon ships
       no floating-action container (same pattern as apply.astro's toast-host).
       An OPAQUE layer plate (subtle border + elevation) backs the ghost button so
       its interior never shows scrolling content through — the label stays legible
       over anything behind it, and the shadow reads it as a distinct floating chip. */
    .comments-fab {
      position: fixed; right: var(--cds-spacing-05, 1rem); bottom: var(--cds-spacing-05, 1rem);
      z-index: 8000;
      background: var(--cds-layer-01, #f4f4f4);
      border: 1px solid var(--cds-border-subtle-01, #e0e0e0);
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
    }
    .comments-count {
      display: inline-grid; place-items: center; min-width: 1.25rem; height: 1.25rem;
      margin-inline-start: var(--cds-spacing-03, 0.5rem); padding: 0 0.375rem;
      border-radius: 0.75rem; background: var(--cds-background-inverse, #393939);
      color: var(--cds-text-inverse, #fff); font-size: 0.75rem; line-height: 1;
    }
    .comments-count[hidden] { display: none; }

    /* Slide-over drawer shell (bespoke positioning; controls inside are cds-*). */
    /* A fixed-height flex column: header + note pinned at top, thread scrolls in
       the middle, composer pinned at the bottom (always reachable, no matter how
       long the thread). */
    .drawer {
      position: fixed; top: 0; right: 0; z-index: 8500;
      inline-size: min(28rem, 100%); block-size: 100vh;
      display: flex; flex-direction: column;
      background: var(--cds-layer-01, #f4f4f4);
      border-inline-start: 1px solid var(--cds-border-subtle-01, #e0e0e0);
      box-shadow: 0 0 12px rgba(0, 0, 0, 0.15);
      transform: translateX(100%);
      transition: transform 0.2s ease;
    }
    .drawer--open { transform: none; }
    @media (prefers-reduced-motion: reduce) { .drawer { transition: none; } }
    .drawer__head { flex: none; display: flex; align-items: center; justify-content: space-between; gap: var(--cds-spacing-03, 0.5rem); padding: var(--cds-spacing-05, 1rem) var(--cds-spacing-05, 1rem) var(--cds-spacing-04, 0.75rem); }
    .drawer__title { margin: 0; }

    /* Comments content. */
    .comments-note { flex: none; margin: 0; padding: 0 var(--cds-spacing-05, 1rem) var(--cds-spacing-05, 1rem); color: var(--cds-text-secondary, #525252); }
    /* The only scrolling region — grows to fill, so the composer below stays put. */
    .comments-thread { flex: 1 1 auto; min-height: 0; overflow-y: auto; list-style: none; margin: 0; padding: 0 var(--cds-spacing-05, 1rem) var(--cds-spacing-05, 1rem); display: grid; gap: var(--cds-spacing-05, 1rem); align-content: start; }
    .comment { display: grid; grid-template-columns: auto 1fr; gap: var(--cds-spacing-04, 0.75rem); align-items: start; }
    .comment__avatar {
      inline-size: 2rem; block-size: 2rem; border-radius: 50%;
      display: grid; place-items: center; font-size: 0.75rem; font-weight: 600;
      background: var(--cds-layer-accent-01, #e0e0e0); color: var(--cds-text-primary, #161616);
    }
    .comment__body { min-width: 0; }
    .comment__meta { margin: 0 0 var(--cds-spacing-02, 0.25rem); color: var(--cds-text-secondary, #525252); }
    .comment__author { font-weight: 600; color: var(--cds-text-primary, #161616); }
    .comment__text { margin: 0; }
    .comment__page { display: block; margin-top: var(--cds-spacing-02, 0.25rem); }
    /* Pinned to the bottom of the drawer — always reachable regardless of thread length. */
    .comments-composer { flex: none; display: grid; gap: var(--cds-spacing-04, 0.75rem); justify-items: start; padding: var(--cds-spacing-05, 1rem); border-top: 1px solid var(--cds-border-subtle-01, #e0e0e0); background: var(--cds-layer-01, #f4f4f4); }

    /* ── Live letter preview ── a white document surface, sticky beside the fields. */
    .preview__label { margin: 0 0 var(--cds-spacing-03, 0.5rem); color: var(--cds-text-secondary, #525252); }
    @media (min-width: 66.01rem) { .preview { position: sticky; top: 4rem; align-self: start; } }
    .sheet {
      background: var(--cds-background, #ffffff);
      border: 1px solid var(--cds-border-subtle-01, #e0e0e0);
      padding: var(--cds-spacing-07, 2rem);
      color: var(--cds-text-primary, #161616);
      max-height: calc(100vh - 6rem);
      overflow-y: auto;
    }
    /* On the package step the letter reads through in full — no inner scroll. */
    .pkg-letter .sheet { max-height: none; overflow-y: visible; }
    @media (max-width: 66rem) { .sheet { max-height: none; } }

    .sheet :global(.ltr__letterhead) { border-bottom: 2px solid var(--cds-border-strong-01, #8d8d8d); padding-bottom: var(--cds-spacing-04, 0.75rem); margin-bottom: var(--cds-spacing-06, 1.5rem); }
    .sheet :global(.ltr__letterhead p) { margin: 0; }
    .sheet :global(.ltr__dept) { margin: 0.125rem 0; }
    .sheet :global(.ltr__date) { margin: 0 0 var(--cds-spacing-05, 1rem); }
    .sheet :global(.ltr__to) { font-style: normal; line-height: 1.5; margin: 0 0 var(--cds-spacing-05, 1rem); }
    .sheet :global(.ltr__body) { line-height: 1.6; margin: 0 0 var(--cds-spacing-05, 1rem); }
    .sheet :global(.ltr__signer) { line-height: 1.5; margin: 0 0 var(--cds-spacing-05, 1rem); }
    .sheet :global(.ltr__sig-line) { height: 2rem; width: 16rem; max-width: 100%; border-bottom: 1px solid var(--cds-border-strong-01, #8d8d8d); margin-bottom: var(--cds-spacing-03, 0.5rem); }
    .sheet :global(.ltr__pagebreak) { border: 0; border-top: 1px dashed var(--cds-border-subtle-01, #c6c6c6); margin: var(--cds-spacing-07, 2rem) 0; }
    .sheet :global(.ltr__h) { margin: 0 0 var(--cds-spacing-04, 0.75rem); }
    .sheet :global(.ltr__conditions) { margin: 0 0 var(--cds-spacing-05, 1rem); padding-left: var(--cds-spacing-06, 1.5rem); display: grid; gap: var(--cds-spacing-03, 0.5rem); }
    .sheet :global(.ltr__conditions p) { margin: 0; }
    .sheet :global(.ltr__cond-owner) { margin: var(--cds-spacing-04, 0.75rem) 0 var(--cds-spacing-02, 0.25rem); color: var(--cds-text-secondary, #525252); font-weight: 600; }
    .sheet :global(.ltr__contact) { margin-bottom: var(--cds-spacing-05, 1rem); }
    .sheet :global(.ltr__contact-head) { margin-bottom: var(--cds-spacing-02, 0.25rem); }
    .sheet :global(.ltr__district-name) { margin: 0; }
    .sheet :global(.ltr__coord) { margin: 0.125rem 0 0; color: var(--cds-text-secondary, #525252); }
    .sheet :global(.ltr__parks) { margin: var(--cds-spacing-02, 0.25rem) 0 0; padding-left: var(--cds-spacing-06, 1.5rem); }
    .sheet :global(.ltr__specimens) { width: 100%; border-collapse: collapse; margin: var(--cds-spacing-03, 0.5rem) 0 var(--cds-spacing-05, 1rem); }
    .sheet :global(.ltr__specimens th), .sheet :global(.ltr__specimens td) { text-align: left; vertical-align: top; padding: var(--cds-spacing-02, 0.25rem) var(--cds-spacing-04, 0.75rem) var(--cds-spacing-02, 0.25rem) 0; border-bottom: 1px solid var(--cds-border-subtle-01, #e0e0e0); }
    .sheet :global(.ltr__specimens th) { font-weight: 600; border-bottom-color: var(--cds-border-strong-01, #8d8d8d); }
    .sheet :global(.ltr__specimens td:first-child) { font-style: italic; }

    /* Add/edit-specimen modal — the 2-col field grid, mirroring the application
       form's specimen dialog (Species/Condition span both columns). */
    .spec-fields { display: grid; grid-template-columns: 1fr 1fr; gap: var(--cds-spacing-05, 1rem); }
    .spec-fields__wide { grid-column: 1 / -1; }
  </style>
</BaseLayout>
